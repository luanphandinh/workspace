#!/bin/sh
# Window/session topology changed. Ensure every window has a sidebar when the
# global sidebar is open, then redraw every live sidebar across the tmux server.
WIDTH=22

state="$(tmux show-options -gqv '@pin_sidebar_open' 2>/dev/null || :)"
if [ "$state" = "1" ]; then
	tmux list-windows -aF '#{window_id}' 2>/dev/null |
		while IFS= read -r win; do
			[ -n "$win" ] || continue
			"$HOME/bin/tmux-pin-sidebar-attach" "$win" >/dev/null 2>&1 || :
		done

	tmux list-panes -aF '#{pane_id} #{@pin_sidebar}' 2>/dev/null |
		awk '$2 == "1" { print $1 }' |
		while IFS= read -r pane; do
			[ -n "$pane" ] || continue
			tmux resize-pane -t "$pane" -x "$WIDTH" >/dev/null 2>&1 || :
		done
fi

"$HOME/bin/tmux-pin-broadcast-redraw" >/dev/null 2>&1 || :
tmux refresh-client >/dev/null 2>&1 || :
