#!/bin/sh
# tmux-claude-codex-status — formatted Claude + Codex usage strip for the
# tmux status bar.
#
# Reads /tmp/claude-rate-limits.json, which is written by
# bin/claude-code-statusline whenever Claude Code calls it. So the
# numbers shown here are the SAME official rate-limit percentages
# Claude Code uses internally — not ccusage's dollar cost.
#
# Output format:
#   claude[s 45%|7d 23%] | codex[13% | 2%][18:43|08-06 10:38]
#
# When usage data is missing for either tool, that tool is omitted from
# the status bar. Stale data is still shown with a marker.
RATE_LIMITS_CACHE=${RATE_LIMITS_CACHE:-/tmp/claude-rate-limits.json}
STALE_AFTER_SEC=900   # 15 minutes — flag the line as stale beyond this
CODEX_STATE_DB=${CODEX_STATE_DB:-"$HOME/.codex/state_5.sqlite"}

empty_status() { :; }

join_status() {
	case "$1:$2" in
		:)  empty_status ;;
		:*) printf '%s' "$2" ;;
		*:) printf '%s' "$1" ;;
		*)  printf '%s | %s' "$1" "$2" ;;
	esac
}

fmt_pct() {
	case "$1" in
		n/a|"") printf 'n/a' ;;
		*)      printf '%.0f%%' "$1" ;;
	esac
}

fmt_window() {
	case "$1" in
		''|*[!0-9]*) printf 'usage' ;;
		10080)       printf '7d' ;;
		300)         printf '5h' ;;
		*)
			if [ $(( $1 % 1440 )) -eq 0 ]; then
				printf '%dd' $(( $1 / 1440 ))
			elif [ $(( $1 % 60 )) -eq 0 ]; then
				printf '%dh' $(( $1 / 60 ))
			else
				printf '%sm' "$1"
			fi
			;;
	esac
}

fmt_epoch() {
	ts="${1:-}"
	format="${2:-%H:%M}"
	case "$ts" in
		''|*[!0-9.]*)
			return
			;;
	esac
	ts="${ts%.*}"
	date -r "$ts" +"$format" 2>/dev/null || date -d "@$ts" +"$format" 2>/dev/null || :
}

fmt_usage() {
	pct="$(fmt_pct "$1")"
	reset="$(fmt_epoch "${2:-}" "${3:-%H:%M}")"
	if [ -n "$reset" ]; then
		printf '%s @ %s' "$pct" "$reset"
	else
		printf '%s' "$pct"
	fi
}

file_mtime() {
	stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null || date +%s
}

codex_status() {
	if ! command -v sqlite3 >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
		empty_status
		return
	fi

	if [ ! -f "$CODEX_STATE_DB" ]; then
		empty_status
		return
	fi

	rollout_path=$(sqlite3 -readonly "$CODEX_STATE_DB" \
		"select rollout_path from threads where rollout_path != '' order by updated_at desc limit 1;" 2>/dev/null)
	if [ -z "$rollout_path" ] || [ ! -f "$rollout_path" ]; then
		empty_status
		return
	fi

	read primary_pct secondary_pct primary_window secondary_window primary_reset secondary_reset <<EOF
$(tail -2000 "$rollout_path" | jq -r '
	select(.type == "event_msg" and .payload.type == "token_count") |
	[
		(.payload.rate_limits.primary.used_percent // "n/a"),
		(.payload.rate_limits.secondary.used_percent // "n/a"),
		(.payload.rate_limits.primary.window_minutes // ""),
		(.payload.rate_limits.secondary.window_minutes // ""),
		(.payload.rate_limits.primary.resets_at // ""),
		(.payload.rate_limits.secondary.resets_at // "")
	] | @tsv
' 2>/dev/null | tail -1)
EOF

	if [ -z "$primary_pct" ]; then
		empty_status
		return
	fi

	if { [ -z "$primary_pct" ] || [ "$primary_pct" = "n/a" ]; } &&
		{ [ -z "$secondary_pct" ] || [ "$secondary_pct" = "n/a" ]; }; then
		empty_status
		return
	fi

	now=$(date +%s)
	updated=$(file_mtime "$rollout_path")
	stale_marker=""
	if [ $((now - updated)) -gt "$STALE_AFTER_SEC" ]; then
		stale_marker=" stale"
	fi

	primary_reset_text=$(fmt_epoch "$primary_reset" "%H:%M")
	secondary_reset_text=$(fmt_epoch "$secondary_reset" "%d-%m %H:%M")
	[ -n "$primary_reset_text" ] || primary_reset_text="n/a"
	[ -n "$secondary_reset_text" ] || secondary_reset_text="n/a"

	printf 'codex[%s | %s][%s|%s%s]' \
		"$(fmt_pct "$primary_pct")" "$(fmt_pct "$secondary_pct")" \
		"$primary_reset_text" "$secondary_reset_text" "$stale_marker"
}

if [ ! -f "$RATE_LIMITS_CACHE" ]; then
	join_status "" "$(codex_status)"
	exit 0
fi


# Pull the four fields we care about with jq (already on this machine —
# see bin/tmux-claude-codex-status sibling). Empty-string fallback when
# null so the format string doesn't barf.
read five_pct seven_pct updated <<EOF
$(jq -r '
	[
		(.five_hour_pct // "n/a"),
		(.seven_day_pct // "n/a"),
		(.updated_at   // 0)
	] | @tsv
' "$RATE_LIMITS_CACHE" 2>/dev/null)
EOF

if [ -z "$updated" ] || [ "$updated" = "0" ]; then
	join_status "" "$(codex_status)"
	exit 0
fi

if { [ -z "$five_pct" ] || [ "$five_pct" = "n/a" ]; } &&
	{ [ -z "$seven_pct" ] || [ "$seven_pct" = "n/a" ]; }; then
	join_status "" "$(codex_status)"
	exit 0
fi

# Stale flag — when Claude Code hasn't run for a while the numbers are old.
now=$(date +%s)
age=$((now - ${updated%.*}))
stale_marker=""
if [ "$age" -gt "$STALE_AFTER_SEC" ]; then
	stale_marker=" (stale)"
fi

claude_segment=$(printf 'claude[s %s|7d %s%s]' \
	"$(fmt_pct "$five_pct")" "$(fmt_pct "$seven_pct")" "$stale_marker")

join_status "$claude_segment" "$(codex_status)"
