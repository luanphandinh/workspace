#!/usr/bin/env python3
import os
import shutil
import subprocess
import sys
from pathlib import Path


LINK_ICON = "\uf0c1"


def hub_home() -> Path:
    return Path(os.environ.get("SKILLS_HUB_HOME", "~/.skills-hub")).expanduser()


def cache_file(home: Path) -> Path:
    return home / "execute_plugins"


def groups_dir(home: Path) -> Path:
    return home / "groups"


def die(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    sys.exit(code)


def usage() -> None:
    print(
        """Usage:
  skills-hub add <command>
  skills-hub pull
  skills-hub list [parent]
  skills-hub pick
  skills-hub group create [name]
  skills-hub group update [name]
  skills-hub group pick
  skills-hub where

Commands:
  add   Run <command> inside the managed skills-hub folder, then cache it in execute_plugins.
  pull  Replay every cached command from execute_plugins inside the managed skills-hub folder.
  list  List hub skills grouped by parent folder.
  pick  Pick hub skills with fzf and copy them into the current folder.
  group Save, update, and install named skill groups.
  where Print the managed skills-hub folder path.

Environment:
  SKILLS_HUB_HOME  Managed folder. Default: ~/.skills-hub

Example:
  skills-hub add 'npx skills add example-org/skills-bundle -y'
  skills-hub pull
  skills-hub list agents
  cd "$(skills-hub where)"
"""
    )


def read_commands(path: Path) -> list[str]:
    if not path.is_file():
        return []
    commands = []
    seen = set()
    for line in path.read_text().splitlines():
        command = line.strip()
        if not command or command.startswith("#"):
            continue
        if command in seen:
            continue
        seen.add(command)
        commands.append(command)
    return commands


def write_commands(path: Path, commands: list[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    text = "".join(f"{command}\n" for command in commands)
    path.write_text(text)


def ensure_home(home: Path) -> None:
    home.mkdir(parents=True, exist_ok=True)
    package_json = home / "package.json"
    if not package_json.exists():
        package_json.write_text('{"private": true, "name": "skills-hub"}\n')


def command_from_args(args: list[str]) -> str:
    command = " ".join(args).strip()
    if not command:
        die("missing command")
    if "\n" in command or "\r" in command:
        die("command must be a single line")
    return command


def validate_group_name(name: str) -> str:
    name = name.strip()
    if not name:
        die("group name is required")
    if name in (".", "..") or "/" in name or "\\" in name:
        die("group name must be a simple file name")
    return name


def group_path(home: Path, name: str) -> Path:
    return groups_dir(home) / validate_group_name(name)


def read_group(path: Path) -> list[str]:
    if not path.is_file():
        return []
    skills = []
    seen = set()
    for line in path.read_text().splitlines():
        rel = line.strip()
        if not rel or rel.startswith("#") or rel in seen:
            continue
        seen.add(rel)
        skills.append(rel)
    return skills


def write_group(path: Path, skills: list[str]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    seen = set()
    lines = []
    for rel in skills:
        rel = rel.strip()
        if not rel or rel in seen:
            continue
        seen.add(rel)
        lines.append(rel)
    path.write_text("".join(f"{rel}\n" for rel in lines))


def discover_groups(home: Path) -> list[str]:
    path = groups_dir(home)
    if not path.is_dir():
        return []
    return sorted(item.name for item in path.iterdir() if item.is_file())


def require_fzf() -> None:
    if shutil.which("fzf") is None:
        die("fzf is required")


def run_fzf(choices: list[str], prompt: str, multi: bool = True, print_query: bool = False) -> tuple[int, list[str]]:
    require_fzf()
    args = ["fzf", "--prompt", prompt]
    if multi:
        args.append("--multi")
    if print_query:
        args.append("--print-query")
    proc = subprocess.run(
        args,
        input="\n".join(choices) + ("\n" if choices else ""),
        capture_output=True,
        text=True,
    )
    return proc.returncode, proc.stdout.splitlines()


def run_plugin(command: str, home: Path) -> int:
    ensure_home(home)
    print(f"skills-hub: {home}")
    print(f"skills-hub: running: {command}")
    return subprocess.run(command, shell=True, cwd=str(home)).returncode


def cache_command(command: str, path: Path) -> None:
    commands = read_commands(path)
    if command not in commands:
        commands.append(command)
    write_commands(path, commands)


def copy_skill_dir(src: Path, dst: Path) -> None:
    if dst.is_symlink() or dst.is_file():
        dst.unlink()
    elif dst.exists():
        shutil.rmtree(dst)
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(
        src,
        dst,
        ignore=shutil.ignore_patterns(".git", ".DS_Store", "__pycache__"),
    )


def discover_skill_dirs(home: Path) -> dict[str, Path]:
    if not home.is_dir():
        return {}

    skills = {}
    for skill_md in home.rglob("SKILL.md"):
        skill_dir = skill_md.parent
        if skill_dir.parent.name != "skills":
            continue
        rel = skill_dir.relative_to(home)
        if len(rel.parts) < 3:
            continue
        skills[str(rel)] = skill_dir
    return dict(sorted(skills.items()))


def parent_label(parent: str) -> str:
    if parent == ".agents":
        return "agent"
    return parent.removeprefix(".")


def parent_filter(name: str) -> str:
    name = name.strip()
    if not name:
        die("parent is required")
    if "/" in name or "\\" in name:
        die("parent must be a simple folder name")
    if name in ("agent", "agents"):
        return ".agents"
    if name.startswith("."):
        return name
    return f".{name}"


def group_skills_by_parent(skills: dict[str, Path]) -> dict[str, list[str]]:
    grouped = {}
    for rel in skills:
        parts = Path(rel).parts
        if len(parts) < 3:
            continue
        parent = parts[0]
        skill_rel = str(Path(*parts[2:]))
        grouped.setdefault(parent, []).append(skill_rel)
    return {parent: sorted(set(items)) for parent, items in sorted(grouped.items())}


def color_enabled() -> bool:
    if os.environ.get("NO_COLOR") is not None:
        return False
    return sys.stdout.isatty() or os.environ.get("FORCE_COLOR") not in (None, "", "0")


def green(text: str) -> str:
    if not color_enabled():
        return text
    return f"\033[32m{text}\033[0m"


def global_skill_roots(parent: str) -> list[Path]:
    home = Path.home()
    return [home / parent / "skills"]


def visible_skill_roots(parent: str) -> list[Path]:
    path = Path.cwd()
    roots = [path / parent / "skills"]
    roots.extend(global_skill_roots(parent))
    seen = set()
    deduped = []
    for root in roots:
        if root in seen:
            continue
        seen.add(root)
        deduped.append(root)
    return deduped


def discover_skill_names(root: Path, symlink_skills: set[str] | None = None) -> set[str]:
    skills = set()
    if not root.is_dir():
        return skills

    for child in root.iterdir():
        if child.name.startswith("."):
            continue
        if child.is_symlink():
            skills.add(child.name)
            if symlink_skills is not None:
                symlink_skills.add(child.name)
            continue
        if child.is_dir():
            skills.add(child.name)

    for skill_md in root.rglob("SKILL.md"):
        try:
            rel = skill_md.parent.relative_to(root)
        except ValueError:
            continue
        if rel.parts:
            skills.add(str(rel))
    return skills


def discover_visible_parents() -> set[str]:
    parents = set()
    for base in (Path.cwd(), Path.home()):
        if not base.is_dir():
            continue
        for child in base.iterdir():
            skills_dir = child / "skills"
            if discover_skill_names(skills_dir):
                parents.add(child.name)
    return parents


def discover_visible_skills(parent: str) -> tuple[list[str], set[str]]:
    skills = set()
    symlink_skills = set()
    for root in visible_skill_roots(parent):
        skills.update(discover_skill_names(root, symlink_skills))
    return sorted(skills), symlink_skills


def format_columns(items: list[str], width: int, indent: str = "  ", gap: int = 2) -> list[str]:
    if not items:
        return []

    available = max(1, width - len(indent))
    item_width = max(len(item) for item in items)
    column_width = item_width + gap
    columns = max(1, min(len(items), available // column_width))
    if columns == 1:
        return [f"{indent}{item}" for item in items]

    rows = (len(items) + columns - 1) // columns
    lines = []
    for row in range(rows):
        row_items = []
        for column in range(columns):
            index = row + column * rows
            if index >= len(items):
                continue
            item = items[index]
            if column == columns - 1 or index + rows >= len(items):
                row_items.append(item)
            else:
                row_items.append(item.ljust(column_width))
        lines.append(f"{indent}{''.join(row_items).rstrip()}")
    return lines


def skill_labels(items: list[str], symlink_items: set[str]) -> list[str]:
    return [f"{item} {LINK_ICON}" if item in symlink_items else item for item in items]


def print_skill_columns(items: list[str], width: int, indent: str, active: bool = False, symlink_items: set[str] | None = None) -> None:
    labels = skill_labels(items, symlink_items or set())
    for line in format_columns(labels, width, indent=indent):
        print(green(line) if active else line)


def install_skill_paths(home: Path, selected: list[str]) -> int:
    skills = discover_skill_dirs(home)
    copied = 0
    seen = set()
    for rel in selected:
        rel = rel.strip()
        if not rel or rel in seen:
            continue
        seen.add(rel)
        src = skills.get(rel)
        if src is None:
            die(f"selected skill is not in hub: {rel}")
        dst = Path.cwd() / rel
        copy_skill_dir(src, dst)
        print(f"skills-hub: installed {rel}")
        copied += 1

    print(f"skills-hub: installed {copied} skill(s)")
    return 0


def cmd_add(args: list[str]) -> int:
    home = hub_home()
    path = cache_file(home)
    command = command_from_args(args)
    code = run_plugin(command, home)
    if code != 0:
        return code
    cache_command(command, path)
    print(f"skills-hub: cached: {path}")
    return 0


def cmd_pull() -> int:
    home = hub_home()
    path = cache_file(home)
    commands = read_commands(path)
    if not commands:
        print(f"skills-hub: no commands in {path}")
        return 0

    failed = []
    for command in commands:
        code = run_plugin(command, home)
        if code != 0:
            failed.append((command, code))

    write_commands(path, commands)
    if failed:
        for command, code in failed:
            print(f"skills-hub: failed ({code}): {command}", file=sys.stderr)
        return 1

    print(f"skills-hub: pulled {len(commands)} command(s)")
    return 0


def cmd_list(args: list[str]) -> int:
    if len(args) > 1:
        die("list takes at most one parent")

    home = hub_home()
    ensure_home(home)
    grouped = group_skills_by_parent(discover_skill_dirs(home))
    parents = set(grouped) | discover_visible_parents()
    if args:
        selected_parent = parent_filter(args[0])
        parents = {selected_parent}

    if not parents:
        print(f"skills-hub: no skills found under {home}")
        return 0

    first = True
    terminal_width = shutil.get_terminal_size((80, 20)).columns
    for parent in sorted(parents):
        if not first:
            print()
        first = False
        print(parent_label(parent))
        skills = grouped.get(parent, [])
        hub_symlink_skills = set()
        discover_skill_names(home / parent / "skills", hub_symlink_skills)
        active_skills, active_symlink_skills = discover_visible_skills(parent)
        active_set = set(active_skills)
        available_skills = [skill for skill in skills if skill not in active_set]
        print(green("  active"))
        print_skill_columns(active_skills, terminal_width, indent="    ", active=True, symlink_items=active_symlink_skills)
        print("  available")
        print_skill_columns(available_skills, terminal_width, indent="    ", symlink_items=hub_symlink_skills)
    return 0


def cmd_pick() -> int:
    home = hub_home()
    ensure_home(home)
    skills = discover_skill_dirs(home)
    if not skills:
        print(f"skills-hub: no skills found under {home}")
        return 0

    code, output = run_fzf(list(skills.keys()), "skills-hub> ")
    if code == 130:
        print("skills-hub: no skills selected")
        return 0
    if code != 0:
        return code

    selected = [line.strip() for line in output if line.strip()]
    if not selected:
        print("skills-hub: no skills selected")
        return 0

    return install_skill_paths(home, selected)


def read_group_name_from_stdin() -> str:
    if not sys.stdin.isatty():
        die("group name is required")
    return validate_group_name(input("Group name: "))


def select_group_name(home: Path):
    names = discover_groups(home)
    code, output = run_fzf(names, "skills-group> ", multi=False, print_query=True)
    if code == 130:
        return None
    if code != 0:
        sys.exit(code)

    query = output[0].strip() if output else ""
    selected = [line.strip() for line in output[1:] if line.strip()]
    if selected:
        return validate_group_name(selected[0])
    if query:
        return validate_group_name(query)
    return None


def cmd_group_edit(name: str, create: bool) -> int:
    home = hub_home()
    ensure_home(home)
    path = group_path(home, name)
    if create and path.exists():
        die(f"group already exists: {name}")
    current = [] if create else read_group(path)
    skills = discover_skill_dirs(home)
    if not skills:
        print(f"skills-hub: no skills found under {home}")
        return 0

    current_set = set(current)
    choices = []
    if create:
        choices.extend(skills.keys())
    else:
        choices.extend(f"- {rel}" for rel in current if rel in skills)
        choices.extend(f"- {rel}" for rel in current if rel not in skills)
        choices.extend(f"+ {rel}" for rel in skills if rel not in current_set)

    code, output = run_fzf(choices, "skills-group-skill> ")
    if code == 130:
        print("skills-hub: group unchanged")
        return 0
    if code != 0:
        return code

    members = list(current)
    for line in output:
        line = line.strip()
        if not line:
            continue
        if line.startswith("+ "):
            rel = line[2:].strip()
            if rel and rel not in members:
                members.append(rel)
            continue
        if line.startswith("- "):
            rel = line[2:].strip()
            members = [item for item in members if item != rel]
            continue
        if create and line in skills and line not in members:
            members.append(line)

    write_group(path, members)
    print(f"skills-hub: saved group {path.name} with {len(members)} skill(s)")
    return 0


def cmd_group_pick() -> int:
    home = hub_home()
    ensure_home(home)
    names = discover_groups(home)
    if not names:
        print(f"skills-hub: no groups found under {groups_dir(home)}")
        return 0

    code, output = run_fzf(names, "skills-group> ")
    if code == 130:
        print("skills-hub: no groups selected")
        return 0
    if code != 0:
        return code

    selected_groups = [line.strip() for line in output if line.strip()]
    if not selected_groups:
        print("skills-hub: no groups selected")
        return 0

    selected_skills = []
    seen = set()
    for name in selected_groups:
        path = group_path(home, name)
        for rel in read_group(path):
            if rel in seen:
                continue
            seen.add(rel)
            selected_skills.append(rel)

    return install_skill_paths(home, selected_skills)


def cmd_group(args: list[str]) -> int:
    if not args or args[0] in ("-h", "--help", "help"):
        print(
            """Usage:
  skills-hub group create [name]
  skills-hub group update [name]
  skills-hub group pick
"""
        )
        return 0

    subcommand = args[0]
    rest = args[1:]
    if subcommand == "create":
        if len(rest) > 1:
            die("group create takes at most one name")
        name = validate_group_name(rest[0]) if rest else read_group_name_from_stdin()
        return cmd_group_edit(name, create=True)
    if subcommand == "update":
        if len(rest) > 1:
            die("group update takes at most one name")
        if rest:
            name = validate_group_name(rest[0])
        else:
            selected = select_group_name(hub_home())
            if selected is None:
                print("skills-hub: no group selected")
                return 0
            name = selected
        return cmd_group_edit(name, create=False)
    if subcommand == "pick":
        if rest:
            die("group pick takes no args")
        return cmd_group_pick()

    die(f"unknown group command: {subcommand}")
    return 1


def cmd_where() -> int:
    home = hub_home()
    ensure_home(home)
    print(home)
    return 0


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        usage()
        return 0

    command = sys.argv[1]
    args = sys.argv[2:]
    if command == "add":
        return cmd_add(args)
    if command == "pull":
        if args:
            die("pull takes no args")
        return cmd_pull()
    if command == "list":
        return cmd_list(args)
    if command == "pick":
        if args:
            die("pick takes no args")
        return cmd_pick()
    if command == "group":
        return cmd_group(args)
    if command == "where":
        if args:
            die("where takes no args")
        return cmd_where()

    die(f"unknown command: {command}")
    return 1


if __name__ == "__main__":
    sys.exit(main())
