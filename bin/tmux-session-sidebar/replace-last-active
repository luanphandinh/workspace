#!/bin/sh
# Replace the LAST-ACTIVE pinned session entry in the pin file with the
# current session. No-op when:
#   - the current session is itself already pinned
#   - the pin file is empty
#   - no pinned session has any activity timestamp we can sort on
#
# "Last-active" = the pinned session with the most recent
# session_activity timestamp (when it was last interacted with).
# tmux's #{client_last_session} is consulted first as a fast path; if
# it's a pinned session, we use it directly.
PIN_FILE="${HOME}/.config/tmux/pinned-sessions"
TAB="$(printf '\t')"
[ -f "$PIN_FILE" ] || { tmux display-message "no pinned sessions"; exit 0; }
[ -s "$PIN_FILE" ] || { tmux display-message "no pinned sessions"; exit 0; }

"$HOME/bin/tmux-session-sidebar/sync-pins" >/dev/null 2>&1 || :

current_id="$(tmux display-message -p '#{session_id}')"
current_name="$(tmux display-message -p '#S')"

# Already pinned → ignore per spec.
if awk -F "$TAB" -v id="$current_id" -v name="$current_name" '
	NF >= 2 && ($1 == name || $2 == id) { found = 1 }
	$0 == name || $0 == id { found = 1 }
	END { exit found ? 0 : 1 }
' "$PIN_FILE" 2>/dev/null; then
	tmux display-message "$current_name is already pinned"
	exit 0
fi

# Fast path: previous session for this client.
last_name="$(tmux display-message -p '#{client_last_session}' 2>/dev/null || :)"
last_id=""
if [ -n "$last_name" ]; then
	last_id="$(tmux list-sessions -F '#{session_name}	#{session_id}' 2>/dev/null \
		| awk -F "$TAB" -v n="$last_name" '$1==n{print $2; exit}')"
	if [ -n "$last_id" ] && ! awk -F "$TAB" -v id="$last_id" '
		NF >= 2 && $2 == id { found = 1 }
		$0 == id { found = 1 }
		END { exit found ? 0 : 1 }
	' "$PIN_FILE" 2>/dev/null; then
		last_id=""   # previous session isn't pinned — fall through
	fi
fi

# Slow path: walk every pinned session id, pick the one with greatest activity.
if [ -z "$last_id" ]; then
	last_id="$(awk -F "$TAB" '
		NF >= 2 && $2 != "" { print $2; next }
		/^\$[0-9]+$/ { print }
	' "$PIN_FILE" | while IFS= read -r pid; do
		ts="$(tmux display-message -p -t "$pid" '#{session_activity}' 2>/dev/null || :)"
		[ -n "$ts" ] && printf '%s %s\n' "$ts" "$pid"
	done | sort -rn | awk 'NR==1{print $2}')"
fi

if [ -z "$last_id" ]; then
	tmux display-message "no pinned session is alive — nothing to replace"
	exit 0
fi

# Look up the human-readable name of the slot we're replacing for the toast.
last_name="$(tmux list-sessions -F '#{session_id}	#{session_name}' 2>/dev/null \
	| awk -F "$TAB" -v id="$last_id" '$1==id{print $2; exit}')"

# In-place replace, preserving line order.
tmp="$(mktemp)"
awk -F "$TAB" -v OFS="$TAB" -v old="$last_id" -v new_name="$current_name" -v new_id="$current_id" '
	NF >= 2 && $2 == old { print new_name, new_id; next }
	$0 == old { print new_name, new_id; next }
	{ print }
' "$PIN_FILE" > "$tmp"
mv "$tmp" "$PIN_FILE"

tmux display-message "pin slot ${last_name:-$last_id} → $current_name"
"$HOME/bin/tmux-session-sidebar/broadcast-redraw" >/dev/null 2>&1 || :
