#!/bin/sh
# Switch the attached client to the next/previous pinned session (wraps).
# Usage: cycle [next|prev]   (default: next)
# Pin file holds name<TAB>id entries; legacy id-only entries are tolerated.
PIN_FILE="${HOME}/.config/tmux/pinned-sessions"
TAB="$(printf '\t')"
DIR="${1:-next}"

if [ ! -s "$PIN_FILE" ]; then
	tmux display-message "no pinned sessions (prefix+a to pin)"
	exit 0
fi

"$HOME/bin/tmux-session-sidebar/sync-pins" >/dev/null 2>&1 || :

# Build an ordered list of pinned session ids.
ordered="$(awk -F "$TAB" '
	NF >= 2 && $2 != "" { print $2; next }
	/^\$[0-9]+$/ { print }
' "$PIN_FILE")"

if [ -z "$ordered" ]; then
	tmux display-message "no pinned sessions are alive"
	exit 0
fi

cur="$(tmux display-message -p '#{session_id}')"

target="$(printf '%s\n' "$ordered" | awk -v cur="$cur" -v dir="$DIR" '
	{ lines[NR] = $0 }
	END {
		n = NR
		for (i = 1; i <= n; i++) if (lines[i] == cur) { idx = i; break }
		if (!idx) { print lines[1]; exit }
		if (dir == "prev") { j = idx - 1; if (j < 1) j = n }
		else               { j = (idx % n) + 1 }
		print lines[j]
	}
')"

if [ -n "$target" ] && [ "$target" != "$cur" ]; then
	tmux switch-client -t "$target"
elif [ -n "$target" ]; then
	tmux display-message "only one pinned session alive"
fi

# NOTE: no broadcast-redraw here. Each sidebar pane already highlights the
# session it lives in (display-message inside the pane returns that pane's
# session), so switch-client makes the right sidebar visible automatically.
# Calling broadcast-redraw on cycle just causes a visible re-render flash.
