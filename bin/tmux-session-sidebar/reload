#!/bin/sh
# Restart open sidebar panes so long-running shells reload changed scripts.
set -e

state="$(tmux show-options -gqv '@pin_sidebar_open' 2>/dev/null || :)"
[ "$state" = "1" ] || exit 0

"$HOME/bin/tmux-session-sidebar/prune" >/dev/null 2>&1 || :

{
	tmux list-windows -aF '#{window_id} #{@pin_sidebar_pane}' 2>/dev/null \
		| awk '$2 != "" { print $2 }'
	tmux list-panes -aF '#{pane_id} #{@pin_sidebar}' 2>/dev/null \
		| awk '$2 == "1" { print $1 }'
} | awk 'NF && !seen[$1]++ { print $1 }' \
	| while IFS= read -r pane; do
		tmux kill-pane -t "$pane" >/dev/null 2>&1 || :
	done

tmux list-windows -aF '#{window_id}' 2>/dev/null | while IFS= read -r win; do
	"$HOME/bin/tmux-session-sidebar/restore-layout" "$win" >/dev/null 2>&1 || :
	tmux set-option -wu -t "$win" '@pin_sidebar_pane' >/dev/null 2>&1 || :
done

tmux set-option -g '@pin_sidebar_open' '1' >/dev/null 2>&1 || :
"$HOME/bin/tmux-session-sidebar/fit-windows" >/dev/null 2>&1 || :

tmux list-windows -aF '#{window_id}' 2>/dev/null | while IFS= read -r win; do
	"$HOME/bin/tmux-session-sidebar/sidebar-attach" "$win" >/dev/null 2>&1 || :
done

"$HOME/bin/tmux-session-sidebar/sidebar-resize" >/dev/null 2>&1 || :
