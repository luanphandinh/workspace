#!/bin/sh
# Force every tmux window across the server to the dimensions of the
# currently-attached client. tmux normally only resizes a window when a
# client is actively viewing it, so inactive sessions retain the size
# cached from whenever they were last viewed — and `select-layout` /
# `resize-pane` against that stale size produces a wrong layout. Calling
# this before any layout op makes every window match the live viewport.
#
# `resize-window` temporarily sets `window-size manual` on the target
# window. Clear that local override after each resize and leave the global
# policy untouched; tmux <= 3.6b can crash when creating a window while the
# global policy is manual (tmux/tmux#4849).
set -e

# Capture viewport from the current client. If the script is run outside
# an attached client, fall back to the largest connected client.
client_w="$(tmux display-message -p '#{client_width}' 2>/dev/null || :)"
client_h="$(tmux display-message -p '#{client_height}' 2>/dev/null || :)"

if [ -z "$client_w" ] || [ -z "$client_h" ]; then
	# No active client context — pick any attached client's viewport.
	client_w="$(tmux list-clients -F '#{client_width}' 2>/dev/null | sort -rn | head -1)"
	client_h="$(tmux list-clients -F '#{client_height}' 2>/dev/null | sort -rn | head -1)"
fi

[ -z "$client_w" ] && exit 0
[ -z "$client_h" ] && exit 0

status_opt="$(tmux show-options -gqv status 2>/dev/null || :)"
case "$status_opt" in
	off|"")
		status_lines=0
		;;
	on)
		status_lines=1
		;;
	*[!0-9]*)
		status_lines=1
		;;
	*)
		status_lines="$status_opt"
		;;
esac

window_h=$((client_h - status_lines))
[ "$window_h" -gt 0 ] || window_h="$client_h"

tmux list-windows -aF '#{window_id}' 2>/dev/null | while IFS= read -r win; do
	tmux resize-window -t "$win" -x "$client_w" -y "$window_h" >/dev/null 2>&1 || :
	tmux set-window-option -u -t "$win" window-size >/dev/null 2>&1 || :
done
