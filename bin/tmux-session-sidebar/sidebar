#!/bin/sh
# Body of the pinned-sessions sidebar. Stays alive; redraws on every line
# received on stdin. Triggers send Enter via `tmux send-keys` so the redraw
# happens in-place — no respawn-pane, no flicker.
PIN_FILE="${HOME}/.config/tmux/pinned-sessions"
TAB="$(printf '\t')"

# Mark this pane as a sidebar so sidebar-resize can find it across
# every session/window without relying on the window-level pointer
# (@pin_sidebar_pane). Idempotent — safe to set on every render. Also
# self-heals existing live sidebars on first redraw after a script update.
if [ -n "${TMUX_PANE:-}" ]; then
	tmux set-option -pt "$TMUX_PANE" '@pin_sidebar' '1' >/dev/null 2>&1 || :
fi

# Suppress terminal echo so trigger keystrokes don't appear in rendered text.
stty -echo 2>/dev/null || :

# Pre-expand the escape sequences once. `printf '%s'` does NOT interpret
# backslash escapes in its arguments, only in the format string — so we
# materialise them here as actual control bytes and use them via %s.
GREEN="$(printf '\033[1;32m')"
DIM="$(printf '\033[2m')"
RESET="$(printf '\033[0m')"
# Erase-to-end-of-line — appended to every line so stale text from a
# previous (longer) render is wiped without blanking the whole pane.
EOL="$(printf '\033[K')"

repeat_char() {
	count="$1"
	char="$2"
	out=""
	i=0
	while [ "$i" -lt "$count" ]; do
		out="${out}${char}"
		i=$((i + 1))
	done
	printf '%s\n' "$out"
}

header_rule() {
	width="$1"
	label=" pinned "
	label_len=8
	if [ "$width" -le "$label_len" ]; then
		printf '%s\n' "$label"
		return
	fi
	side=$(((width - label_len) / 2))
	extra=$((width - label_len - 2 * side))
	printf '%s%s%s\n' "$(repeat_char "$side" "─")" "$label" "$(repeat_char "$((side + extra))" "─")"
}

sidebar_width() {
	width="$(tmux show-options -gqv '@pin_sidebar_width' 2>/dev/null || :)"
	case "$width" in
		''|*[!0-9]*) width=20 ;;
	esac
	printf '%s\n' "$width"
}

render_pins() {
	current="$1"
	current_window="$2"
	sessions="$3"
	windows="$4"
	sep="$(printf '\034')"

	{
		printf '%s\n' "$sessions"
		printf '%s\n' "$sep"
		printf '%s\n' "$windows"
		printf '%s\n' "$sep"
		cat "$PIN_FILE" 2>/dev/null || :
	} | awk -F "$TAB" \
		-v tab="$TAB" \
		-v sep="$sep" \
		-v current="$current" \
		-v current_window="$current_window" \
		-v rule="$RULE" \
		-v green="$GREEN" \
		-v dim="$DIM" \
		-v reset="$RESET" \
		-v eol="$EOL" '
		$0 == sep {
			section++
			next
		}
		section == 0 && $1 != "" && $2 != "" {
			id_to_name[$1] = $2
			name_to_id[$2] = $1
			next
		}
		section == 1 && $1 != "" {
			id = $1
			n = ++win_count[id]
			win_id[id, n] = $2
			win_name[id, n] = $3
			next
		}
		section == 2 && $0 != "" {
			pins[++pin_count] = $0
		}
		END {
			prev_current = 0
			for (i = 1; i <= pin_count; i++) {
				entry = pins[i]
				stored_name = ""
				stored_id = ""

				if (index(entry, tab) > 0) {
					split(entry, parts, tab)
					stored_name = parts[1]
					stored_id = parts[2]
				} else if (entry ~ /^\$[0-9]+$/) {
					stored_id = entry
				} else {
					stored_name = entry
				}

				name = ""
				id = ""
				if (stored_name != "" && (stored_name in name_to_id)) {
					name = stored_name
					id = name_to_id[stored_name]
				} else if (stored_id != "" && (stored_id in id_to_name)) {
					id = stored_id
					name = id_to_name[stored_id]
				}

				is_current = (id != "" && id == current) ? 1 : 0

				if (is_current == 1 || prev_current == 1)
					printf "%s%s%s%s\n", green, rule, reset, eol
				else
					printf "%s%s\n", rule, eol

				if (id == "" || name == "") {
					dead_name = (name != "") ? name : entry
					printf "%s✗ %s (dead)%s%s\n", dim, dead_name, reset, eol
					prev_current = is_current
					continue
				}

				if (is_current == 1)
					printf "%s▸ %s%s%s\n", green, name, reset, eol
				else
					printf "  %s%s\n", name, eol

				n = win_count[id]
				for (j = 1; j <= n; j++) {
					active = (win_id[id, j] == current_window) ? 1 : 0
					wname = win_name[id, j]
					tree = (j == n) ? "└" : "├"
					if (active == 1 && is_current == 1)
						printf "  %s▸ %s%s%s\n", green, wname, reset, eol
					else
						printf "  %s %s%s\n", tree, wname, eol
				}

				prev_current = is_current
			}

			if (prev_current == 1)
				printf "%s%s%s%s\n", green, rule, reset, eol
			else
				printf "%s%s\n", rule, eol
		}
	'
}

render() {
	WIDTH="$(sidebar_width)"
	RULE="$(repeat_char "$WIDTH" "─")"
	HEADER="$(header_rule "$WIDTH")"

	{
		# Hide cursor + go home. NO full-screen clear — that's the source
		# of the visible blank flicker. Each line below ends with EOL to
		# erase residual text; after all content, \033[J wipes any extra
		# trailing lines from a previous longer render.
		printf '\033[?25l\033[H'

		# Centered header rule + blank spacer.
		printf '%s%s\n%s\n' "$HEADER" "$EOL" "$EOL"

		if [ ! -s "$PIN_FILE" ]; then
			printf '(none: prefix + a)%s\n' "$EOL"
		else
			target="${TMUX_PANE:-}"
			if [ -n "$target" ]; then
				current="$(tmux show-options -wqv -t "$target" '@pin_sidebar_focus_session' 2>/dev/null || :)"
				current_window="$(tmux show-options -wqv -t "$target" '@pin_sidebar_focus_window' 2>/dev/null || :)"
				[ -n "$current" ] || current="$(tmux display-message -p -t "$target" '#{session_id}' 2>/dev/null || :)"
				[ -n "$current_window" ] || current_window="$(tmux display-message -p -t "$target" '#{window_id}' 2>/dev/null || :)"
			else
				current="$(tmux show-options -wqv '@pin_sidebar_focus_session' 2>/dev/null || :)"
				current_window="$(tmux show-options -wqv '@pin_sidebar_focus_window' 2>/dev/null || :)"
				[ -n "$current" ] || current="$(tmux display-message -p '#{session_id}' 2>/dev/null || :)"
				[ -n "$current_window" ] || current_window="$(tmux display-message -p '#{window_id}' 2>/dev/null || :)"
			fi
			sessions="$(tmux list-sessions -F '#{session_id}	#{session_name}' 2>/dev/null || :)"
			windows="$(tmux list-windows -aF '#{session_id}	#{window_id}	#{window_name}' 2>/dev/null || :)"
			render_pins "$current" "$current_window" "$sessions" "$windows"
		fi

		# Compact help for macOS and cross-platform terminal bindings.
		# Blank spacer line above must be EOL-cleared (not just `\n`-skipped)
		# so a previous longer render's content doesn't linger here.
		printf '%s\n%s%s\n' "$EOL" "$RULE" "$EOL"
		printf 'prefix +%s\n' "$EOL"
		printf '  a pin/unpin%s\n' "$EOL"
		printf '  A sidebar%s\n' "$EOL"
		printf '  e clear%s\n' "$EOL"
		printf 'O-C/C-S +%s\n' "$EOL"
		printf '  ↑/↓ session%s\n' "$EOL"
		printf '  ←/→ window%s\n' "$EOL"
		printf 'C-S +%s\n' "$EOL"
		printf '  j/k session%s\n' "$EOL"
		printf '  h/l window%s\n' "$EOL"
		printf 'Cmd +%s\n' "$EOL"
		printf '  1..9 window%s\n' "$EOL"

		# Wipe any stale content below the new render (left over from a
		# previous taller render — e.g. dropped pin, closed window).
		printf '\033[J\033[?25h'
	}
}

render

# Block waiting for stdin; each Enter sent by broadcast-redraw
# unblocks `read` and triggers a re-render. When the pane is killed,
# `read` returns non-zero and we exit cleanly.
while IFS= read -r _; do
	render
done
