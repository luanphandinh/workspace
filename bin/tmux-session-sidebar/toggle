#!/bin/sh
# Toggle pin status of the current tmux session.
set -e

PIN_FILE="${HOME}/.config/tmux/pinned-sessions"
TAB="$(printf '\t')"
mkdir -p "$(dirname "$PIN_FILE")"
[ -f "$PIN_FILE" ] || : > "$PIN_FILE"

"$HOME/bin/tmux-session-sidebar/sync-pins" >/dev/null 2>&1 || :

id="$(tmux display-message -p '#{session_id}')"
name="$(tmux display-message -p '#S')"

if awk -F "$TAB" -v id="$id" -v name="$name" '
	NF >= 2 && ($1 == name || $2 == id) { found = 1 }
	$0 == name || $0 == id { found = 1 }
	END { exit found ? 0 : 1 }
' "$PIN_FILE" 2>/dev/null; then
	tmp="$(mktemp)"
	awk -F "$TAB" -v id="$id" -v name="$name" '
		NF >= 2 && ($1 == name || $2 == id) { next }
		$0 == name || $0 == id { next }
		{ print }
	' "$PIN_FILE" > "$tmp"
	mv "$tmp" "$PIN_FILE"
	tmux display-message "unpinned: $name"
else
	printf '%s\t%s\n' "$name" "$id" >> "$PIN_FILE"
	tmux display-message "pinned: $name"
fi

# Trigger an in-place redraw of every open sidebar (no respawn = no flicker).
"$HOME/bin/tmux-session-sidebar/broadcast-redraw" >/dev/null 2>&1 || :
