#!/usr/bin/env bash
# Create or extend a multi-repo git-worktree workspace under $PWD.
# Usage: mkworkspace --name <name> [--branch <branch>] [--add <repo>...]

set -uo pipefail

command -v git >/dev/null 2>&1 || { echo "error: git not installed" >&2; exit 1; }

usage() {
  cat <<'EOF'
Usage: mkworkspace --name <name> [--branch <branch>] [--add <repo>...]

Creates or extends a multi-repo git-worktree workspace under $PWD.

  --name <name>       workspace name (also the folder name; '/' becomes '_')
  --branch <branch>   branch name; required on first create, optional after
                      (must match workspace.yml if provided on re-add)
  --add <repo>...     one or more repo directory names to add; variadic,
                      e.g. --add a b c  or  --add a --add b
  -h, --help          show this message

Each workspace has a manifest at <workspace>/workspace.yml:
  name: <workspace-name>
  branch_name: <branch>
  repos:
    - repo-a
    - repo-b
EOF
}

PROJECT_ROOT="$PWD"
NAME=""
BRANCH=""
REPOS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)
      [[ $# -ge 2 ]] || { echo "error: --name requires a value" >&2; exit 1; }
      NAME="$2"
      shift 2
      ;;
    --branch)
      [[ $# -ge 2 ]] || { echo "error: --branch requires a value" >&2; exit 1; }
      BRANCH="$2"
      shift 2
      ;;
    --add)
      shift
      while [[ $# -gt 0 && "$1" != --* ]]; do
        REPOS+=("$1")
        shift
      done
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown flag: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

[[ -n "$NAME" ]] || { echo "error: --name required" >&2; exit 1; }

WORKSPACE_NAME="${NAME//\//_}"
WORKSPACE_DIR="$PROJECT_ROOT/$WORKSPACE_NAME"
YML="$WORKSPACE_DIR/workspace.yml"

if [[ -f "$YML" ]]; then
  EXISTING_BRANCH=$(awk -F': *' '/^branch_name:/{print $2; exit}' "$YML")
  if [[ -z "$EXISTING_BRANCH" ]]; then
    echo "error: workspace.yml at $YML is missing branch_name" >&2
    exit 1
  fi
  if [[ -n "$BRANCH" && "$BRANCH" != "$EXISTING_BRANCH" ]]; then
    echo "error: --branch '$BRANCH' does not match workspace.yml branch '$EXISTING_BRANCH'" >&2
    exit 1
  fi
  BRANCH="$EXISTING_BRANCH"
else
  [[ -n "$BRANCH" ]] || { echo "error: --branch required when creating a new workspace" >&2; exit 1; }
  mkdir -p "$WORKSPACE_DIR"
  {
    echo "name: $NAME"
    echo "branch_name: $BRANCH"
    echo "repos:"
  } > "$YML"
fi

existing_repos() {
  awk '/^repos:/{flag=1; next} flag && /^  - /{sub(/^  - /, ""); print}' "$YML"
}

repo_in_yml() {
  local target="$1" r
  while IFS= read -r r; do
    [[ "$r" == "$target" ]] && return 0
  done < <(existing_repos)
  return 1
}

detect_base() {
  local repo="$1"
  for b in master main; do
    if git -C "$repo" show-ref --verify --quiet "refs/heads/$b" \
       || git -C "$repo" show-ref --verify --quiet "refs/remotes/origin/$b"; then
      echo "$b"
      return 0
    fi
  done
  return 1
}

added=0
skipped=0
failed=0

if [[ ${#REPOS[@]} -gt 0 ]]; then
  for repo in "${REPOS[@]}"; do
    printf '\n=== %s ===\n' "$repo"

    if [[ ! -d "$PROJECT_ROOT/$repo/.git" ]]; then
      echo "  ! not a git repo at $PROJECT_ROOT/$repo"
      failed=$((failed + 1))
      continue
    fi

    if repo_in_yml "$repo"; then
      echo "  already in workspace, skipping"
      skipped=$((skipped + 1))
      continue
    fi

    WT_PATH="$WORKSPACE_DIR/$repo"
    if [[ -e "$WT_PATH" ]]; then
      echo "  worktree path already exists, recording in yml"
      echo "  - $repo" >> "$YML"
      skipped=$((skipped + 1))
      continue
    fi

    if git -C "$repo" worktree add "$WT_PATH" "$BRANCH" 2>/dev/null; then
      echo "  checked out existing branch $BRANCH"
      echo "  - $repo" >> "$YML"
      added=$((added + 1))
      continue
    fi

    echo "  fetching latest from origin"
    git -C "$repo" fetch origin --quiet 2>/dev/null || echo "  ! fetch failed, falling back to local refs"

    base=$(detect_base "$repo") || {
      echo "  ! could not detect base branch (master/main)"
      failed=$((failed + 1))
      continue
    }

    if git -C "$repo" show-ref --verify --quiet "refs/remotes/origin/$base"; then
      start_ref="origin/$base"
    else
      start_ref="$base"
    fi

    echo "  creating new branch $BRANCH from $start_ref"
    if git -C "$repo" worktree add -b "$BRANCH" "$WT_PATH" "$start_ref"; then
      echo "  - $repo" >> "$YML"
      added=$((added + 1))
    else
      echo "  ! worktree add failed"
      failed=$((failed + 1))
    fi
  done
fi

printf '\n=== go.work ===\n'
if command -v go >/dev/null 2>&1; then
  cd "$WORKSPACE_DIR"
  [[ -f go.work ]] || go work init 2>/dev/null || true
  while IFS= read -r repo; do
    if [[ -f "$WORKSPACE_DIR/$repo/go.mod" ]]; then
      go work use "./$repo"
    fi
  done < <(existing_repos)
  echo "  go.work at $WORKSPACE_DIR/go.work"
else
  echo "  go not installed, skipping go.work"
fi

printf '\n=== summary ===\n'
echo "  workspace: $WORKSPACE_DIR"
echo "  branch:    $BRANCH"
echo "  added: $added, skipped: $skipped, failed: $failed"
