#!/bin/sh
  # ~/bin/go — inject -toolexec=init-patcher and debug gcflags into `go test`.

  REAL_GO="/usr/local/go/bin/go"
  PATCHER="init-patcher"
  GCFLAGS="all=-N -l"

  log() {
    printf 'go wrapper execute "%s"\n' "$*" >&2
  }

  if [ "$1" = "test" ]; then
    shift

    # Detect existing flags to avoid double-injection.
    have_toolexec=0
    have_gcflags=0
    for arg in "$@"; do
      case "$arg" in
        -toolexec=*|--toolexec=*) have_toolexec=1 ;;
        -gcflags=*|--gcflags=*)   have_gcflags=1 ;;
      esac
    done

    set -- "$@"
    [ "$have_toolexec" = "0" ] && set -- "-toolexec=$PATCHER" "$@"
    [ "$have_gcflags"  = "0" ] && set -- "-gcflags=$GCFLAGS"  "$@"

    log "$REAL_GO test $*"
    exec "$REAL_GO" test "$@"
  fi

  log "$REAL_GO $*"
  exec "$REAL_GO" "$@"
