#!/usr/bin/env python3
"""Claude Code statusline.

Fields:
  ctx          current context tokens / model window (from stdin context_window)
  session      5-hour rate-limit usage %, with reset time
  7d-all       7-day rate-limit usage %
  7d-sonnet    last-7-day Sonnet-only token usage (computed from ~/.claude/projects)

Input:  Claude Code pipes a JSON blob on stdin. Everything except the weekly
        sonnet figure comes directly from it.
Output: one line to stdout. Weekly sonnet uses a serve-stale-while-revalidate
        cache at /tmp/claude-code-statusline-cache.json — the glob over the
        projects dir is otherwise slow enough to trip Claude Code's statusline
        timeout and blank the bar.
"""

import glob
import json
import os
import subprocess
import sys
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path

PROJECTS_DIR = os.path.expanduser("~/.claude/projects")
CACHE_FILE = Path("/tmp/claude-code-statusline-cache.json")
ERR_LOG = Path("/tmp/claude-code-statusline.err.log")
CACHE_TTL_SEC = 60


def _num(v):
    """float(v) if numeric, else None. Tolerates str, int, float, None, and
    anything else (dict/list → None) so one surprising field type can't blank
    the whole statusline."""
    if v is None or isinstance(v, bool):
        return None
    try:
        return float(v)
    except (TypeError, ValueError):
        return None


def read_stdin_json() -> dict:
    try:
        return json.loads(sys.stdin.read() or "{}")
    except Exception:
        return {}


def iter_jsonl(path: str):
    try:
        with open(path, "r", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    yield json.loads(line)
                except Exception:
                    continue
    except OSError:
        return


def usage_sum(u: dict) -> int:
    return (
        (u.get("input_tokens") or 0)
        + (u.get("output_tokens") or 0)
        + (u.get("cache_creation_input_tokens") or 0)
        + (u.get("cache_read_input_tokens") or 0)
    )


def _read_cache():
    if not CACHE_FILE.exists():
        return None, None
    try:
        val = int(json.loads(CACHE_FILE.read_text()).get("sonnet", 0))
        age = time.time() - CACHE_FILE.stat().st_mtime
        return val, age
    except Exception:
        return None, None


def _compute_weekly_sonnet() -> int:
    cutoff = datetime.now(timezone.utc) - timedelta(days=7)
    cutoff_ts = cutoff.timestamp()
    total = 0
    for path in glob.iglob(os.path.join(PROJECTS_DIR, "*", "*.jsonl")):
        try:
            if os.path.getmtime(path) < cutoff_ts:
                continue
        except OSError:
            continue
        for obj in iter_jsonl(path):
            msg = obj.get("message") or {}
            if "sonnet" not in str(msg.get("model") or "").lower():
                continue
            ts = obj.get("timestamp")
            if ts:
                try:
                    t = datetime.fromisoformat(str(ts).replace("Z", "+00:00"))
                    if t < cutoff:
                        continue
                except Exception:
                    pass
            u = msg.get("usage") or {}
            if u:
                total += usage_sum(u)
    try:
        CACHE_FILE.write_text(json.dumps({"sonnet": total}))
    except OSError:
        pass
    return total


def _spawn_refresh():
    """Detached background refresh — never blocks the foreground render."""
    try:
        subprocess.Popen(
            [sys.executable, __file__, "--refresh-cache"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        pass


def weekly_sonnet_tokens() -> int:
    """Serve cached value immediately; refresh in background when stale.

    First-ever run has no cache and must compute synchronously. After that,
    every call returns instantly — even when the cache is stale, we serve it
    and spawn a detached refresh for the next call.
    """
    cached, age = _read_cache()
    if cached is None:
        return _compute_weekly_sonnet()
    if age is not None and age >= CACHE_TTL_SEC:
        _spawn_refresh()
    return cached


def fmt_k(n: int) -> str:
    if n >= 1_000_000:
        return f"{n / 1_000_000:.1f}M"
    if n >= 1_000:
        return f"{n / 1_000:.1f}k"
    return str(int(n))


def fmt_resets_at(resets_at) -> str:
    """Format `resets_at` as local time, e.g. '3 PM' or '3:45 PM'.

    Claude Code sends Unix epoch seconds (int/float), but we also accept
    ISO8601 strings in case the format ever changes.
    """
    if resets_at is None or isinstance(resets_at, bool):
        return ""
    t = None
    try:
        t = datetime.fromtimestamp(float(resets_at), tz=timezone.utc)
    except (TypeError, ValueError):
        try:
            t = datetime.fromisoformat(str(resets_at).replace("Z", "+00:00"))
        except Exception:
            return ""
    local = t.astimezone()
    if local.minute == 0:
        return local.strftime("%I %p").lstrip("0")
    return local.strftime("%I:%M %p").lstrip("0")


def render(data: dict) -> str:
    model = data.get("model")
    if not isinstance(model, dict):
        model = {}
    model_name = str(model.get("display_name") or model.get("id") or "?")

    cw = data.get("context_window")
    if not isinstance(cw, dict):
        cw = {}
    ctx = int(_num(cw.get("current_usage")) or 0)
    ctx_limit = int(_num(cw.get("context_window_size")) or 0)
    ctx_pct_val = _num(cw.get("used_percentage"))
    if ctx_pct_val is None:
        ctx_pct = (ctx / ctx_limit * 100) if ctx_limit else 0.0
    else:
        ctx_pct = ctx_pct_val

    rate_limits = data.get("rate_limits")
    if not isinstance(rate_limits, dict):
        rate_limits = {}

    def pct_field(label: str, rl_key: str, with_reset: bool = False) -> str:
        rl = rate_limits.get(rl_key)
        if not isinstance(rl, dict):
            return f"{label} n/a"
        val = _num(rl.get("used_percentage"))
        if val is None:
            return f"{label} n/a"
        suffix = ""
        if with_reset:
            resets = fmt_resets_at(rl.get("resets_at"))
            if resets:
                suffix = f" (Reset {resets})"
        return f"{label} {val:.0f}%{suffix}"

    try:
        week_sonnet = weekly_sonnet_tokens()
    except Exception:
        week_sonnet = 0

    parts = [
        model_name,
        f"ctx {fmt_k(ctx)}/{fmt_k(ctx_limit) if ctx_limit else '?'} ({ctx_pct:.0f}%)",
        pct_field("session", "five_hour", with_reset=True),
        pct_field("7d-all", "seven_day"),
        f"7d-sonnet {fmt_k(week_sonnet)}",
    ]
    return " │ ".join(parts)


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--refresh-cache":
        try:
            _compute_weekly_sonnet()
        except Exception:
            pass
        return
    try:
        data = read_stdin_json()
        sys.stdout.write(render(data))
    except Exception as e:
        # Log full traceback so we can diagnose; print a short note so the bar
        # stays visible.
        try:
            import traceback
            with open(ERR_LOG, "a") as f:
                f.write(f"--- {datetime.now().isoformat()} ---\n")
                f.write(traceback.format_exc())
                f.write("\n")
        except Exception:
            pass
        msg = str(e)[:60]
        sys.stdout.write(f"statusline err: {type(e).__name__}: {msg}")


if __name__ == "__main__":
    main()
