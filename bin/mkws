#!/usr/bin/env bash
# Create, extend, or sync a multi-repo git-worktree workspace.
# Usage:
#   mkws [--name <name>] [--branch <branch>] [--add <repo>...]
#   mkws sync [--name <name>]

set -uo pipefail

command -v git >/dev/null 2>&1 || { echo "error: git not installed" >&2; exit 1; }

# All workspaces live under this container folder inside the repo root. Keeps
# the root uncluttered when many workspaces accumulate over time.
WS_CONTAINER="lpworkspaces"

usage() {
  cat <<'EOF'
Usage:
  mkws [--name <name>] [--branch <branch>] [--add <repo>...]
  mkws sync [<folder>]

Modes:
  (default)  Create or extend a workspace. Run from the root folder that
             contains the source repos, or from inside a workspace dir.
  sync       Regenerate go.work and run `go work sync` for a workspace folder.
             Targets the given folder (relative or absolute). If omitted,
             defaults to $PWD. The folder must contain a workspace.yml.
             Examples:
               mkws sync                     # sync $PWD
               mkws sync ./lpworkspaces/myws # sync a relative path
               mkws sync /abs/path/to/ws     # sync an absolute path

Flags:
  --name <name>       workspace name. Required when creating a new workspace
                      or when invoked from the root. When invoked from inside
                      a workspace dir, read from workspace.yml. `/` in the
                      name becomes `_` in the folder.
  --branch <branch>   branch name. Required on first create. Optional on
                      re-add; must match workspace.yml if provided.
  --add <repo>...     one or more repos to add. Each entry can be:
                        - a bare name (looked up under the root)
                        - a relative path (resolved against $PWD, e.g. ../repo)
                        - an absolute path
                      The basename is used for the workspace folder and yml.
                      Variadic: --add a b c  or  --add a --add b
  -h, --help          show this message

Layout:
  All workspaces live inside `$PWD/lpworkspaces/<name>/` so the repo root
  stays uncluttered. The container folder is created on demand.

Context:
  If $PWD contains workspace.yml, that folder is treated as the workspace;
  root is two levels up (grandparent of PWD). If $PWD's basename is
  `lpworkspaces`, root is its parent. Otherwise $PWD is the root and the
  workspace is placed at $PWD/lpworkspaces/<name>/.

Manifest (<root>/lpworkspaces/<name>/workspace.yml):
  name: <workspace-name>
  branch_name: <branch>
  repos:
    - repo-a
    - repo-b
EOF
}

MODE="default"
NAME=""
BRANCH=""
REPOS=()
SYNC_PATH=""

if [[ $# -gt 0 && "$1" != -* ]]; then
  case "$1" in
    sync)
      MODE="sync"
      shift
      # Optional positional: a path to the workspace folder. Defaults to $PWD.
      # Accepts relative, absolute, or ./foo paths — resolved as a directory.
      if [[ $# -gt 0 && "$1" != -* ]]; then
        SYNC_PATH="$1"
        shift
      else
        SYNC_PATH="$PWD"
      fi
      ;;
    *)
      echo "error: unknown subcommand: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --name)
      [[ $# -ge 2 ]] || { echo "error: --name requires a value" >&2; exit 1; }
      NAME="$2"
      shift 2
      ;;
    --branch)
      [[ $# -ge 2 ]] || { echo "error: --branch requires a value" >&2; exit 1; }
      BRANCH="$2"
      shift 2
      ;;
    --add)
      shift
      while [[ $# -gt 0 && "$1" != --* ]]; do
        REPOS+=("$1")
        shift
      done
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown flag: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [[ "$MODE" == "sync" ]]; then
  if [[ ${#REPOS[@]} -gt 0 || -n "$BRANCH" || -n "$NAME" ]]; then
    echo "error: 'sync' takes a folder path only; --add/--branch/--name are not accepted" >&2
    exit 1
  fi
  # Sync resolves its target directly from the positional folder path (or $PWD).
  # No name lookups, no container traversal — whatever folder you point at must
  # contain workspace.yml.
  [[ -d "$SYNC_PATH" ]] || { echo "error: not a directory: $SYNC_PATH" >&2; exit 1; }
  WORKSPACE_DIR="$(cd "$SYNC_PATH" && pwd)"
  YML="$WORKSPACE_DIR/workspace.yml"
  [[ -f "$YML" ]] || { echo "error: no workspace.yml at $WORKSPACE_DIR (not a workspace)" >&2; exit 1; }
  NAME=$(awk -F': *' '/^name:/{print $2; exit}' "$YML")
  REPO_ROOT="$(dirname "$(dirname "$WORKSPACE_DIR")")"
else
  # Default mode: inside a workspace (PWD has yml) → root is grandparent.
  # At the lpworkspaces container → root is parent. Otherwise PWD is the root.
  if [[ -f "$PWD/workspace.yml" ]]; then
    WORKSPACE_DIR="$PWD"
    REPO_ROOT="$(dirname "$(dirname "$PWD")")"
    YML="$WORKSPACE_DIR/workspace.yml"
    NAME_FROM_YML=$(awk -F': *' '/^name:/{print $2; exit}' "$YML")
    if [[ -n "$NAME" && "$NAME" != "$NAME_FROM_YML" ]]; then
      echo "error: --name '$NAME' does not match workspace.yml name '$NAME_FROM_YML'" >&2
      exit 1
    fi
    NAME="$NAME_FROM_YML"
  else
    [[ -n "$NAME" ]] || { echo "error: --name required (or run from inside a workspace dir)" >&2; exit 1; }
    if [[ "$(basename "$PWD")" == "$WS_CONTAINER" ]]; then
      REPO_ROOT="$(dirname "$PWD")"
    else
      REPO_ROOT="$PWD"
    fi
    WORKSPACE_NAME="${NAME//\//_}"
    WORKSPACE_DIR="$REPO_ROOT/$WS_CONTAINER/$WORKSPACE_NAME"
    YML="$WORKSPACE_DIR/workspace.yml"
  fi
fi

if [[ -f "$YML" ]]; then
  EXISTING_BRANCH=$(awk -F': *' '/^branch_name:/{print $2; exit}' "$YML")
  [[ -n "$EXISTING_BRANCH" ]] || { echo "error: workspace.yml at $YML is missing branch_name" >&2; exit 1; }
  if [[ -n "$BRANCH" && "$BRANCH" != "$EXISTING_BRANCH" ]]; then
    echo "error: --branch '$BRANCH' does not match workspace.yml branch '$EXISTING_BRANCH'" >&2
    exit 1
  fi
  BRANCH="$EXISTING_BRANCH"
elif [[ "$MODE" != "sync" ]]; then
  [[ -n "$BRANCH" ]] || { echo "error: --branch required when creating a new workspace" >&2; exit 1; }
  mkdir -p "$WORKSPACE_DIR"
  {
    echo "name: $NAME"
    echo "branch_name: $BRANCH"
    echo "repos:"
  } > "$YML"
fi

existing_repos() {
  awk '/^repos:/{flag=1; next} flag && /^  - /{sub(/^  - /, ""); print}' "$YML"
}

repo_in_yml() {
  local target="$1" r
  while IFS= read -r r; do
    [[ "$r" == "$target" ]] && return 0
  done < <(existing_repos)
  return 1
}

detect_base() {
  local repo_path="$1"
  for b in master main; do
    if git -C "$repo_path" show-ref --verify --quiet "refs/heads/$b" \
       || git -C "$repo_path" show-ref --verify --quiet "refs/remotes/origin/$b"; then
      echo "$b"
      return 0
    fi
  done
  return 1
}

# Resolve a --add argument to an absolute path pointing at a git repo.
# Accepts: bare names (looked up under REPO_ROOT), relative paths (resolved
# against PWD), and absolute paths. Prints the absolute path on success.
resolve_source() {
  local raw="$1" resolved
  if [[ "$raw" = /* ]]; then
    resolved="$raw"
  elif [[ "$raw" == */* ]]; then
    resolved=$(cd "$raw" 2>/dev/null && pwd) || return 1
  else
    resolved="$REPO_ROOT/$raw"
  fi
  [[ -d "$resolved/.git" ]] || return 1
  (cd "$resolved" && pwd)
}

regen_go_work() {
  if ! command -v go >/dev/null 2>&1; then
    echo "  go not installed, skipping go.work"
    return 0
  fi
  (
    cd "$WORKSPACE_DIR"
    [[ -f go.work ]] || go work init 2>/dev/null || true
    while IFS= read -r repo; do
      if [[ -f "$WORKSPACE_DIR/$repo/go.mod" ]]; then
        go work use "./$repo"
      fi
    done < <(existing_repos)
  )
  echo "  go.work at $WORKSPACE_DIR/go.work"
}

if [[ "$MODE" == "sync" ]]; then
  printf '=== go.work ===\n'
  regen_go_work

  printf '\n=== go work sync ===\n'
  if ! command -v go >/dev/null 2>&1; then
    echo "  ! go not installed, cannot sync"
    exit 1
  fi
  if (cd "$WORKSPACE_DIR" && go work sync); then
    echo "  synced"
  else
    echo "  ! go work sync failed"
    exit 1
  fi

  printf '\n=== summary ===\n'
  echo "  workspace: $WORKSPACE_DIR"
  echo "  branch:    $BRANCH"
  exit 0
fi

added=0
skipped=0
failed=0

if [[ ${#REPOS[@]} -gt 0 ]]; then
  for repo in "${REPOS[@]}"; do
    printf '\n=== %s ===\n' "$repo"

    REPO_PATH=$(resolve_source "$repo") || {
      echo "  ! not a git repo: $repo"
      failed=$((failed + 1))
      continue
    }
    LEAF=$(basename "$REPO_PATH")

    if [[ "$LEAF" != "$repo" ]]; then
      echo "  source: $REPO_PATH (recorded as '$LEAF')"
    fi

    if repo_in_yml "$LEAF"; then
      echo "  '$LEAF' already in workspace, skipping"
      skipped=$((skipped + 1))
      continue
    fi

    WT_PATH="$WORKSPACE_DIR/$LEAF"
    if [[ -e "$WT_PATH" ]]; then
      echo "  worktree path already exists, recording in yml"
      echo "  - $LEAF" >> "$YML"
      skipped=$((skipped + 1))
      continue
    fi

    if git -C "$REPO_PATH" worktree add "$WT_PATH" "$BRANCH" 2>/dev/null; then
      echo "  checked out existing branch $BRANCH"
      echo "  - $LEAF" >> "$YML"
      added=$((added + 1))
      continue
    fi

    echo "  fetching latest from origin"
    git -C "$REPO_PATH" fetch origin --quiet 2>/dev/null || echo "  ! fetch failed, falling back to local refs"

    base=$(detect_base "$REPO_PATH") || {
      echo "  ! could not detect base branch (master/main)"
      failed=$((failed + 1))
      continue
    }

    if git -C "$REPO_PATH" show-ref --verify --quiet "refs/remotes/origin/$base"; then
      start_ref="origin/$base"
    else
      start_ref="$base"
    fi

    echo "  creating new branch $BRANCH from $start_ref"
    if git -C "$REPO_PATH" worktree add -b "$BRANCH" "$WT_PATH" "$start_ref"; then
      echo "  - $LEAF" >> "$YML"
      added=$((added + 1))
    else
      echo "  ! worktree add failed"
      failed=$((failed + 1))
    fi
  done
fi

printf '\n=== go.work ===\n'
regen_go_work

printf '\n=== summary ===\n'
echo "  workspace: $WORKSPACE_DIR"
echo "  branch:    $BRANCH"
echo "  added: $added, skipped: $skipped, failed: $failed"
