#!/usr/bin/env python3
"""mkws — multi-repo git-worktree workspace manager.

Every workspace lives at `<root>/lpworkspaces/<name>/` and is a set of git
worktrees (one per source repo) all on the same feature branch, glued together
by a small `workspace.yml` manifest. Go workspaces (`go.work`) are intentionally
NOT created — per-module semantics (GOWORK=off everywhere) is the standard here;
cross-module navigation happens via `<leader>gw` worktree switching instead.
"""

import concurrent.futures
import os
import shutil
import subprocess
import sys
from pathlib import Path

WS_CONTAINER = "lpworkspaces"

# ---------------------------------------------------------------------------
# Colored logging. Disabled when stdout isn't a TTY or NO_COLOR is set, so pipes
# and CI logs stay clean.
# ---------------------------------------------------------------------------
_USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(code: str) -> str:
    return f"\033[{code}m" if _USE_COLOR else ""


RESET = _c("0")
BOLD = _c("1")
DIM = _c("2")
RED = _c("31")
GREEN = _c("32")
YELLOW = _c("33")
BLUE = _c("34")
CYAN = _c("36")


def heading(text: str) -> None:
    # flush=True keeps our stdout interleaved correctly with subprocess stderr
    # when the final output is redirected (where stdout would otherwise become
    # block-buffered and git messages leak above our headings).
    print(f"\n{BOLD}{CYAN}=== {text} ==={RESET}", flush=True)


def info(text: str) -> None:
    print(f"  {text}", flush=True)


def ok(text: str) -> None:
    print(f"  {GREEN}✓{RESET} {text}", flush=True)


def warn(text: str) -> None:
    print(f"  {YELLOW}!{RESET} {text}", flush=True)


def fail(text: str) -> None:
    print(f"  {RED}✗{RESET} {text}", flush=True)


def die(text: str, code: int = 1) -> None:
    print(f"{RED}error:{RESET} {text}", file=sys.stderr)
    sys.exit(code)


def has_cmd(name: str) -> bool:
    return shutil.which(name) is not None


# ---------------------------------------------------------------------------
# Parallel per-repo runner. Each worker writes to its own RepoLog instead of
# stdout; once all workers finish, logs are printed in submission order so
# output reads like the serial version — no interleaving, no flickering.
# ---------------------------------------------------------------------------
class RepoLog:
    """A buffered logger. Same methods as the top-level log helpers but
    accumulates lines so they can be flushed together at the end."""

    def __init__(self) -> None:
        self._lines: list = []

    def heading(self, t: str) -> None: self._lines.append(("heading", t))
    def info(self, t: str) -> None: self._lines.append(("info", t))
    def ok(self, t: str) -> None: self._lines.append(("ok", t))
    def warn(self, t: str) -> None: self._lines.append(("warn", t))
    def fail(self, t: str) -> None: self._lines.append(("fail", t))
    def raw(self, t: str) -> None: self._lines.append(("raw", t))

    def render(self) -> None:
        for kind, text in self._lines:
            if kind == "heading": heading(text)
            elif kind == "info": info(text)
            elif kind == "ok": ok(text)
            elif kind == "warn": warn(text)
            elif kind == "fail": fail(text)
            elif kind == "raw":
                if text:
                    print(text, flush=True)


def _draw_progress_bar(done: int, total: int) -> None:
    """Draw/redraw a single-line progress bar in place using \r. Caller is
    responsible for clearing the line when done."""
    bar_width = 30
    filled = int(bar_width * done / total) if total else bar_width
    bar = "█" * filled + "░" * (bar_width - filled)
    pct = int(done / total * 100) if total else 100
    sys.stdout.write(f"\r  [{CYAN}{bar}{RESET}] {done}/{total} ({pct}%)")
    sys.stdout.flush()


def _clear_progress_line() -> None:
    # 60 spaces clears a 30-char bar plus the "N/M (P%)" counter safely.
    sys.stdout.write("\r" + " " * 60 + "\r")
    sys.stdout.flush()


def run_in_parallel(items, worker, max_workers: int = 8) -> list:
    """Call worker(item, log) for each item in a thread pool, then flush each
    RepoLog in submission order. Returns the list of worker return values,
    one per item in the same order.

    Shows a live progress bar while workers run, as long as stdout is a TTY
    and there are enough items to make it worthwhile (>=2). The bar is drawn
    in-place with \\r and cleared before the buffered logs are rendered, so
    the final output still reads cleanly."""
    if not items:
        return []
    n = min(max_workers, len(items))
    logs = [RepoLog() for _ in items]
    results: list = [None] * len(items)

    show_bar = sys.stdout.isatty() and len(items) >= 2
    if show_bar:
        _draw_progress_bar(0, len(items))

    with concurrent.futures.ThreadPoolExecutor(max_workers=n) as ex:
        futs = {ex.submit(worker, item, logs[i]): i for i, item in enumerate(items)}
        done = 0
        for fut in concurrent.futures.as_completed(futs):
            i = futs[fut]
            try:
                results[i] = fut.result()
            except Exception as e:
                results[i] = None
                logs[i].fail(f"worker crashed: {e}")
            done += 1
            if show_bar:
                _draw_progress_bar(done, len(items))

    if show_bar:
        _clear_progress_line()

    for log in logs:
        log.render()
    return results


# ---------------------------------------------------------------------------
# Subprocess helpers
# ---------------------------------------------------------------------------
def run(cmd, cwd=None, capture=True):
    return subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        capture_output=capture,
        text=True,
    )


# ---------------------------------------------------------------------------
# workspace.yml I/O. Hand-parsed so we don't pull in PyYAML.
# Format:
#   name: <workspace-name>
#   branch_name: <branch>
#   repos:
#     - repo-a
#     - repo-b
# ---------------------------------------------------------------------------
def read_manifest(yml: Path) -> dict:
    data = {"name": "", "branch_name": "", "repos": []}
    in_repos = False
    for line in yml.read_text().splitlines():
        if line.startswith("name:"):
            data["name"] = line.split(":", 1)[1].strip()
            in_repos = False
        elif line.startswith("branch_name:"):
            data["branch_name"] = line.split(":", 1)[1].strip()
            in_repos = False
        elif line.startswith("repos:"):
            in_repos = True
        elif in_repos and line.startswith("  - "):
            data["repos"].append(line[4:].strip())
    return data


def write_manifest(yml: Path, name: str, branch: str, repos: list) -> None:
    lines = [f"name: {name}", f"branch_name: {branch}", "repos:"]
    lines.extend(f"  - {r}" for r in repos)
    yml.write_text("\n".join(lines) + "\n")


def append_repo(yml: Path, leaf: str) -> None:
    with yml.open("a") as f:
        f.write(f"  - {leaf}\n")


# ---------------------------------------------------------------------------
# Git helpers
# ---------------------------------------------------------------------------
def has_ref(repo: Path, ref: str) -> bool:
    return run(["git", "-C", str(repo), "show-ref", "--verify", "--quiet", ref]).returncode == 0


def detect_base(repo: Path):
    for b in ("master", "main"):
        if has_ref(repo, f"refs/heads/{b}") or has_ref(repo, f"refs/remotes/origin/{b}"):
            return b
    return None


def resolve_source(raw: str, repo_root: Path):
    """Resolve a --add argument to an absolute path to a git repo.
    Bare name → <repo_root>/<name>
    Contains a slash → resolved against $PWD
    Absolute → as-is
    Must contain .git/ to count.
    """
    if raw.startswith("/"):
        resolved = Path(raw)
    elif "/" in raw:
        try:
            resolved = Path(raw).resolve(strict=True)
        except (OSError, FileNotFoundError):
            return None
    else:
        resolved = repo_root / raw
    if not (resolved / ".git").is_dir():
        return None
    return resolved.resolve()


# ---------------------------------------------------------------------------
# Target expansion for pull/master: take a list of user-provided folder args
# and flatten into a deduped list of git-repo paths.
#
# Per arg:
#   - absolute path → used as-is
#   - path with a slash → resolved against $PWD
#   - bare name → $PWD/<name>
# If the resulting folder has .git, it's treated as a single repo. Otherwise
# its immediate subfolders are scanned and each one with .git is included.
# Empty input → default to [$PWD].
# ---------------------------------------------------------------------------
def expand_targets(folders: list, block_workspace: bool = False) -> list:
    if not folders:
        folders = [os.getcwd()]

    repos: list = []
    seen: set = set()

    for raw in folders:
        p = Path(raw)
        if not p.is_absolute():
            p = Path.cwd() / p
        p = p.resolve()

        if not p.is_dir():
            die(f"not a directory: {raw}")

        if block_workspace and (p / "workspace.yml").is_file():
            die(
                f"'master' is blocked inside a workspace ({p} contains "
                f"workspace.yml). Use `mkws pull` there instead, or run "
                f"`mkws master` on the repo root."
            )

        if (p / ".git").exists():
            candidates = [p]
        else:
            candidates = sorted(
                s for s in p.iterdir() if s.is_dir() and (s / ".git").exists()
            )

        for c in candidates:
            key = str(c)
            if key not in seen:
                seen.add(key)
                repos.append(c)

    return repos


# ---------------------------------------------------------------------------
# Default-mode context detection:
#   PWD has workspace.yml → PWD is the workspace dir; root is grandparent.
#   PWD's basename is lpworkspaces → root is its parent.
#   Otherwise → PWD is the root; workspace goes to PWD/lpworkspaces/<name>/.
# ---------------------------------------------------------------------------
def resolve_default_context(pwd: Path, name_flag: str):
    yml = pwd / "workspace.yml"
    if yml.is_file():
        data = read_manifest(yml)
        name_from_yml = data["name"] or ""
        if name_flag and name_flag != name_from_yml:
            die(f"--name '{name_flag}' does not match workspace.yml name '{name_from_yml}'")
        return pwd, pwd.parent.parent, name_from_yml

    if not name_flag:
        die("--name required (or run from inside a workspace dir)")

    repo_root = pwd.parent if pwd.name == WS_CONTAINER else pwd
    workspace_folder = name_flag.replace("/", "_")
    return repo_root / WS_CONTAINER / workspace_folder, repo_root, name_flag


# ---------------------------------------------------------------------------
# pull mode: iterate every immediate subfolder of the target; for each one
# that's a git repo (source repo or worktree — `.git` can be a dir or a file),
# run `git pull` on the currently checked-out branch.
# ---------------------------------------------------------------------------
def cmd_pull(folders: list) -> int:
    repos = expand_targets(folders)

    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    info(f"pulling {len(repos)} repo(s) in parallel...")

    def worker(sub: Path, log: RepoLog) -> str:
        log.heading(sub.name)
        proc = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
        branch = proc.stdout.strip() if proc.returncode == 0 else ""
        if not branch:
            log.warn("could not determine current branch, skipping")
            return "skipped"
        if branch == "HEAD":
            log.warn("detached HEAD, skipping")
            return "skipped"
        log.info(f"pull latest data from {BOLD}{branch}{RESET}")
        proc = run(["git", "-C", str(sub), "pull", "--ff-only"])
        log.raw((proc.stdout or "").rstrip())
        log.raw((proc.stderr or "").rstrip())
        if proc.returncode == 0:
            log.ok(f"updated {sub.name}")
            return "pulled"
        log.fail(f"pull failed for {sub.name}")
        return "failed"

    results = run_in_parallel(repos, worker)
    pulled = sum(1 for r in results if r == "pulled")
    skipped = sum(1 for r in results if r == "skipped")
    failed_repos = [repos[i].name for i, r in enumerate(results) if r == "failed"]
    failed = len(failed_repos)

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"pulled: {color}{pulled}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    if failed_repos:
        info(f"failed: {RED}{', '.join(failed_repos)}{RESET}")
    return 0 if failed == 0 else 1


# ---------------------------------------------------------------------------
# master mode: for every git repo in the immediate subfolders, nuke untracked
# files, discard local changes on the current branch, switch to master
# (falling back to main), and fast-forward pull. Explicitly BLOCKED inside
# workspace folders — worktrees live on feature branches and this would
# clobber the feature work.
# ---------------------------------------------------------------------------
def cmd_master(folders: list) -> int:
    repos = expand_targets(folders, block_workspace=True)

    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    info(f"resetting {len(repos)} repo(s) to master in parallel...")

    def worker(sub: Path, log: RepoLog) -> str:
        log.heading(sub.name)
        base = detect_base(sub)
        if base is None:
            log.warn("no master/main branch, skipping")
            return "skipped"

        cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
        cur_branch = cur.stdout.strip() if cur.returncode == 0 else ""

        log.info("git clean -d -f")
        p = run(["git", "-C", str(sub), "clean", "-d", "-f"])
        log.raw((p.stdout or "").rstrip())
        log.raw((p.stderr or "").rstrip())

        # Discard local changes to tracked files before anything else so the
        # branch switch below can't fail with "would be overwritten". Only run
        # when the tree is actually dirty — `git checkout -- .` on a clean
        # tree prints a noisy "pathspec '.' did not match" error.
        status = run(["git", "-C", str(sub), "status", "--porcelain"])
        if status.stdout.strip():
            log.info("git checkout -- . (discard local changes)")
            p = run(["git", "-C", str(sub), "checkout", "--", "."])
            log.raw((p.stdout or "").rstrip())
            log.raw((p.stderr or "").rstrip())

        if cur_branch != base:
            log.info(f"git checkout {base} (was on {cur_branch or 'unknown'})")
            p = run(["git", "-C", str(sub), "checkout", base])
            log.raw((p.stdout or "").rstrip())
            log.raw((p.stderr or "").rstrip())
            if p.returncode != 0:
                log.fail(f"failed to checkout {base}")
                return "failed"

        log.info(f"pull latest from {BOLD}{base}{RESET}")
        p = run(["git", "-C", str(sub), "pull", "--ff-only"])
        log.raw((p.stdout or "").rstrip())
        log.raw((p.stderr or "").rstrip())
        if p.returncode != 0:
            log.fail("pull failed")
            return "failed"

        log.ok(f"on {base} and updated")
        return "reset"

    results = run_in_parallel(repos, worker)
    reset = sum(1 for r in results if r == "reset")
    skipped = sum(1 for r in results if r == "skipped")
    failed_repos = [repos[i].name for i, r in enumerate(results) if r == "failed"]
    failed = len(failed_repos)

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"reset: {color}{reset}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    if failed_repos:
        info(f"failed: {RED}{', '.join(failed_repos)}{RESET}")
    return 0 if failed == 0 else 1


# ---------------------------------------------------------------------------
# Shared rebase helper used by both `mkws rebase` and `mkws sync`.
#
# Flow:
#   1. Detect base (master/main) and current branch. Skip repos on base,
#      detached, or without a base branch.
#   2. If working tree is dirty, `git stash push -u` (untracked included).
#   3. `git fetch origin <base>` (non-zero → pop stash, return "failed")
#   4. `git merge --no-edit origin/<base>`
#        - clean merge   → pop stash, return "rebased"
#        - conflict      → leave the merge + stash in place, print resolve
#                          instructions, return "conflict"
#        - other failure → `git merge --abort`, pop stash, return "failed"
#
# Returns one of:
#   "rebased"  — merge succeeded
#   "already"  — already on base, nothing to do (informational; not a failure)
#   "skipped"  — no base branch or detached HEAD
#   "failed"   — non-conflict failure; state restored; caller should halt
#   "conflict" — merge conflict; state left in place; caller MUST halt
# ---------------------------------------------------------------------------
def _rebase_one(sub: Path) -> str:
    base = detect_base(sub)
    if base is None:
        warn("no master/main branch, skipping rebase")
        return "skipped"

    cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
    cur_branch = cur.stdout.strip() if cur.returncode == 0 else ""
    if not cur_branch or cur_branch == "HEAD":
        warn("detached HEAD, skipping rebase")
        return "skipped"
    if cur_branch == base:
        info(f"already on {base}, skipping rebase")
        return "already"

    stashed = False
    status = run(["git", "-C", str(sub), "status", "--porcelain"])
    if status.stdout.strip():
        info("git stash push -u (autosaving local changes)")
        sp = run(["git", "-C", str(sub), "stash", "push", "-u", "-m", "mkws rebase autostash"])
        if sp.returncode != 0:
            fail("stash failed")
            return "failed"
        stashed = True

    def pop_stash():
        if not stashed:
            return
        info("git stash pop")
        pp = run(["git", "-C", str(sub), "stash", "pop"])
        if pp.returncode != 0:
            warn("stash pop had conflicts — resolve manually")

    info(f"git fetch origin {base}")
    fp = run(["git", "-C", str(sub), "fetch", "origin", base])
    if fp.returncode != 0:
        fail("fetch failed")
        pop_stash()
        return "failed"

    info(f"git merge origin/{base} (into {cur_branch})")
    mp = run(["git", "-C", str(sub), "merge", "--no-edit", f"origin/{base}"], capture=False)
    if mp.returncode == 0:
        ok(f"merged origin/{base} into {cur_branch}")
        pop_stash()
        return "rebased"

    unmerged = run(["git", "-C", str(sub), "ls-files", "--unmerged"])
    if unmerged.stdout.strip():
        heading(f"CONFLICT in {sub.name}")
        warn(f"merge conflict — resolve manually in {sub}")
        info("  1. fix conflicted files")
        info("  2. git add <files> && git commit")
        if stashed:
            info(f"  3. {BOLD}git stash pop{RESET} (your pre-rebase changes are in the stash)")
        return "conflict"

    fail("merge failed (non-conflict)")
    run(["git", "-C", str(sub), "merge", "--abort"])
    pop_stash()
    return "failed"


# ---------------------------------------------------------------------------
# rebase mode: bring every matching repo's feature branch up to master/main
# via merge. Serial, halts on conflict. Uses `_rebase_one` above.
# ---------------------------------------------------------------------------
def cmd_rebase(folders: list) -> int:
    repos = expand_targets(folders)
    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    info(f"rebasing {len(repos)} repo(s) onto master (serial)...")
    rebased = skipped = failed = 0

    for sub in repos:
        heading(sub.name)
        status = _rebase_one(sub)
        if status == "rebased":
            rebased += 1
        elif status in ("already", "skipped"):
            skipped += 1
        elif status == "failed":
            failed += 1
            heading("summary")
            info(f"rebased: {rebased}, skipped: {skipped}, failed: 1")
            info(f"halted at: {BOLD}{sub.name}{RESET}")
            return 1
        elif status == "conflict":
            info("")
            info("halted; other repos not processed")
            heading("summary")
            info(f"rebased: {rebased}, skipped: {skipped}, conflict: 1")
            info(f"halted at: {BOLD}{sub.name}{RESET}")
            return 1

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"rebased: {color}{rebased}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    return 0 if failed == 0 else 1


# ---------------------------------------------------------------------------
# push mode: `git push origin HEAD` for every matching repo, in parallel.
# Detached HEAD is skipped. Non-ff / auth failures are reported as failures
# but don't halt — user can inspect the list and retry individually.
# ---------------------------------------------------------------------------
def cmd_push(folders: list) -> int:
    repos = expand_targets(folders)
    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    info(f"pushing {len(repos)} repo(s) in parallel...")

    def worker(sub: Path, log: RepoLog) -> str:
        log.heading(sub.name)
        cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
        branch = cur.stdout.strip() if cur.returncode == 0 else ""
        if not branch or branch == "HEAD":
            log.warn("detached HEAD, skipping")
            return "skipped"
        log.info(f"git push origin HEAD ({BOLD}{branch}{RESET})")
        proc = run(["git", "-C", str(sub), "push", "origin", "HEAD"])
        log.raw((proc.stdout or "").rstrip())
        log.raw((proc.stderr or "").rstrip())
        if proc.returncode == 0:
            log.ok(f"pushed {branch}")
            return "pushed"
        log.fail(f"push failed for {sub.name}")
        return "failed"

    results = run_in_parallel(repos, worker)
    pushed = sum(1 for r in results if r == "pushed")
    skipped = sum(1 for r in results if r == "skipped")
    failed_repos = [repos[i].name for i, r in enumerate(results) if r == "failed"]
    failed = len(failed_repos)

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"pushed: {color}{pushed}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    if failed_repos:
        info(f"failed: {RED}{', '.join(failed_repos)}{RESET}")
    return 0 if failed == 0 else 1


# ---------------------------------------------------------------------------
# sync mode: pull → rebase → push, per repo, serial. Halts on rebase
# conflict (like `mkws rebase`). Pull/push failures are recorded but the
# command continues to the next repo — only rebase halts the batch.
#
# Why serial: a conflict during rebase needs the user's attention. Parallel
# pulls + parallel pushes would also work but would obscure which repo
# halted.
# ---------------------------------------------------------------------------
def cmd_sync(folders: list) -> int:
    repos = expand_targets(folders)
    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    info(f"syncing {len(repos)} repo(s) — pull → rebase → push (serial)...")
    synced = skipped = 0
    pull_fails: list = []
    push_fails: list = []
    rebase_fails: list = []

    for sub in repos:
        heading(sub.name)

        cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
        cur_branch = cur.stdout.strip() if cur.returncode == 0 else ""
        if not cur_branch or cur_branch == "HEAD":
            warn("detached HEAD, skipping repo")
            skipped += 1
            continue

        # 1. pull current branch (explicit `origin <branch>` — not `HEAD`, which
        #    on the remote side resolves to the default branch, not the same-
        #    named one). If `origin/<branch>` doesn't exist yet (brand-new
        #    local branch), that's not a failure — we just skip straight to
        #    the rebase+push steps so the first push creates the remote ref.
        has_remote = run(
            ["git", "-C", str(sub), "ls-remote", "--exit-code",
             "--heads", "origin", cur_branch]
        ).returncode == 0
        if not has_remote:
            info(f"no origin/{cur_branch} yet — skipping pull (will be created on push)")
        else:
            info(f"git pull --ff-only origin {BOLD}{cur_branch}{RESET}")
            pp = run(
                ["git", "-C", str(sub), "pull", "--ff-only", "origin", cur_branch],
                capture=False,
            )
            if pp.returncode != 0:
                fail("pull failed — skipping rebase/push for this repo")
                pull_fails.append(sub.name)
                continue

        # 2. rebase (unless already on base)
        status = _rebase_one(sub)
        if status == "conflict":
            info("")
            info("halted; remaining repos not processed")
            heading("summary")
            info(f"synced: {synced}, skipped: {skipped}, halted at: {BOLD}{sub.name}{RESET} (rebase conflict)")
            if pull_fails:
                info(f"pull failed before halt: {RED}{', '.join(pull_fails)}{RESET}")
            return 1
        if status == "failed":
            rebase_fails.append(sub.name)
            heading("summary")
            info(f"synced: {synced}, skipped: {skipped}, halted at: {BOLD}{sub.name}{RESET} (rebase failed)")
            return 1
        # "rebased", "already", "skipped" — continue to push

        # 3. push
        info(f"git push origin HEAD")
        pushp = run(["git", "-C", str(sub), "push", "origin", "HEAD"], capture=False)
        if pushp.returncode != 0:
            fail("push failed")
            push_fails.append(sub.name)
            continue
        ok(f"synced {cur_branch}")
        synced += 1

    heading("summary")
    total_fail = len(pull_fails) + len(push_fails) + len(rebase_fails)
    color = GREEN if total_fail == 0 else YELLOW
    info(f"synced: {color}{synced}{RESET}, skipped: {skipped}, failed: {color}{total_fail}{RESET}")
    if pull_fails:
        info(f"pull failed: {RED}{', '.join(pull_fails)}{RESET}")
    if push_fails:
        info(f"push failed: {RED}{', '.join(push_fails)}{RESET}")
    return 0 if total_fail == 0 else 1


# ---------------------------------------------------------------------------
# drop mode: remove every worktree listed in the manifest, prune the source
# repos, then delete the workspace folder itself. Destructive by design —
# uncommitted work inside the worktrees is lost (mirrors `git worktree remove
# --force`). No confirmation prompt.
# ---------------------------------------------------------------------------
def cmd_drop(folder: str) -> int:
    path = Path(folder)
    if not path.is_dir():
        die(f"not a directory: {folder}")
    workspace_dir = path.resolve()
    yml = workspace_dir / "workspace.yml"
    if not yml.is_file():
        die(f"no workspace.yml at {workspace_dir} (not a workspace)")

    data = read_manifest(yml)
    repos = data["repos"]
    repo_root = workspace_dir.parent.parent

    # Collect unique source repos so we can prune each one once at the end,
    # regardless of whether its worktree needed rm -rf fallback.
    sources: list = []
    seen: set = set()

    for leaf in repos:
        heading(f"drop {leaf}")
        source_path = repo_root / leaf
        worktree_path = workspace_dir / leaf
        source_is_git = (source_path / ".git").is_dir()

        if source_is_git and source_path not in seen:
            sources.append(source_path)
            seen.add(source_path)

        if not worktree_path.exists():
            info(f"worktree already gone at {worktree_path}")
            continue

        removed_via_git = False
        if source_is_git:
            proc = run(
                ["git", "-C", str(source_path), "worktree", "remove",
                 "--force", str(worktree_path)]
            )
            if proc.returncode == 0:
                ok(f"removed worktree at {worktree_path}")
                removed_via_git = True
            else:
                warn("git worktree remove failed, falling back to rm -rf")
        else:
            warn(f"source repo {source_path} not found, removing directly")

        if not removed_via_git:
            try:
                shutil.rmtree(worktree_path)
                ok(f"removed directory {worktree_path}")
            except OSError as e:
                fail(f"failed to remove {worktree_path}: {e}")

    if sources:
        heading("prune source repos")
        for src in sources:
            proc = run(["git", "-C", str(src), "worktree", "prune"])
            if proc.returncode == 0:
                ok(f"pruned {src}")
            else:
                warn(f"prune failed for {src}")

    heading("cleanup")
    try:
        shutil.rmtree(workspace_dir)
        ok(f"removed workspace dir {workspace_dir}")
    except OSError as e:
        fail(f"failed to remove {workspace_dir}: {e}")

    # If the lpworkspaces container is now empty, drop it too. Best-effort —
    # any failure is fine (container still holds other workspaces).
    container = workspace_dir.parent
    if container.is_dir() and container.name == WS_CONTAINER:
        try:
            container.rmdir()
            ok(f"removed empty container {container}")
        except OSError:
            pass

    heading("summary")
    info(f"workspace: {BOLD}{workspace_dir}{RESET} (dropped)")
    info(f"repos dropped: {len(repos)}")
    return 0


# ---------------------------------------------------------------------------
# default mode: create or extend a workspace, optionally --add repos.
# ---------------------------------------------------------------------------
def cmd_default(name_flag: str, branch_flag: str, repos_arg: list) -> int:
    pwd = Path.cwd()
    workspace_dir, repo_root, name = resolve_default_context(pwd, name_flag)
    yml = workspace_dir / "workspace.yml"

    if yml.is_file():
        data = read_manifest(yml)
        existing = data["branch_name"]
        if not existing:
            die(f"workspace.yml at {yml} is missing branch_name")
        if branch_flag and branch_flag != existing:
            die(f"--branch '{branch_flag}' does not match workspace.yml branch '{existing}'")
        branch = existing
    else:
        if not branch_flag:
            die("--branch required when creating a new workspace")
        workspace_dir.mkdir(parents=True, exist_ok=True)
        write_manifest(yml, name=name, branch=branch_flag, repos=[])
        branch = branch_flag

    added = skipped = failed = 0

    for repo in repos_arg:
        heading(repo)
        repo_path = resolve_source(repo, repo_root)
        if repo_path is None:
            fail(f"not a git repo: {repo}")
            failed += 1
            continue

        leaf = repo_path.name
        if leaf != repo:
            info(f"source: {repo_path} (recorded as '{leaf}')")

        if leaf in read_manifest(yml)["repos"]:
            info(f"'{leaf}' already in workspace, skipping")
            skipped += 1
            continue

        wt_path = workspace_dir / leaf
        if wt_path.exists():
            info("worktree path already exists, recording in yml")
            append_repo(yml, leaf)
            skipped += 1
            continue

        # Try the existing branch first. Bash version silences stderr here
        # because the "no such branch" error is expected.
        proc = run(["git", "-C", str(repo_path), "worktree", "add", str(wt_path), branch])
        if proc.returncode == 0:
            ok(f"checked out existing branch {branch}")
            append_repo(yml, leaf)
            added += 1
            continue

        info("fetching latest from origin")
        if run(["git", "-C", str(repo_path), "fetch", "origin", "--quiet"]).returncode != 0:
            warn("fetch failed, falling back to local refs")

        base = detect_base(repo_path)
        if base is None:
            fail("could not detect base branch (master/main)")
            failed += 1
            continue

        start_ref = f"origin/{base}" if has_ref(repo_path, f"refs/remotes/origin/{base}") else base
        info(f"creating new branch {branch} from {start_ref}")
        proc = run(
            ["git", "-C", str(repo_path), "worktree", "add", "-b", branch, str(wt_path), start_ref],
            capture=False,
        )
        if proc.returncode == 0:
            ok(f"worktree added at {wt_path}")
            append_repo(yml, leaf)
            added += 1
        else:
            fail("worktree add failed")
            failed += 1

    heading("summary")
    info(f"workspace: {BOLD}{workspace_dir}{RESET}")
    info(f"branch:    {BOLD}{branch}{RESET}")
    color = GREEN if failed == 0 else YELLOW
    info(f"added: {color}{added}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    return 0


# ---------------------------------------------------------------------------
# Argument parsing. Manual, because --add is variadic (takes N bare args until
# the next --flag) and argparse makes that awkward.
# ---------------------------------------------------------------------------
USAGE = """\
Usage:
  mkws [--name <name>] [--branch <branch>] [--add <repo>...]
  mkws pull [<folder>...]
  mkws push [<folder>...]
  mkws master [<folder>...]
  mkws rebase [<folder>...]
  mkws sync [<folder>...]
  mkws drop <folder>

Modes:
  (default)  Create or extend a workspace. Run from the root folder that
             contains the source repos, or from inside a workspace dir.
  pull       `git pull --ff-only` on the currently checked-out branch of every
             matching repo. Takes any number of folder args (absolute, relative,
             or a bare name under $PWD). Each arg is either a git repo (pulled
             directly) or a directory whose immediate git-repo subfolders are
             pulled. No args → iterate $PWD's subfolders.
             Examples:
               mkws pull                        # every repo under $PWD
               mkws pull repo-a                 # just one repo in $PWD
               mkws pull repo-a repo-b          # two repos
               mkws pull ./lpworkspaces/myws    # every worktree in a workspace
               mkws pull /abs/repo-a ./repo-b   # mix absolute and relative
  master     For every matching repo: `git clean -d -f`, optional
             `git checkout -- .` to discard local changes, switch to master
             (fallback main), and `git pull --ff-only`. DESTRUCTIVE to
             uncommitted work. Takes the same folder-args form as `pull`.
             BLOCKED when any target folder itself contains a workspace.yml —
             running it in a workspace would wipe feature-branch state.
             Examples:
               mkws master                      # all source repos under $PWD
               mkws master repo-a repo-b        # two specific repos
               mkws master /abs/path/to/root
  push       `git push origin HEAD` on the current branch of every matching
             repo. Parallel. Detached HEAD is skipped. Non-ff / auth failures
             are reported at the end; the batch does not halt.
             Examples:
               mkws push                     # push every repo under $PWD
               mkws push repo-a repo-b       # two specific repos
  rebase     For every matching repo on a feature branch: stash dirty edits,
             `git fetch origin <base>`, `git merge origin/<base>` into the
             current branch, then pop the stash. Runs serial (conflicts need
             attention). On conflict: HALTS — leaves the merge + stash in
             place for you to resolve, prints resolve-and-finish instructions,
             and does NOT process remaining repos. Non-conflict failures
             trigger `git merge --abort` + stash-pop to restore state.
             Takes the same folder-args form as pull/master.
             Examples:
               mkws rebase                   # merge master into every feature
                                             #   branch in $PWD's repos
               mkws rebase diamond_filter
  sync       Composite: for every matching repo, pull the current branch,
             rebase onto master (skipped if already on master/main), then
             push. Serial. Rebase conflicts halt the whole run with the same
             instructions as `mkws rebase`. Pull/push failures for one repo
             don't halt — they're recorded and the run continues.
             Examples:
               mkws sync                     # pull+rebase+push every repo
               mkws sync diamond_filter      # just one repo
  drop       Remove every worktree listed in the workspace, prune the source
             repos, and delete the workspace folder itself. DESTRUCTIVE —
             uncommitted work in the worktrees is lost (runs `git worktree
             remove --force`). No confirmation prompt.
             Examples:
               mkws drop ./lpworkspaces/myws
               mkws drop /abs/path/to/ws

Flags:
  --name <name>       workspace name. Required when creating a new workspace
                      or when invoked from the root. When invoked from inside
                      a workspace dir, read from workspace.yml. `/` in the
                      name becomes `_` in the folder.
  --branch <branch>   branch name. Required on first create. Optional on
                      re-add; must match workspace.yml if provided.
  --add <repo>...     one or more repos to add. Each entry can be:
                        - a bare name (looked up under the root)
                        - a relative path (resolved against $PWD, e.g. ../repo)
                        - an absolute path
                      Variadic: --add a b c  or  --add a --add b
  -h, --help          show this message

Layout:
  All workspaces live inside `$PWD/lpworkspaces/<name>/`.

Environment:
  NO_COLOR      set to any value to disable colored output.
"""


def parse_args(argv):
    mode = "default"
    name = ""
    branch = ""
    repos: list = []
    target_path = ""
    target_paths: list = []

    argv = list(argv)

    if argv and not argv[0].startswith("-"):
        sub = argv[0]
        if sub == "pull":
            mode = "pull"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "push":
            mode = "push"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "sync":
            mode = "sync"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "master":
            mode = "master"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "rebase":
            mode = "rebase"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "drop":
            mode = "drop"
            argv.pop(0)
            if argv and not argv[0].startswith("-"):
                target_path = argv.pop(0)
            else:
                die(f"'drop' requires a workspace folder path\n\n{USAGE}")
        else:
            die(f"unknown subcommand: {sub}\n\n{USAGE}")

    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--name":
            if i + 1 >= len(argv):
                die("--name requires a value")
            name = argv[i + 1]
            i += 2
        elif a == "--branch":
            if i + 1 >= len(argv):
                die("--branch requires a value")
            branch = argv[i + 1]
            i += 2
        elif a == "--add":
            i += 1
            while i < len(argv) and not argv[i].startswith("--"):
                repos.append(argv[i])
                i += 1
        elif a in ("-h", "--help"):
            print(USAGE)
            sys.exit(0)
        else:
            die(f"unknown flag: {a}\n\n{USAGE}")

    return mode, name, branch, repos, target_path, target_paths


def main() -> None:
    if not has_cmd("git"):
        die("git not installed")

    mode, name, branch, repos, target_path, target_paths = parse_args(sys.argv[1:])

    if mode == "pull":
        if repos or branch or name:
            die("'pull' takes folder path(s) only; --add/--branch/--name are not accepted")
        sys.exit(cmd_pull(target_paths))
    if mode == "push":
        if repos or branch or name:
            die("'push' takes folder path(s) only; --add/--branch/--name are not accepted")
        sys.exit(cmd_push(target_paths))
    if mode == "sync":
        if repos or branch or name:
            die("'sync' takes folder path(s) only; --add/--branch/--name are not accepted")
        sys.exit(cmd_sync(target_paths))
    if mode == "master":
        if repos or branch or name:
            die("'master' takes folder path(s) only; --add/--branch/--name are not accepted")
        sys.exit(cmd_master(target_paths))
    if mode == "rebase":
        if repos or branch or name:
            die("'rebase' takes folder path(s) only; --add/--branch/--name are not accepted")
        sys.exit(cmd_rebase(target_paths))
    if mode == "drop":
        if repos or branch or name:
            die("'drop' takes a folder path only; --add/--branch/--name are not accepted")
        sys.exit(cmd_drop(target_path))
    sys.exit(cmd_default(name, branch, repos))


if __name__ == "__main__":
    main()
