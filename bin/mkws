#!/usr/bin/env python3
"""mkws — multi-repo git-worktree workspace manager.

Every workspace lives at `<root>/local_workspaces/<name>/` and is a set of git
worktrees (one per source repo) on a default branch, with optional per-repo
branch and base-branch overrides, glued together by a small `workspace.yml` manifest. Go
workspaces (`go.work`) are intentionally NOT created — per-module semantics
(GOWORK=off everywhere) is the standard here; cross-module navigation happens
via `<leader>gw` worktree switching instead.
"""

import concurrent.futures
import os
import shutil
import subprocess
import sys
from pathlib import Path

WS_CONTAINER = "local_workspaces"
EXTERNAL_DIR = "_external"
AGENT_SKILL_TARGETS = (
    ("codex", Path(".agent") / "skills"),
    ("claude-code", Path(".claude") / "skills"),
    ("cursor", Path(".cursor") / "skills"),
)

# ---------------------------------------------------------------------------
# Colored logging. Disabled when stdout isn't a TTY or NO_COLOR is set, so pipes
# and CI logs stay clean.
# ---------------------------------------------------------------------------
_USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(code: str) -> str:
    return f"\033[{code}m" if _USE_COLOR else ""


RESET = _c("0")
BOLD = _c("1")
DIM = _c("2")
RED = _c("31")
GREEN = _c("32")
YELLOW = _c("33")
BLUE = _c("34")
CYAN = _c("36")


def heading(text: str) -> None:
    # flush=True keeps our stdout interleaved correctly with subprocess stderr
    # when the final output is redirected (where stdout would otherwise become
    # block-buffered and git messages leak above our headings).
    print(f"\n{BOLD}{CYAN}=== {text} ==={RESET}", flush=True)


def info(text: str) -> None:
    print(f"  {text}", flush=True)


def ok(text: str) -> None:
    print(f"  {GREEN}✓{RESET} {text}", flush=True)


def warn(text: str) -> None:
    print(f"  {YELLOW}!{RESET} {text}", flush=True)


def fail(text: str) -> None:
    print(f"  {RED}✗{RESET} {text}", flush=True)


def die(text: str, code: int = 1) -> None:
    print(f"{RED}error:{RESET} {text}", file=sys.stderr)
    sys.exit(code)


def has_cmd(name: str) -> bool:
    return shutil.which(name) is not None


def is_git_worktree(path: Path) -> bool:
    proc = run(["git", "-C", str(path), "rev-parse", "--is-inside-work-tree"])
    return proc.returncode == 0 and proc.stdout.strip() == "true"


def git_top_level(path: Path):
    proc = run(["git", "-C", str(path), "rev-parse", "--show-toplevel"])
    if proc.returncode != 0:
        return None
    out = proc.stdout.strip()
    return Path(out).resolve() if out else None


# ---------------------------------------------------------------------------
# Parallel per-repo runner. Each worker writes to its own RepoLog instead of
# stdout; once all workers finish, logs are printed in submission order so
# output reads like the serial version — no interleaving, no flickering.
# ---------------------------------------------------------------------------
class RepoLog:
    """A buffered logger. Same methods as the top-level log helpers but
    accumulates lines so they can be flushed together at the end."""

    def __init__(self) -> None:
        self._lines: list = []

    def heading(self, t: str) -> None: self._lines.append(("heading", t))
    def info(self, t: str) -> None: self._lines.append(("info", t))
    def ok(self, t: str) -> None: self._lines.append(("ok", t))
    def warn(self, t: str) -> None: self._lines.append(("warn", t))
    def fail(self, t: str) -> None: self._lines.append(("fail", t))
    def raw(self, t: str) -> None: self._lines.append(("raw", t))

    def render(self) -> None:
        for kind, text in self._lines:
            if kind == "heading": heading(text)
            elif kind == "info": info(text)
            elif kind == "ok": ok(text)
            elif kind == "warn": warn(text)
            elif kind == "fail": fail(text)
            elif kind == "raw":
                if text:
                    print(text, flush=True)


def _draw_progress_bar(done: int, total: int) -> None:
    """Draw/redraw a single-line progress bar in place using \r. Caller is
    responsible for clearing the line when done."""
    bar_width = 30
    filled = int(bar_width * done / total) if total else bar_width
    bar = "█" * filled + "░" * (bar_width - filled)
    pct = int(done / total * 100) if total else 100
    sys.stdout.write(f"\r  [{CYAN}{bar}{RESET}] {done}/{total} ({pct}%)")
    sys.stdout.flush()


def _clear_progress_line() -> None:
    # 60 spaces clears a 30-char bar plus the "N/M (P%)" counter safely.
    sys.stdout.write("\r" + " " * 60 + "\r")
    sys.stdout.flush()


def run_in_parallel(items, worker, max_workers: int = 8) -> list:
    """Call worker(item, log) for each item in a thread pool, then flush each
    RepoLog in submission order. Returns the list of worker return values,
    one per item in the same order.

    Shows a live progress bar while workers run, as long as stdout is a TTY
    and there are enough items to make it worthwhile (>=2). The bar is drawn
    in-place with \\r and cleared before the buffered logs are rendered, so
    the final output still reads cleanly."""
    if not items:
        return []
    n = min(max_workers, len(items))
    logs = [RepoLog() for _ in items]
    results: list = [None] * len(items)

    show_bar = sys.stdout.isatty() and len(items) >= 2
    if show_bar:
        _draw_progress_bar(0, len(items))

    with concurrent.futures.ThreadPoolExecutor(max_workers=n) as ex:
        futs = {ex.submit(worker, item, logs[i]): i for i, item in enumerate(items)}
        done = 0
        for fut in concurrent.futures.as_completed(futs):
            i = futs[fut]
            try:
                results[i] = fut.result()
            except Exception as e:
                results[i] = None
                logs[i].fail(f"worker crashed: {e}")
            done += 1
            if show_bar:
                _draw_progress_bar(done, len(items))

    if show_bar:
        _clear_progress_line()

    for log in logs:
        log.render()
    return results


# ---------------------------------------------------------------------------
# Subprocess helpers
# ---------------------------------------------------------------------------
def run(cmd, cwd=None, capture=True):
    return subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        capture_output=capture,
        text=True,
    )


# ---------------------------------------------------------------------------
# workspace.yml I/O. Hand-parsed so we don't pull in PyYAML.
# v1 format:
#   name: <workspace-name>
#   branch_name: <branch>
#   repos:
#     - repo-a
#     - repo-b
# v2 format:
#   version: v2
#   name: <workspace-name>
#   branch_name: <default-branch>
#   links:
#     - name: docs
#       link: https://example.com
#   repos:
#     - name: repo-a
#       branch_name: <repo-branch>
#       base_branch: <optional-base-branch>
# Omit base_branch to use the default main/master detection.
# ---------------------------------------------------------------------------
def read_manifest(yml: Path) -> dict:
    data = {"version": "v1", "name": "", "branch_name": "", "repos": [], "links": []}
    section = ""
    current_repo = None
    current_link = None
    for line in yml.read_text().splitlines():
        if line.startswith("version:"):
            data["version"] = line.split(":", 1)[1].strip() or "v1"
            section = ""
        elif line.startswith("name:"):
            data["name"] = line.split(":", 1)[1].strip()
            section = ""
        elif line.startswith("branch_name:"):
            data["branch_name"] = line.split(":", 1)[1].strip()
            section = ""
        elif line.startswith("links:"):
            section = "links"
            current_link = None
        elif line.startswith("repos:"):
            section = "repos"
            current_repo = None
        elif section == "links" and line.startswith("  - name:"):
            current_link = {"name": line.split(":", 1)[1].strip(), "link": ""}
            data["links"].append(current_link)
        elif section == "links" and line.startswith("    link:") and current_link is not None:
            current_link["link"] = line.split(":", 1)[1].strip()
        elif section == "repos" and line.startswith("  - name:"):
            current_repo = {
                "name": line.split(":", 1)[1].strip(),
                "branch_name": "",
                "base_branch": "",
            }
            data["repos"].append(current_repo)
        elif section == "repos" and line.startswith("    branch_name:") and current_repo is not None:
            current_repo["branch_name"] = line.split(":", 1)[1].strip()
        elif section == "repos" and line.startswith("    base_branch:") and current_repo is not None:
            current_repo["base_branch"] = line.split(":", 1)[1].strip()
        elif section == "repos" and line.startswith("  - "):
            data["repos"].append({
                "name": line[4:].strip(),
                "branch_name": data["branch_name"],
                "base_branch": "",
            })
    return data


def write_manifest(yml: Path, name: str, branch: str, repos: list, links: list = None) -> None:
    lines = ["version: v2", f"name: {name}", f"branch_name: {branch}"]
    normalized_links = normalize_links(links or [])
    if normalized_links:
        lines.append("links:")
        for item in normalized_links:
            lines.append(f"  - name: {item['name']}")
            lines.append(f"    link: {item['link']}")
    lines.append("repos:")
    for repo in normalize_repos(repos, branch):
        lines.append(f"  - name: {repo['name']}")
        lines.append(f"    branch_name: {repo['branch_name']}")
        if repo["base_branch"]:
            lines.append(f"    base_branch: {repo['base_branch']}")
    yml.write_text("\n".join(lines) + "\n")


def ensure_tech_doc_repo(workspace_dir: Path) -> None:
    tech_doc = workspace_dir / "tech_doc"
    if tech_doc.exists() and not tech_doc.is_dir():
        die(f"tech_doc path exists and is not a directory: {tech_doc}")
    tech_doc.mkdir(parents=True, exist_ok=True)
    if (tech_doc / ".git").exists():
        return
    proc = run(["git", "-C", str(tech_doc), "init", "-q"])
    if proc.returncode != 0:
        die(f"failed to initialize tech_doc git repo at {tech_doc}")


def normalize_repos(repos: list, default_branch: str = "") -> list:
    out = []
    for repo in repos or []:
        if isinstance(repo, dict):
            name = str(repo.get("name") or "").strip()
            branch = str(repo.get("branch_name") or default_branch or "").strip()
            base_branch = str(repo.get("base_branch") or "").strip()
        else:
            name = str(repo).strip()
            branch = default_branch or ""
            base_branch = ""
        if name:
            out.append({
                "name": name,
                "branch_name": branch,
                "base_branch": base_branch,
            })
    return out


def normalize_links(links: list) -> list:
    out = []
    for item in links or []:
        if not isinstance(item, dict):
            continue
        name = str(item.get("name") or "").strip()
        link = str(item.get("link") or "").strip()
        if name and link:
            out.append({"name": name, "link": link})
    return out


def repo_names(repos: list) -> list:
    return [r["name"] for r in normalize_repos(repos)]


def repo_branch(repos: list, name: str, default_branch: str = "") -> str:
    for repo in normalize_repos(repos, default_branch):
        if repo["name"] == name:
            return repo["branch_name"] or default_branch
    return default_branch


def repo_base_branch(repos: list, name: str) -> str:
    for repo in normalize_repos(repos):
        if repo["name"] == name:
            return repo["base_branch"]
    return ""


def repo_entry(repos: list, name: str, default_branch: str = ""):
    for repo in normalize_repos(repos, default_branch):
        if repo["name"] == name:
            return repo
    return None


def append_repo(yml: Path, leaf: str, branch: str, base_branch: str = "") -> None:
    data = read_manifest(yml)
    repos = normalize_repos(data["repos"], data["branch_name"])
    repos.append({"name": leaf, "branch_name": branch, "base_branch": base_branch})
    write_manifest(yml, data["name"], data["branch_name"], repos, data["links"])


def upsert_link(yml: Path, name: str, link: str) -> str:
    data = read_manifest(yml)
    links = normalize_links(data.get("links", []))
    for item in links:
        if item["link"] == link:
            item["name"] = name
            write_manifest(yml, data["name"], data["branch_name"], data["repos"], links)
            return "renamed"
    for item in links:
        if item["name"] == name:
            item["link"] = link
            write_manifest(yml, data["name"], data["branch_name"], data["repos"], links)
            return "updated"
    links.append({"name": name, "link": link})
    write_manifest(yml, data["name"], data["branch_name"], data["repos"], links)
    return "added"


def parse_repo_spec(spec: str) -> tuple:
    if "@" not in spec:
        return spec, ""
    source, branch = spec.rsplit("@", 1)
    if not source or not branch:
        die(f"invalid --add repo spec '{spec}', expected <repo> or <repo>@<branch>")
    return source, branch


# ---------------------------------------------------------------------------
# Git helpers
# ---------------------------------------------------------------------------
DEFAULT_BASE_BRANCHES = ("main", "master")


def has_ref(repo: Path, ref: str) -> bool:
    return run(["git", "-C", str(repo), "show-ref", "--verify", "--quiet", ref]).returncode == 0


def git_output(repo: Path, args: list) -> str:
    proc = run(["git", "-C", str(repo), *args])
    if proc.returncode != 0:
        return ""
    return proc.stdout.strip()


def remote_names(repo: Path) -> list:
    out = git_output(repo, ["remote"])
    return [line.strip() for line in out.splitlines() if line.strip()]


def has_local_branch(repo: Path, branch: str) -> bool:
    return has_ref(repo, f"refs/heads/{branch}")


def has_remote_branch(repo: Path, branch: str) -> bool:
    return has_ref(repo, f"refs/remotes/origin/{branch}")


def detect_base(repo: Path):
    for b in DEFAULT_BASE_BRANCHES:
        if has_ref(repo, f"refs/heads/{b}") or has_ref(repo, f"refs/remotes/origin/{b}"):
            return b
    return None


def resolve_base(repo: Path, base_branch: str = ""):
    if base_branch:
        if has_local_branch(repo, base_branch) or has_remote_branch(repo, base_branch):
            return base_branch
        if "origin" in remote_names(repo):
            run(["git", "-C", str(repo), "fetch", "--quiet", "origin", base_branch])
            if has_remote_branch(repo, base_branch):
                return base_branch
        return None
    return detect_base(repo)


def base_ref(repo: Path, base: str, explicit_base: bool = False) -> str:
    if explicit_base and has_local_branch(repo, base):
        return base
    if has_remote_branch(repo, base):
        return f"origin/{base}"
    return base


def fetch_base_if_remote(repo: Path, base: str, ref: str) -> bool:
    if ref != f"origin/{base}":
        info(f"using local base branch {base}")
        return True
    info(f"git fetch origin {base}")
    return run(["git", "-C", str(repo), "fetch", "origin", base]).returncode == 0


def workspace_base_branch_for_repo(repo_path: Path) -> str:
    workspace_yml = repo_path.parent / "workspace.yml"
    if not workspace_yml.is_file():
        return ""
    data = read_manifest(workspace_yml)
    return repo_base_branch(data["repos"], repo_path.name)


def resolve_source(raw: str, repo_root: Path):
    """Resolve a --add argument to an absolute path to a git repo.
    Bare name → <repo_root>/<name>
    Contains a slash → resolved against $PWD
    Absolute → as-is
    Must contain .git/ to count.
    """
    if raw.startswith("/"):
        resolved = Path(raw)
    elif "/" in raw:
        try:
            resolved = Path(raw).resolve(strict=True)
        except (OSError, FileNotFoundError):
            return None
    else:
        resolved = repo_root / raw
    if not (resolved / ".git").is_dir():
        return None
    return resolved.resolve()


# ---------------------------------------------------------------------------
# Target expansion for batch repo commands: take a list of user-provided folder args
# and flatten into a deduped list of git-repo paths.
#
# Per arg:
#   - absolute path → used as-is
#   - path with a slash → resolved against $PWD
#   - bare name → $PWD/<name>
# If the resulting folder has .git, it's treated as a single repo. Otherwise
# its immediate subfolders are scanned and each one with .git is included.
# Empty input → default to [$PWD].
# ---------------------------------------------------------------------------
def target_label(path: Path) -> str:
    if path.parent.name == EXTERNAL_DIR:
        return f"{EXTERNAL_DIR}/{path.name}"
    return path.name


def target_kind(path: Path) -> str:
    return "external" if path.parent.name == EXTERNAL_DIR else "regular"


def expand_targets(folders: list, include_default_external: bool = False) -> list:
    if not folders:
        cwd = Path.cwd()
        folders = [str(cwd)]
        external_dir = cwd / EXTERNAL_DIR
        if include_default_external and not (cwd / ".git").exists() and external_dir.is_dir():
            folders.append(str(external_dir))

    repos: list = []
    seen: set = set()

    for raw in folders:
        p = Path(raw)
        if not p.is_absolute():
            p = Path.cwd() / p
        p = p.resolve()

        if not p.is_dir():
            die(f"not a directory: {raw}")

        if (p / ".git").exists():
            candidates = [p]
        else:
            candidates = sorted(
                s for s in p.iterdir() if s.is_dir() and (s / ".git").exists()
            )

        for c in candidates:
            key = str(c)
            if key not in seen:
                seen.add(key)
                repos.append(c)

    return repos


# ---------------------------------------------------------------------------
# Default-mode context detection:
#   PWD has workspace.yml → PWD is the workspace dir; root is grandparent.
#   PWD's basename is local_workspaces → root is its parent.
#   Otherwise → PWD is the root; workspace goes to PWD/local_workspaces/<name>/.
# ---------------------------------------------------------------------------
def resolve_default_context(pwd: Path, name_flag: str):
    yml = pwd / "workspace.yml"
    if yml.is_file():
        data = read_manifest(yml)
        name_from_yml = data["name"] or ""
        if name_flag and name_flag != name_from_yml:
            die(f"--name '{name_flag}' does not match workspace.yml name '{name_from_yml}'")
        return pwd, pwd.parent.parent, name_from_yml

    if not name_flag:
        die("--name required (or run from inside a workspace dir)")

    if Path(name_flag).is_absolute() or "/" in name_flag:
        workspace_dir = Path(name_flag)
        if not workspace_dir.is_absolute():
            workspace_dir = pwd / workspace_dir
        workspace_dir = workspace_dir.resolve()
        yml = workspace_dir / "workspace.yml"
        if not yml.is_file():
            die(f"--name path does not contain workspace.yml: {workspace_dir}")
        data = read_manifest(yml)
        return workspace_dir, workspace_dir.parent.parent, data["name"] or workspace_dir.name

    repo_root = pwd.parent if pwd.name == WS_CONTAINER else pwd
    workspace_folder = name_flag.replace("/", "_")
    return repo_root / WS_CONTAINER / workspace_folder, repo_root, name_flag


def resolve_existing_workspace_context(pwd: Path, name_flag: str) -> Path:
    if name_flag:
        workspace_dir, _, _ = resolve_default_context(pwd, name_flag)
        return workspace_dir

    cur = pwd.resolve()
    for candidate in (cur, *cur.parents):
        if (candidate / "workspace.yml").is_file():
            return candidate

    die("--name required (or run from inside a workspace dir/worktree)")


# ---------------------------------------------------------------------------
# pull mode: iterate every immediate subfolder of the target; for each one
# that's a git repo (source repo or worktree — `.git` can be a dir or a file),
# run `git pull` on the currently checked-out branch.
# ---------------------------------------------------------------------------
def cmd_pull(folders: list) -> int:
    repos = expand_targets(folders, include_default_external=True)

    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    external_total = sum(1 for repo in repos if target_kind(repo) == "external")
    if external_total:
        regular_total = len(repos) - external_total
        info(f"pulling {len(repos)} repo(s) in parallel ({regular_total} regular, {external_total} external)...")
    else:
        info(f"pulling {len(repos)} repo(s) in parallel...")

    def worker(sub: Path, log: RepoLog) -> str:
        label = target_label(sub)
        log.heading(label)
        proc = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
        branch = proc.stdout.strip() if proc.returncode == 0 else ""
        if not branch:
            log.warn("could not determine current branch, skipping")
            return "skipped"
        if branch == "HEAD":
            log.warn("detached HEAD, skipping")
            return "skipped"
        log.info(f"pull latest data from {BOLD}{branch}{RESET}")
        proc = run(["git", "-C", str(sub), "pull", "--ff-only"])
        log.raw((proc.stdout or "").rstrip())
        log.raw((proc.stderr or "").rstrip())
        if proc.returncode == 0:
            log.ok(f"updated {label}")
            return "pulled"
        log.fail(f"pull failed for {label}")
        return "failed"

    results = run_in_parallel(repos, worker)
    pulled = sum(1 for r in results if r == "pulled")
    skipped = sum(1 for r in results if r == "skipped")
    failed_repos = [target_label(repos[i]) for i, r in enumerate(results) if r == "failed"]
    failed = len(failed_repos)

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"pulled: {color}{pulled}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    if external_total:
        external_pulled = sum(1 for i, r in enumerate(results) if r == "pulled" and target_kind(repos[i]) == "external")
        external_skipped = sum(1 for i, r in enumerate(results) if r == "skipped" and target_kind(repos[i]) == "external")
        external_failed = sum(1 for i, r in enumerate(results) if r == "failed" and target_kind(repos[i]) == "external")
        info(f"external: pulled {external_pulled}, skipped: {external_skipped}, failed: {external_failed}")
    if failed_repos:
        info(f"failed: {RED}{', '.join(failed_repos)}{RESET}")
    return 0 if failed == 0 else 1


# Shared base-merge helper used by `mkws sync`.
#
# Flow:
#   1. Resolve base (configured base_branch, otherwise main/master) and current
#      branch. Skip repos on base, detached, or without a base branch.
#   2. If working tree is dirty, `git stash push -u` (untracked included).
#   3. Fetch origin/<base> when using a remote base.
#   4. `git merge --no-edit <base-ref>`
#        - clean merge   → pop stash, return "merged"
#        - conflict      → leave the merge + stash in place, print resolve
#                          instructions, return "conflict"
#        - other failure → `git merge --abort`, pop stash, return "failed"
#
# Returns one of:
#   "merged"   — merge succeeded
#   "already"  — already on base, nothing to do (informational; not a failure)
#   "skipped"  — no base branch or detached HEAD
#   "failed"   — non-conflict failure; state restored; caller should halt
#   "conflict" — merge conflict; state left in place; caller MUST halt
# ---------------------------------------------------------------------------
def _sync_base_merge_one(sub: Path, base_branch: str = "") -> str:
    base = resolve_base(sub, base_branch)
    if base is None:
        if base_branch:
            warn(f"base_branch '{base_branch}' not found, skipping base merge")
        else:
            warn("no main/master branch, skipping base merge")
        return "skipped"

    cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
    cur_branch = cur.stdout.strip() if cur.returncode == 0 else ""
    if not cur_branch or cur_branch == "HEAD":
        warn("detached HEAD, skipping base merge")
        return "skipped"
    if cur_branch == base:
        info(f"already on {base}, skipping base merge")
        return "already"

    stashed = False
    status = run(["git", "-C", str(sub), "status", "--porcelain"])
    if status.stdout.strip():
        info("git stash push -u (autosaving local changes)")
        sp = run(["git", "-C", str(sub), "stash", "push", "-u", "-m", "mkws sync autostash"])
        if sp.returncode != 0:
            fail("stash failed")
            return "failed"
        stashed = True

    def pop_stash():
        if not stashed:
            return
        info("git stash pop")
        pp = run(["git", "-C", str(sub), "stash", "pop"])
        if pp.returncode != 0:
            warn("stash pop had conflicts — resolve manually")

    merge_ref = base_ref(sub, base, explicit_base=bool(base_branch))
    if not fetch_base_if_remote(sub, base, merge_ref):
        fail("fetch failed")
        pop_stash()
        return "failed"

    info(f"git merge {merge_ref} (into {cur_branch})")
    mp = run(["git", "-C", str(sub), "merge", "--no-edit", merge_ref], capture=False)
    if mp.returncode == 0:
        ok(f"merged {merge_ref} into {cur_branch}")
        pop_stash()
        return "merged"

    unmerged = run(["git", "-C", str(sub), "ls-files", "--unmerged"])
    if unmerged.stdout.strip():
        heading(f"CONFLICT in {sub.name}")
        warn(f"merge conflict — resolve manually in {sub}")
        info("  1. fix conflicted files")
        info("  2. git add <files> && git commit")
        if stashed:
            info(f"  3. {BOLD}git stash pop{RESET} (your pre-sync changes are in the stash)")
        return "conflict"

    fail("merge failed (non-conflict)")
    run(["git", "-C", str(sub), "merge", "--abort"])
    pop_stash()
    return "failed"


# ---------------------------------------------------------------------------
# merge — Case B per-repo: bring base INTO the feature branch
# in a workspace worktree. Like the sync base-merge helper but with two extras:
#   1. Pulls origin/<feature> first if a remote-tracking branch exists.
#   2. Pushes the feature branch after a clean merge.
# Returns the same status strings as the sync base-merge helper.
# ---------------------------------------------------------------------------
def _merge_base_to_feature_one(sub: Path, requested_base: str, base_branch: str = "") -> str:
    base = resolve_base(sub, base_branch)
    if base is None:
        if base_branch:
            warn(f"base_branch '{base_branch}' not found, skipping")
        else:
            warn("no main/master branch, skipping")
        return "skipped"
    if not base_branch and requested_base not in (base, "master", "main"):
        warn(f"requested base '{requested_base}' is not the repo's base ('{base}'), skipping")
        return "skipped"

    cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
    cur_branch = cur.stdout.strip() if cur.returncode == 0 else ""
    if not cur_branch or cur_branch == "HEAD":
        warn("detached HEAD, skipping")
        return "skipped"
    if cur_branch == base:
        info(f"already on {base}, skipping")
        return "already"

    stashed = False
    status = run(["git", "-C", str(sub), "status", "--porcelain"])
    if status.stdout.strip():
        info("git stash push -u (autosaving local changes)")
        sp = run(["git", "-C", str(sub), "stash", "push", "-u", "-m", "mkws merge autostash"])
        if sp.returncode != 0:
            fail("stash failed")
            return "failed"
        stashed = True

    def pop_stash():
        if not stashed:
            return
        info("git stash pop")
        pp = run(["git", "-C", str(sub), "stash", "pop"])
        if pp.returncode != 0:
            warn("stash pop had conflicts — resolve manually")

    merge_ref = base_ref(sub, base, explicit_base=bool(base_branch))
    if not fetch_base_if_remote(sub, base, merge_ref):
        fail("fetch failed")
        pop_stash()
        return "failed"

    # Pull origin/<feature> if remote tracking exists; otherwise skip silently.
    if has_ref(sub, f"refs/remotes/origin/{cur_branch}"):
        info(f"git pull --ff-only origin {cur_branch}")
        pl = run(["git", "-C", str(sub), "pull", "--ff-only", "origin", cur_branch], capture=False)
        if pl.returncode != 0:
            fail("pull of feature branch failed (non-ff or other)")
            pop_stash()
            return "failed"

    info(f"git merge --no-ff {merge_ref} (into {cur_branch})")
    mp = run(["git", "-C", str(sub), "merge", "--no-ff", "--no-edit", merge_ref], capture=False)
    if mp.returncode == 0:
        ok(f"merged {merge_ref} into {cur_branch}")
        pop_stash()
        info(f"git push origin {cur_branch}")
        pp = run(["git", "-C", str(sub), "push", "origin", cur_branch], capture=False)
        if pp.returncode != 0:
            fail("push failed (non-ff or auth) — local merge is intact, push manually")
            return "failed"
        ok(f"pushed {cur_branch}")
        return "rebased"

    unmerged = run(["git", "-C", str(sub), "ls-files", "--unmerged"])
    if unmerged.stdout.strip():
        heading(f"CONFLICT in {sub.name}")
        warn(f"merge conflict — resolve manually in {sub}")
        info("  1. fix conflicted files")
        info("  2. git add <files> && git commit")
        if stashed:
            info(f"  3. {BOLD}git stash pop{RESET} (your pre-merge changes are in the stash)")
        info(f"  4. {BOLD}git push origin {cur_branch}{RESET} (push when ready)")
        return "conflict"

    fail("merge failed (non-conflict)")
    run(["git", "-C", str(sub), "merge", "--abort"])
    pop_stash()
    return "failed"


# ---------------------------------------------------------------------------
# merge — Case A per-repo: bring the feature branch INTO base
# in the SOURCE repo (sibling of local_workspaces/, not the worktree). No push.
# ---------------------------------------------------------------------------
def _merge_feature_to_base_one(source_repo: Path, feature_branch: str, base_branch: str = "") -> str:
    if not (source_repo / ".git").is_dir():
        warn(f"not a source repo (no .git dir): {source_repo}")
        return "skipped"

    base = resolve_base(source_repo, base_branch)
    if base is None:
        if base_branch:
            warn(f"base_branch '{base_branch}' not found, skipping")
        else:
            warn("no main/master branch, skipping")
        return "skipped"

    cur = run(["git", "-C", str(source_repo), "rev-parse", "--abbrev-ref", "HEAD"])
    cur_branch = cur.stdout.strip() if cur.returncode == 0 else ""
    if cur_branch != base:
        warn(f"source repo is on '{cur_branch}', not '{base}' — switch to {base} first, skipping")
        return "skipped"

    status = run(["git", "-C", str(source_repo), "status", "--porcelain"])
    if status.stdout.strip():
        fail(f"source repo has uncommitted changes — clean up before merge")
        return "failed"

    if has_remote_branch(source_repo, base):
        info(f"git pull --ff-only origin {base}")
        pl = run(["git", "-C", str(source_repo), "pull", "--ff-only", "origin", base], capture=False)
        if pl.returncode != 0:
            fail("pull of base failed (non-ff or other)")
            return "failed"
    else:
        info(f"using local base branch {base}")

    if not has_ref(source_repo, f"refs/heads/{feature_branch}"):
        warn(f"feature branch '{feature_branch}' not found in this repo, skipping")
        return "skipped"

    info(f"git merge --no-ff {feature_branch} (into {base})")
    mp = run(["git", "-C", str(source_repo), "merge", "--no-ff", "--no-edit", feature_branch], capture=False)
    if mp.returncode == 0:
        ok(f"merged {feature_branch} into {base} (NOT pushed — run `git push origin {base}` when ready)")
        return "rebased"

    unmerged = run(["git", "-C", str(source_repo), "ls-files", "--unmerged"])
    if unmerged.stdout.strip():
        heading(f"CONFLICT in {source_repo.name}")
        warn(f"merge conflict — resolve manually in {source_repo}")
        info("  1. fix conflicted files")
        info("  2. git add <files> && git commit")
        info(f"  3. git push origin {base} (when satisfied)")
        return "conflict"

    fail("merge failed (non-conflict)")
    run(["git", "-C", str(source_repo), "merge", "--abort"])
    return "failed"


# ---------------------------------------------------------------------------
# merge mode: bidirectional based on <target>.
#   - target == "master" or "main" → Case B: pull base, pull feature, merge
#     base INTO feature, push feature. Must run from inside a workspace.
#   - target == <workspace-name>   → Case A: in each source sibling repo on
#     its configured base or default base, pull base, merge feature INTO base.
#     NO push.
# Both serial; halt on conflict.
# ---------------------------------------------------------------------------
def cmd_merge(target: str, folders: list) -> int:
    if not target:
        die("'merge' requires a target: `mkws merge master|main` (Case B) or `mkws merge <workspace-name>` (Case A)")

    pwd = Path.cwd()
    case_b = target in ("master", "main")

    if case_b:
        # Case B: merge base into feature-branch worktree(s).
        # Allowed cwd contexts:
        #   1. workspace dir (has workspace.yml)         → all worktrees in manifest
        #   2. a worktree inside a workspace             → just that one worktree
        if (pwd / "workspace.yml").is_file():
            workspace_dir = pwd
        elif (pwd / ".git").exists() and (pwd.parent / "workspace.yml").is_file():
            workspace_dir = pwd.parent
            if not folders:
                folders = [str(pwd)]
        else:
            die("`mkws merge master|main` must be run from inside a workspace dir or one of its worktrees")

        repos = expand_targets(folders) if folders else expand_targets([str(workspace_dir)])
        if not repos:
            heading("summary")
            info("no git repos found")
            return 0

        info(f"merging base into {len(repos)} feature-branch worktree(s) (serial)...")
        rebased = skipped = failed = 0
        for sub in repos:
            heading(sub.name)
            status = _merge_base_to_feature_one(
                sub,
                target,
                workspace_base_branch_for_repo(sub),
            )
            if status == "rebased":
                rebased += 1
            elif status in ("already", "skipped"):
                skipped += 1
            elif status == "failed":
                failed += 1
                heading("summary")
                info(f"merged: {rebased}, skipped: {skipped}, failed: 1")
                info(f"halted at: {BOLD}{sub.name}{RESET}")
                return 1
            elif status == "conflict":
                info("")
                info("halted; other repos not processed")
                heading("summary")
                info(f"merged: {rebased}, skipped: {skipped}, conflict: 1")
                info(f"halted at: {BOLD}{sub.name}{RESET}")
                return 1

        heading("summary")
        color = GREEN if failed == 0 else YELLOW
        info(f"merged: {color}{rebased}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
        return 0 if failed == 0 else 1

    # Case A: target is a workspace name. Find <root>/local_workspaces/<target>/workspace.yml.
    # Allowed cwd contexts: root, local_workspaces/, a workspace dir, OR a source repo
    # (sibling of local_workspaces/) — the last one auto-scopes to that one repo.
    candidates = [
        pwd / "local_workspaces" / target / "workspace.yml",                  # cwd is root
        pwd.parent / "local_workspaces" / target / "workspace.yml",           # cwd is a source repo (sibling of local_workspaces/)
        pwd.parent / target / "workspace.yml",                                # cwd is local_workspaces/
        pwd.parent.parent / "local_workspaces" / target / "workspace.yml",    # cwd is a workspace
    ]
    yml = next((c for c in candidates if c.is_file()), None)
    if yml is None:
        die(f"workspace '{target}' not found (looked under local_workspaces/ from cwd, parent, grandparent)")

    workspace_dir = yml.parent
    repo_root = workspace_dir.parent.parent
    data = read_manifest(yml)

    repo_names_list = repo_names(data["repos"])
    # Auto-scope to the current dir if it's a source repo in the manifest.
    if (pwd / ".git").is_dir() and pwd.parent == repo_root and pwd.name in repo_names_list:
        if folders:
            wanted = {Path(f).name for f in folders}
            if pwd.name not in wanted:
                die(f"current dir '{pwd.name}' is not in the requested folder scope")
        repo_names_list = [pwd.name]
    elif folders:
        wanted = {Path(f).name for f in folders}
        repo_names_list = [r for r in repo_names_list if r in wanted]
    if not repo_names_list:
        heading("summary")
        info("no repos to merge")
        return 0

    info(f"merging workspace feature branches INTO base across {len(repo_names_list)} source repo(s) (serial, no push)...")
    rebased = skipped = failed = 0
    for r in repo_names_list:
        source_repo = repo_root / r
        feature_branch = repo_branch(data["repos"], r, data["branch_name"])
        if not feature_branch:
            warn(f"{r}: no branch_name in workspace.yml, skipping")
            skipped += 1
            continue
        heading(r)
        status = _merge_feature_to_base_one(
            source_repo,
            feature_branch,
            repo_base_branch(data["repos"], r),
        )
        if status == "rebased":
            rebased += 1
        elif status in ("already", "skipped"):
            skipped += 1
        elif status == "failed":
            failed += 1
            heading("summary")
            info(f"merged: {rebased}, skipped: {skipped}, failed: 1")
            info(f"halted at: {BOLD}{r}{RESET}")
            return 1
        elif status == "conflict":
            info("")
            info("halted; other repos not processed")
            heading("summary")
            info(f"merged: {rebased}, skipped: {skipped}, conflict: 1")
            info(f"halted at: {BOLD}{r}{RESET}")
            return 1

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"merged: {color}{rebased}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    info("NOT pushed — review the merge commits, then run `git push origin <base>` per repo")
    return 0 if failed == 0 else 1


# push mode: `git push origin HEAD` for every matching repo, in parallel.
# Detached HEAD is skipped. Non-ff / auth failures are reported as failures
# but don't halt — user can inspect the list and retry individually.
# ---------------------------------------------------------------------------
def cmd_push(folders: list) -> int:
    repos = expand_targets(folders)
    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    info(f"pushing {len(repos)} repo(s) in parallel...")

    def worker(sub: Path, log: RepoLog) -> str:
        log.heading(sub.name)
        cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
        branch = cur.stdout.strip() if cur.returncode == 0 else ""
        if not branch or branch == "HEAD":
            log.warn("detached HEAD, skipping")
            return "skipped"
        log.info(f"git push origin HEAD ({BOLD}{branch}{RESET})")
        proc = run(["git", "-C", str(sub), "push", "origin", "HEAD"])
        log.raw((proc.stdout or "").rstrip())
        log.raw((proc.stderr or "").rstrip())
        if proc.returncode == 0:
            log.ok(f"pushed {branch}")
            return "pushed"
        log.fail(f"push failed for {sub.name}")
        return "failed"

    results = run_in_parallel(repos, worker)
    pushed = sum(1 for r in results if r == "pushed")
    skipped = sum(1 for r in results if r == "skipped")
    failed_repos = [repos[i].name for i, r in enumerate(results) if r == "failed"]
    failed = len(failed_repos)

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"pushed: {color}{pushed}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    if failed_repos:
        info(f"failed: {RED}{', '.join(failed_repos)}{RESET}")
    return 0 if failed == 0 else 1


# ---------------------------------------------------------------------------
# sync mode: pull -> merge base, per repo, serial. With --push, also push the
# current branch after the base merge. Pull/push failures are recorded but the
# command continues to the next repo; only the base merge halts the batch.
#
# Why serial: a conflict during the base merge needs the user's attention. Parallel
# pulls + parallel pushes would also work but would obscure which repo
# halted.
# ---------------------------------------------------------------------------
def cmd_sync(folders: list, push: bool = False) -> int:
    repos = expand_targets(folders)
    if not repos:
        heading("summary")
        info("no git repos found")
        return 0

    flow = "pull -> base merge -> push" if push else "pull -> base merge"
    info(f"syncing {len(repos)} repo(s) - {flow} (serial)...")
    synced = skipped = 0
    pull_fails: list = []
    push_fails: list = []
    rebase_fails: list = []

    for sub in repos:
        heading(sub.name)
        base_branch = workspace_base_branch_for_repo(sub)

        cur = run(["git", "-C", str(sub), "rev-parse", "--abbrev-ref", "HEAD"])
        cur_branch = cur.stdout.strip() if cur.returncode == 0 else ""
        if not cur_branch or cur_branch == "HEAD":
            warn("detached HEAD, skipping repo")
            skipped += 1
            continue

        # 1. pull current branch (explicit `origin <branch>` — not `HEAD`, which
        #    on the remote side resolves to the default branch, not the same-
        #    named one). If `origin/<branch>` doesn't exist yet (brand-new
        #    local branch), that's not a failure — we just skip straight to
        #    the base-merge+push steps so the first push creates the remote ref.
        has_remote = run(
            ["git", "-C", str(sub), "ls-remote", "--exit-code",
             "--heads", "origin", cur_branch]
        ).returncode == 0
        if not has_remote:
            info(f"no origin/{cur_branch} yet — skipping pull (will be created on push)")
        else:
            info(f"git pull --ff-only origin {BOLD}{cur_branch}{RESET}")
            pp = run(
                ["git", "-C", str(sub), "pull", "--ff-only", "origin", cur_branch],
                capture=False,
            )
            if pp.returncode != 0:
                fail("pull failed — skipping base-merge/push for this repo")
                pull_fails.append(sub.name)
                continue

        # 2. merge base (unless already on base)
        status = _sync_base_merge_one(sub, base_branch)
        if status == "conflict":
            info("")
            info("halted; remaining repos not processed")
            heading("summary")
            info(f"synced: {synced}, skipped: {skipped}, halted at: {BOLD}{sub.name}{RESET} (base-merge conflict)")
            if pull_fails:
                info(f"pull failed before halt: {RED}{', '.join(pull_fails)}{RESET}")
            return 1
        if status == "failed":
            rebase_fails.append(sub.name)
            heading("summary")
            info(f"synced: {synced}, skipped: {skipped}, halted at: {BOLD}{sub.name}{RESET} (base merge failed)")
            return 1

        # 3. Optional push, but not when the current branch is the base branch.
        if status == "already":
            info(f"on {BOLD}{cur_branch}{RESET}, skipping push")
            ok(f"synced {cur_branch} (pull only)")
            synced += 1
            continue

        if not push:
            ok(f"synced {cur_branch} (local only)")
            synced += 1
            continue

        info(f"git push origin HEAD")
        pushp = run(["git", "-C", str(sub), "push", "origin", "HEAD"], capture=False)
        if pushp.returncode != 0:
            fail("push failed")
            push_fails.append(sub.name)
            continue
        ok(f"synced {cur_branch}")
        synced += 1

    heading("summary")
    total_fail = len(pull_fails) + len(push_fails) + len(rebase_fails)
    color = GREEN if total_fail == 0 else YELLOW
    info(f"synced: {color}{synced}{RESET}, skipped: {skipped}, failed: {color}{total_fail}{RESET}")
    if pull_fails:
        info(f"pull failed: {RED}{', '.join(pull_fails)}{RESET}")
    if push_fails:
        info(f"push failed: {RED}{', '.join(push_fails)}{RESET}")
    return 0 if total_fail == 0 else 1


# ---------------------------------------------------------------------------
# clean workspace mode: remove every code worktree listed in the manifest and prune the
# source repos, but keep the workspace folder and workspace-level files. The
# manifest is reset to an empty branch/repo list so docs and other workspace
# artifacts remain available for future reuse.
# ---------------------------------------------------------------------------
def cmd_clean_workspace(folder: str = "") -> int:
    path = Path(folder) if folder else Path.cwd()
    if not path.is_absolute():
        path = Path.cwd() / path
    if not path.is_dir():
        die(f"not a directory: {folder}")
    workspace_dir = path.resolve()
    yml = workspace_dir / "workspace.yml"
    if not yml.is_file():
        die(f"no workspace.yml at {workspace_dir} (not a workspace)")

    data = read_manifest(yml)
    repos = repo_names(data["repos"])
    repo_root = workspace_dir.parent.parent

    # Collect unique source repos so we can prune each one once at the end,
    # regardless of whether its worktree needed rm -rf fallback.
    sources: list = []
    seen: set = set()

    for leaf in repos:
        heading(f"clean {leaf}")
        source_path = repo_root / leaf
        worktree_path = workspace_dir / leaf
        source_is_git = (source_path / ".git").is_dir()

        if source_is_git and source_path not in seen:
            sources.append(source_path)
            seen.add(source_path)

        if not worktree_path.exists():
            info(f"worktree already gone at {worktree_path}")
            continue

        removed_via_git = False
        if source_is_git:
            proc = run(
                ["git", "-C", str(source_path), "worktree", "remove",
                 "--force", str(worktree_path)]
            )
            if proc.returncode == 0:
                ok(f"removed worktree at {worktree_path}")
                removed_via_git = True
            else:
                warn("git worktree remove failed, falling back to rm -rf")
        else:
            warn(f"source repo {source_path} not found, removing directly")

        if not removed_via_git:
            try:
                shutil.rmtree(worktree_path)
                ok(f"removed directory {worktree_path}")
            except OSError as e:
                fail(f"failed to remove {worktree_path}: {e}")

    if sources:
        heading("prune source repos")
        for src in sources:
            proc = run(["git", "-C", str(src), "worktree", "prune"])
            if proc.returncode == 0:
                ok(f"pruned {src}")
            else:
                warn(f"prune failed for {src}")

    heading("cleanup")
    write_manifest(yml, name=data["name"] or workspace_dir.name, branch="", repos=[], links=data["links"])
    ok(f"reset manifest at {yml}")
    ok(f"kept workspace dir {workspace_dir}")

    heading("summary")
    info(f"workspace: {BOLD}{workspace_dir}{RESET} (kept)")
    info(f"code repos cleaned: {len(repos)}")
    return 0


def cmd_clean(folder: str = "") -> int:
    if folder:
        path = Path(folder)
        if not path.is_absolute():
            path = Path.cwd() / path
        target = path.resolve()
        if (target / "workspace.yml").is_file():
            return cmd_clean_workspace(str(target))
        die(f"no workspace.yml at {target}; use `mkwst clean` for workstation.yml")

    pwd = Path.cwd().resolve()
    if (pwd / "workspace.yml").is_file():
        return cmd_clean_workspace(str(pwd))
    die(f"no workspace.yml at {pwd}; use `mkwst clean` for workstation.yml")


def cmd_migrate(folder: str) -> int:
    path = Path(folder) if folder else Path.cwd()
    if not path.is_absolute():
        path = Path.cwd() / path
    workspace_dir = path.resolve()
    yml = workspace_dir / "workspace.yml"
    if not yml.is_file():
        die(f"no workspace.yml at {workspace_dir} (not a workspace)")

    data = read_manifest(yml)
    repos = normalize_repos(data["repos"], data["branch_name"])
    write_manifest(
        yml,
        name=data["name"] or workspace_dir.name,
        branch=data["branch_name"],
        repos=repos,
        links=data["links"],
    )

    heading("migrate")
    ok(f"wrote v2 manifest at {yml}")
    info(f"repos: {len(repos)}")
    return 0


def cmd_link(name_flag: str, link_pairs: list) -> int:
    workspace_dir = resolve_existing_workspace_context(Path.cwd(), name_flag)
    yml = workspace_dir / "workspace.yml"
    if not yml.is_file():
        die(f"no workspace.yml at {workspace_dir} (not a workspace)")

    heading("link")
    for link_name, link_url in link_pairs:
        status = upsert_link(yml, link_name, link_url)
        ok(f"{status} {BOLD}{link_name}{RESET} -> {link_url}")
    return 0


def open_url(url: str) -> int:
    if sys.platform == "darwin":
        opener = "open"
    elif has_cmd("xdg-open"):
        opener = "xdg-open"
    else:
        die("no default browser opener found (`open` or `xdg-open`)")
    return run([opener, url], capture=False).returncode


def cmd_open(name_flag: str, query_parts: list) -> int:
    workspace_dir = resolve_existing_workspace_context(Path.cwd(), name_flag)
    yml = workspace_dir / "workspace.yml"
    if not yml.is_file():
        die(f"no workspace.yml at {workspace_dir} (not a workspace)")

    data = read_manifest(yml)
    links = normalize_links(data.get("links", []))
    query = " ".join(query_parts).strip()

    if not links:
        heading("links")
        info("no links recorded")
        return 0

    if not query:
        heading("links")
        for item in links:
            info(f"{BOLD}{item['name']}{RESET} -> {item['link']}")
        return 0

    exact = [item for item in links if item["name"] == query or item["link"] == query]
    matches = exact
    if not matches:
        q = query.lower()
        matches = [
            item for item in links
            if q in item["name"].lower() or q in item["link"].lower()
        ]

    if not matches:
        die(f"no link matched: {query}")
    if len(matches) > 1:
        heading("matches")
        for item in matches:
            info(f"{BOLD}{item['name']}{RESET} -> {item['link']}")
        die(f"multiple links matched: {query}")

    item = matches[0]
    heading("open")
    info(f"{item['name']} -> {item['link']}")
    rc = open_url(item["link"])
    if rc == 0:
        ok("opened in default browser")
    else:
        fail("browser open failed")
    return rc


# ---------------------------------------------------------------------------
# sync_tech_doc mode: mirror every workspace tech_doc folder into the root
# tech_doc index using symlinks:
#   <root>/tech_doc/<workspace-name>/tech_doc -> <root>/local_workspaces/<workspace-name>/tech_doc
# Stale generated symlinks are removed. Real files/dirs are never deleted.
# ---------------------------------------------------------------------------
def resolve_workspace_root(pwd: Path) -> Path:
    if (pwd / "workspace.yml").is_file():
        return pwd.parent.parent
    if pwd.name == WS_CONTAINER:
        return pwd.parent
    return pwd


def cmd_sync_tech_doc() -> int:
    root = resolve_workspace_root(Path.cwd()).resolve()
    workspaces_dir = root / WS_CONTAINER
    index_dir = root / "tech_doc"

    if not workspaces_dir.is_dir():
        die(f"no {WS_CONTAINER}/ directory at {root}")

    index_dir.mkdir(parents=True, exist_ok=True)

    desired: dict = {}
    for workspace_dir in sorted(p for p in workspaces_dir.iterdir() if p.is_dir()):
        yml = workspace_dir / "workspace.yml"
        if not yml.is_file():
            continue
        tech_doc = workspace_dir / "tech_doc"
        if tech_doc.is_dir():
            data = read_manifest(yml)
            name = data["name"] or workspace_dir.name
            desired[name] = tech_doc.resolve()

    created = updated = removed = skipped = 0

    heading("link tech docs")
    for name, target in desired.items():
        link_parent = index_dir / name
        link_path = link_parent / "tech_doc"
        link_parent.mkdir(parents=True, exist_ok=True)

        if link_path.is_symlink():
            current = link_path.resolve()
            if current == target:
                info(f"{name}: already linked")
                skipped += 1
                continue
            link_path.unlink()
            link_path.symlink_to(target, target_is_directory=True)
            ok(f"{name}: updated -> {target}")
            updated += 1
            continue

        if link_path.exists():
            warn(f"{name}: {link_path} exists and is not a symlink, skipping")
            skipped += 1
            continue

        link_path.symlink_to(target, target_is_directory=True)
        ok(f"{name}: created -> {target}")
        created += 1

    heading("remove stale links")
    for entry in sorted(p for p in index_dir.iterdir() if p.is_dir()):
        link_path = entry / "tech_doc"
        if entry.name in desired:
            continue
        if not link_path.is_symlink():
            continue
        link_path.unlink()
        removed += 1
        ok(f"{entry.name}: removed stale link")
        try:
            entry.rmdir()
        except OSError:
            pass

    heading("summary")
    info(f"root:    {BOLD}{root}{RESET}")
    info(f"index:   {BOLD}{index_dir}{RESET}")
    info(f"created: {created}, updated: {updated}, removed: {removed}, skipped: {skipped}")
    return 0


def resolve_skill_sync_context(pwd: Path):
    pwd = pwd.resolve()
    if (pwd / "workspace.yml").is_file():
        return pwd, None

    repo_dir = git_top_level(pwd)
    if repo_dir and (repo_dir.parent / "workspace.yml").is_file():
        return repo_dir.parent, repo_dir

    die("`mkws skill-sync` must be run from a workspace dir or a repo inside one")


def workspace_skill_dirs(workspace_dir: Path) -> list:
    source_dir = workspace_dir / "skills"
    if not source_dir.is_dir():
        die(f"no skills/ directory at {workspace_dir}")
    return sorted(
        p for p in source_dir.iterdir()
        if p.is_dir() and (p / "SKILL.md").is_file()
    )


def skill_sync_targets(workspace_dir: Path, scoped_repo):
    if scoped_repo is not None:
        return [scoped_repo]

    data = read_manifest(workspace_dir / "workspace.yml")
    targets = []
    seen = set()
    for repo in normalize_repos(data["repos"], data["branch_name"]):
        target = (workspace_dir / repo["name"]).resolve()
        if target in seen:
            continue
        seen.add(target)
        targets.append(target)
    return targets


def replace_skill_dir(src: Path, dst: Path) -> None:
    if dst.is_symlink() or dst.is_file():
        dst.unlink()
    elif dst.exists():
        shutil.rmtree(dst)
    shutil.copytree(
        src,
        dst,
        ignore=shutil.ignore_patterns(".git", ".DS_Store", "__pycache__"),
    )


def cmd_skill_sync() -> int:
    workspace_dir, scoped_repo = resolve_skill_sync_context(Path.cwd())
    skills = workspace_skill_dirs(workspace_dir)
    targets = skill_sync_targets(workspace_dir, scoped_repo)

    heading("skill-sync")
    info(f"workspace: {BOLD}{workspace_dir}{RESET}")
    info(f"source:    {BOLD}{workspace_dir / 'skills'}{RESET}")
    info(f"skills:    {len(skills)}")
    info(f"targets:   {len(targets)}")

    copied = skipped = failed = 0
    for repo in targets:
        heading(repo.name)
        if not repo.is_dir():
            warn(f"missing repo path: {repo}")
            failed += 1
            continue
        if not is_git_worktree(repo):
            warn(f"not a git repo: {repo}")
            failed += 1
            continue
        if not skills:
            info("no skills with SKILL.md found")
            skipped += 1
            continue
        for agent, rel in AGENT_SKILL_TARGETS:
            target_root = repo / rel
            target_root.mkdir(parents=True, exist_ok=True)
            for skill in skills:
                replace_skill_dir(skill, target_root / skill.name)
                copied += 1
            ok(f"{agent}: {len(skills)} skill(s)")

    heading("summary")
    info(f"copied: {copied}, skipped: {skipped}, failed: {failed}")
    return 1 if failed else 0


# ---------------------------------------------------------------------------
# default mode: create or extend a workspace, optionally --add repos.
# ---------------------------------------------------------------------------
def cmd_default(name_flag: str, branch_flag: str, repos_arg: list) -> int:
    pwd = Path.cwd()
    workspace_dir, repo_root, name = resolve_default_context(pwd, name_flag)
    yml = workspace_dir / "workspace.yml"
    repo_specs = [parse_repo_spec(r) for r in repos_arg]
    specs_need_default_branch = any(not branch for _, branch in repo_specs)

    if yml.is_file():
        data = read_manifest(yml)
        existing = data["branch_name"]
        if existing:
            if branch_flag and branch_flag != existing:
                die(f"--branch '{branch_flag}' does not match workspace.yml branch '{existing}'")
            branch = existing
        else:
            # Branch is empty in yml — workspace was created empty (no --branch).
            if branch_flag:
                # User is filling in the branch now; persist it.
                write_manifest(yml, name=name, branch=branch_flag, repos=data["repos"], links=data["links"])
                branch = branch_flag
            else:
                branch = ""
    else:
        if not branch_flag and repos_arg and specs_need_default_branch:
            die("--branch required when adding repos without per-repo branches to a new workspace")
        workspace_dir.mkdir(parents=True, exist_ok=True)
        write_manifest(yml, name=name, branch=branch_flag or "", repos=[], links=[])
        branch = branch_flag or ""

    ensure_tech_doc_repo(workspace_dir)

    added = skipped = failed = 0

    for repo, repo_branch_override in repo_specs:
        heading(repo)
        repo_path = resolve_source(repo, repo_root)
        if repo_path is None:
            fail(f"not a git repo: {repo}")
            failed += 1
            continue

        leaf = repo_path.name
        if leaf != repo:
            info(f"source: {repo_path} (recorded as '{leaf}')")

        manifest_data = read_manifest(yml)
        existing_repo = repo_entry(manifest_data["repos"], leaf, manifest_data["branch_name"])
        if (
            existing_repo
            and repo_branch_override
            and existing_repo["branch_name"]
            and existing_repo["branch_name"] != repo_branch_override
        ):
            fail(
                f"{leaf} is recorded on branch '{existing_repo['branch_name']}', "
                f"not '{repo_branch_override}'"
            )
            failed += 1
            continue

        branch_for_repo = (
            (existing_repo or {}).get("branch_name")
            or repo_branch_override
            or branch
        )
        base_for_repo = (existing_repo or {}).get("base_branch", "")
        already_recorded = existing_repo is not None
        if not branch_for_repo:
            fail(f"no branch for {repo}; pass --branch <branch> or use {repo}@<branch>")
            failed += 1
            continue

        wt_path = workspace_dir / leaf
        if wt_path.exists():
            if already_recorded:
                info(f"'{leaf}' already in workspace, skipping")
            else:
                info("worktree path already exists, recording in yml")
                append_repo(yml, leaf, branch_for_repo, base_for_repo)
            skipped += 1
            continue

        info("fetching latest from origin")
        if run(["git", "-C", str(repo_path), "fetch", "--quiet", "origin"]).returncode != 0:
            warn("fetch failed, falling back to local refs")

        remote_branch = f"origin/{branch_for_repo}"
        remote_branch_exists = has_ref(repo_path, f"refs/remotes/{remote_branch}")

        if has_ref(repo_path, f"refs/heads/{branch_for_repo}"):
            proc = run(["git", "-C", str(repo_path), "worktree", "add", str(wt_path), branch_for_repo])
            if proc.returncode == 0:
                ok(f"checked out existing branch {branch_for_repo}")
                if remote_branch_exists:
                    up = run(
                        [
                            "git", "-C", str(wt_path), "branch",
                            "--set-upstream-to", remote_branch, branch_for_repo,
                        ]
                    )
                    if up.returncode == 0:
                        ok(f"tracking {remote_branch}")
                    else:
                        warn(f"failed to set upstream to {remote_branch}")
                if not already_recorded:
                    append_repo(yml, leaf, branch_for_repo, base_for_repo)
                added += 1
                continue
            fail("existing branch worktree add failed")
            failed += 1
            continue

        if remote_branch_exists:
            info(f"creating tracking branch {branch_for_repo} from {remote_branch}")
            proc = run(
                [
                    "git", "-C", str(repo_path), "worktree", "add",
                    "--track", "-b", branch_for_repo, str(wt_path), remote_branch,
                ],
                capture=False,
            )
            if proc.returncode == 0:
                ok(f"worktree added at {wt_path}")
                if not already_recorded:
                    append_repo(yml, leaf, branch_for_repo, base_for_repo)
                added += 1
                continue
            fail("tracking worktree add failed")
            failed += 1
            continue

        base = resolve_base(repo_path, base_for_repo)
        if base is None:
            if base_for_repo:
                fail(f"configured base_branch '{base_for_repo}' not found")
            else:
                fail("could not detect base branch (main/master)")
            failed += 1
            continue

        start_ref = base_ref(repo_path, base, explicit_base=bool(base_for_repo))
        info(f"creating new branch {branch_for_repo} from {start_ref}")
        proc = run(
            ["git", "-C", str(repo_path), "worktree", "add", "-b", branch_for_repo, str(wt_path), start_ref],
            capture=False,
        )
        if proc.returncode == 0:
            ok(f"worktree added at {wt_path}")
            if not already_recorded:
                append_repo(yml, leaf, branch_for_repo, base_for_repo)
            added += 1
        else:
            fail("worktree add failed")
            failed += 1

    heading("summary")
    info(f"workspace: {BOLD}{workspace_dir}{RESET}")
    info(f"default branch: {BOLD}{branch or '(unset — use repo@branch or pass --branch)'}{RESET}")
    color = GREEN if failed == 0 else YELLOW
    info(f"added: {color}{added}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    return 0


# ---------------------------------------------------------------------------
# Argument parsing. Manual, because --add is variadic (takes N bare args until
# the next --flag) and argparse makes that awkward.
# ---------------------------------------------------------------------------
USAGE = """\
Usage:
  mkws [--name <name>] [--branch <branch>] [--add <repo>...]
  mkws [--name <workspace>] --link <name> <link> [<name> <link>...]
  mkws pull [<folder>...]
  mkws push [<folder>...]
  mkws merge <target> [<folder>...]
  mkws sync [--push] [<folder>...]
  mkws clean [<workspace-folder>]
  mkws migrate [<workspace-folder>]
  mkws skill-sync
  mkws sync_tech_doc
  mkws open [<name-or-link>]

Modes:
  (default)  Create or extend a workspace. Run from the root folder that
             contains the source repos, or from inside a workspace dir.
  pull       `git pull --ff-only` on the currently checked-out branch of every
             matching repo. Takes any number of folder args (absolute, relative,
             or a bare name under $PWD). Each arg is either a git repo (pulled
             directly) or a directory whose immediate git-repo subfolders are
             pulled. No args → iterate $PWD's subfolders and immediate git
             repos under $PWD/_external when present.
             Examples:
               mkws pull                        # every repo under $PWD plus _external
               mkws pull repo-a                 # just one repo in $PWD
               mkws pull repo-a repo-b          # two repos
               mkws pull _external              # only external repos
               mkws pull ./local_workspaces/myws    # every worktree in a workspace
               mkws pull /abs/repo-a ./repo-b   # mix absolute and relative
  push       `git push origin HEAD` on the current branch of every matching
             repo. Parallel. Detached HEAD is skipped. Non-ff / auth failures
             are reported at the end; the batch does not halt.
             Examples:
               mkws push                     # push every repo under $PWD
               mkws push repo-a repo-b       # two specific repos
  merge      Bidirectional merge driven by <target>:
             • `mkws merge master` (or `main`) — Case B: for each worktree on
               a feature branch: use the configured per-repo base_branch when
               present, otherwise main/master; pull origin/<feature> if a
               remote exists, merge the base --no-ff into the feature branch,
               then push the feature branch. Halts on conflict.
             • `mkws merge <workspace-name>` — Case A: for each source sibling
               repo listed in the workspace's manifest: switch to the
               configured per-repo base_branch when present, otherwise
               main/master; pull --ff-only when the base exists on origin,
               then merge --no-ff <feature> into base. NO push — review and
               `git push origin <base>` yourself when satisfied. Workspace is
               kept for further work.
             Context-aware cwd:
               - In root or workspace dir → operates on all matching repos.
               - In a single git repo → auto-scopes to that one repo (the
                 source repo for Case A, the worktree for Case B).
             Folder args optional to further scope by repo name. Both cases
             serial; halt on conflict (state left in place to resolve).
             Examples:
               # inside workspace: integrate latest base into all worktrees
               cd local_workspaces/myws && mkws merge master
               # inside ONE worktree: integrate just that one
               cd local_workspaces/myws/repo-a && mkws merge master
               # at root: land feature branches into base locally across all repos
               mkws merge myws
               # inside ONE source repo: land just that one
               cd repo-a && mkws merge myws
  sync       Composite: for every matching repo, pull the current branch and
             merge its configured base_branch (or default main/master) into
             the current branch. With --push, push the current branch after
             the base merge. Serial. Merge conflicts halt the whole run.
             Pull/push failures for one repo don't halt; they're recorded and
             the run continues.
             Examples:
               mkws sync                     # pull+base-merge every repo
               mkws sync --push              # pull+base-merge+push every repo
               mkws sync repo-a              # just one repo, local only
  clean      Remove every code worktree listed in workspace.yml, prune the
             source repos, keep workspace-level files, and reset workspace.yml
             to an empty branch/repo list. DESTRUCTIVE for code worktrees —
             uncommitted work there is lost (runs `git worktree remove
             --force`). No confirmation prompt. Use `mkwst clean` for
             workstation.yml metadata cleanup.
             Examples:
               mkws clean                    # current workspace
               mkws clean ./local_workspaces/myws
  migrate    Rewrite an existing workspace.yml into the v2 manifest format.
             With no folder arg, migrates the current directory.
             Examples:
               mkws migrate
               mkws migrate ./local_workspaces/myws
  skill-sync Copy `<workspace>/skills/<skill>/` into project-local agent skill
             folders for workspace repos. Run from the workspace dir to sync
             every repo listed in workspace.yml, or from inside one workspace
             repo to sync only that repo.
             Targets:
               .agent/skills/
               .claude/skills/
               .cursor/skills/
             Example:
               mkws skill-sync
  sync_tech_doc
             Mirror workspace tech docs into one root index:
             `<root>/tech_doc/<workspace>/tech_doc` symlinks to
             `<root>/local_workspaces/<workspace>/tech_doc`.
             Creates links for new workspace tech docs and removes stale
             generated links when a workspace tech_doc disappears. Real files
             or directories are never deleted.
             Example:
               mkws sync_tech_doc
  open       Open a recorded workspace link in the default browser. With no
             query, lists the workspace links. Query can match the link name
             or URL exactly, or a unique substring.
             Examples:
               mkws open
               mkws open design-doc
               mkws open design-doc --name myws

Flags:
  --name <name>       workspace name. Required when creating a new workspace
                      or when invoked from the root. When invoked from inside
                      a workspace dir, read from workspace.yml. `/` in the
                      name becomes `_` in the folder.
  --branch <branch>   default branch name. Required when an added repo does
                      not specify its own branch. Optional on re-add; must
                      match workspace.yml if provided.
  --add <repo>...     one or more repos to add. Each entry can be:
                        - a bare name (looked up under the root)
                        - a relative path (resolved against $PWD, e.g. ../repo)
                        - an absolute path
                        - any of the above with @<branch> for a per-repo branch
                      Variadic: --add a b c  or  --add a --add b
  --link <name> <link>
                      add or update one or more quick-access workspace links.
                      Values are name/link pairs. Repeating --link is also
                      accepted. Run inside a workspace, or pass --name.
  --push              with `mkws sync`, push the current branch after local
                      pull+base-merge.
  -h, --help          show this message

Layout:
  All workspaces live inside `$PWD/local_workspaces/<name>/`.
  Each workspace has `tech_doc/` initialized as its own git repo for design
  milestone commits.

Environment:
  NO_COLOR      set to any value to disable colored output.
"""


def parse_args(argv):
    mode = "default"
    name = ""
    branch = ""
    repos: list = []
    link_pairs: list = []
    target_path = ""
    target_paths: list = []
    sync_push = False

    argv = list(argv)

    if argv and not argv[0].startswith("-"):
        sub = argv[0]
        if sub == "index":
            die("`mkws index` moved to `mkwst index`")
        elif sub == "setup":
            die("`mkws setup` moved to `mkwst setup`")
        elif sub == "pull":
            mode = "pull"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "push":
            mode = "push"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "sync":
            mode = "sync"
            argv.pop(0)
            while argv:
                if argv[0] == "--push":
                    sync_push = True
                    argv.pop(0)
                elif argv[0].startswith("-"):
                    break
                else:
                    target_paths.append(argv.pop(0))
        elif sub == "master":
            die("`mkws master` was removed; use direct git commands for destructive base resets")
        elif sub == "rebase":
            die("`mkws rebase` was removed; use `mkws sync` or `mkws sync --push`")
        elif sub == "merge":
            mode = "merge"
            argv.pop(0)
            if not (argv and not argv[0].startswith("-")):
                die("'merge' requires a target: master|main (Case B) or <workspace-name> (Case A)")
            target_path = argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        elif sub == "clean":
            mode = "clean"
            argv.pop(0)
            if argv and not argv[0].startswith("-"):
                target_path = argv.pop(0)
        elif sub == "migrate":
            mode = "migrate"
            argv.pop(0)
            if argv and not argv[0].startswith("-"):
                target_path = argv.pop(0)
        elif sub == "skill-sync":
            mode = "skill-sync"
            argv.pop(0)
        elif sub == "sync_tech_doc":
            mode = "sync_tech_doc"
            argv.pop(0)
        elif sub == "open":
            mode = "open"
            argv.pop(0)
            while argv and not argv[0].startswith("-"):
                target_paths.append(argv.pop(0))
        else:
            die(f"unknown subcommand: {sub}\n\n{USAGE}")

    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--name":
            if i + 1 >= len(argv):
                die("--name requires a value")
            name = argv[i + 1]
            i += 2
        elif a == "--branch":
            if i + 1 >= len(argv):
                die("--branch requires a value")
            branch = argv[i + 1]
            i += 2
        elif a == "--add":
            i += 1
            while i < len(argv) and not argv[i].startswith("--"):
                repos.append(argv[i])
                i += 1
        elif a == "--link":
            i += 1
            values = []
            while i < len(argv) and not argv[i].startswith("--"):
                values.append(argv[i])
                i += 1
            if not values or len(values) % 2 != 0:
                die("--link requires name/link pairs")
            for j in range(0, len(values), 2):
                link_pairs.append((values[j], values[j + 1]))
        elif a in ("-h", "--help"):
            print(USAGE)
            sys.exit(0)
        else:
            die(f"unknown flag: {a}\n\n{USAGE}")

    return mode, name, branch, repos, link_pairs, target_path, target_paths, sync_push


def main() -> None:
    if not has_cmd("git"):
        die("git not installed")

    mode, name, branch, repos, link_pairs, target_path, target_paths, sync_push = parse_args(sys.argv[1:])

    if mode == "pull":
        if repos or branch or name or link_pairs:
            die("'pull' takes folder path(s) only; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_pull(target_paths))
    if mode == "push":
        if repos or branch or name or link_pairs:
            die("'push' takes folder path(s) only; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_push(target_paths))
    if mode == "sync":
        if repos or branch or name or link_pairs:
            die("'sync' takes [--push] and folder path(s) only; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_sync(target_paths, push=sync_push))
    if mode == "merge":
        if repos or branch or name or link_pairs:
            die("'merge' takes a target + folder path(s) only; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_merge(target_path, target_paths))
    if mode == "clean":
        if repos or branch or name or link_pairs or target_paths:
            die("'clean' takes an optional folder path only; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_clean(target_path))
    if mode == "migrate":
        if repos or branch or name or link_pairs or target_paths:
            die("'migrate' takes an optional workspace folder only; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_migrate(target_path))
    if mode == "skill-sync":
        if repos or branch or name or link_pairs or target_path or target_paths:
            die("'skill-sync' takes no args; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_skill_sync())
    if mode == "sync_tech_doc":
        if repos or branch or name or link_pairs or target_path or target_paths:
            die("'sync_tech_doc' takes no args; --add/--branch/--name/--link are not accepted")
        sys.exit(cmd_sync_tech_doc())
    if mode == "open":
        if repos or branch or link_pairs or target_path:
            die("'open' takes an optional query only; --add/--branch/--link are not accepted")
        sys.exit(cmd_open(name, target_paths))
    if link_pairs:
        if repos or branch or target_path or target_paths:
            die("--link can be used with --name only; --add/--branch and subcommand args are not accepted")
        sys.exit(cmd_link(name, link_pairs))
    sys.exit(cmd_default(name, branch, repos))


if __name__ == "__main__":
    main()
