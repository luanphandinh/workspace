#!/usr/bin/env python3
"""meta-hub - sync workspace metadata into a git repository."""

import getpass
import hashlib
import os
import re
import shutil
import socket
import subprocess
import sys
from pathlib import Path

INFO_FILE = "info.yml"
REGISTRY_FILE = "registry.yml"
LEGACY_WORKSTATIONS_FILE = "workstations.yml"
WORKSTATION_FILE = "workstation.yml"
WORKSPACE_FILE = "workspace.yml"
WS_CONTAINER = "local_workspaces"
TECH_DOC_DIR = "tech_doc"
EXTERNAL_DIR = "_external"
EXTRA_SYNC_PATHS = (
    (Path(".skills-hub") / "execute_plugins", Path(".skills-hub") / "execute_plugins"),
    (Path(".cmds-hub") / "cmd_history", Path(".cmds-hub") / "cmd_history"),
)

_USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(code: str) -> str:
    return f"\033[{code}m" if _USE_COLOR else ""


RESET = _c("0")
BOLD = _c("1")
RED = _c("31")
GREEN = _c("32")
YELLOW = _c("33")
CYAN = _c("36")


def heading(text: str) -> None:
    print(f"\n{BOLD}{CYAN}=== {text} ==={RESET}", flush=True)


def info(text: str) -> None:
    print(f"  {text}", flush=True)


def ok(text: str) -> None:
    print(f"  {GREEN}ok{RESET} {text}", flush=True)


def warn(text: str) -> None:
    print(f"  {YELLOW}!{RESET} {text}", flush=True)


def die(text: str, code: int = 1) -> None:
    print(f"{RED}error:{RESET} {text}", file=sys.stderr)
    sys.exit(code)


def run(cmd: list, cwd: Path = None, capture: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        capture_output=capture,
        text=True,
    )


def parse_yml_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == '"' and value[-1] == '"':
        body = value[1:-1]
        return body.replace('\\"', '"').replace("\\\\", "\\")
    return value


def quote_yml_scalar(value: str) -> str:
    text = str(value or "")
    text = text.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{text}"'


def meta_home() -> Path:
    return Path.home() / ".meta-hub"


def legacy_meta_home() -> Path:
    return Path.home() / ".meta-sync"


def info_path() -> Path:
    return meta_home() / INFO_FILE


def local_legacy_registry_path() -> Path:
    return meta_home() / REGISTRY_FILE


def legacy_registry_path() -> Path:
    return legacy_meta_home() / REGISTRY_FILE


def parse_registry_file(yml: Path) -> list:
    entries = []
    remotes = []
    current = None
    section = ""
    for line in yml.read_text().splitlines():
        if line.startswith("  - root:"):
            current = {
                "root": parse_yml_scalar(line.split(":", 1)[1]),
                "repo": "",
                "clone": "",
            }
            entries.append(current)
            section = "entries"
        elif current is not None and line.startswith("    repo:"):
            current["repo"] = parse_yml_scalar(line.split(":", 1)[1])
        elif current is not None and line.startswith("    clone:"):
            current["clone"] = parse_yml_scalar(line.split(":", 1)[1])
        elif line.startswith("  - remote:"):
            current = {
                "repo": parse_yml_scalar(line.split(":", 1)[1]),
                "clone": "",
                "roots": [],
            }
            remotes.append(current)
            section = "remotes"
        elif section == "remotes" and current is not None and line.startswith("    clone:"):
            current["clone"] = parse_yml_scalar(line.split(":", 1)[1])
        elif section == "remotes" and current is not None and line.startswith("      - path:"):
            current["roots"].append(parse_yml_scalar(line.split(":", 1)[1]))
    if remotes:
        out = []
        for remote in remotes:
            for root in remote["roots"]:
                out.append({"root": root, "repo": remote["repo"], "clone": remote["clone"]})
        return [e for e in out if e.get("root") and e.get("repo") and e.get("clone")]
    return [e for e in entries if e.get("root") and e.get("repo") and e.get("clone")]


def parse_info_file(yml: Path) -> list:
    entries = []
    current = None
    for line in yml.read_text().splitlines():
        if line.startswith("  - path:"):
            current = {
                "root": parse_yml_scalar(line.split(":", 1)[1]),
                "clone": "",
            }
            entries.append(current)
        elif current is not None and line.startswith("    clone:"):
            current["clone"] = parse_yml_scalar(line.split(":", 1)[1])
    out = []
    for entry in entries:
        clone = Path(entry.get("clone") or "").expanduser()
        repo = git_origin(clone) if clone else ""
        if entry.get("root") and entry.get("clone") and repo:
            out.append({"root": entry["root"], "repo": repo, "clone": entry["clone"]})
    return out


def migrate_legacy_registry() -> list:
    old_yml = legacy_registry_path()
    if info_path().is_file() or local_legacy_registry_path().is_file() or not old_yml.is_file():
        return []
    migrated = []
    for entry in parse_registry_file(old_yml):
        clone = clone_path_for_repo(entry["repo"])
        old_clone = Path(entry["clone"]).expanduser()
        if old_clone.is_dir() and not clone.exists():
            clone.parent.mkdir(parents=True, exist_ok=True)
            shutil.copytree(old_clone, clone)
        migrated.append({"root": entry["root"], "repo": entry["repo"], "clone": str(clone)})
    if migrated:
        write_registry(migrated)
    return migrated


def read_registry() -> list:
    yml = info_path()
    if yml.is_file():
        old_yml = local_legacy_registry_path()
        if old_yml.is_file() or old_yml.is_symlink():
            old_yml.unlink()
        return parse_info_file(yml)
    old_yml = local_legacy_registry_path()
    if old_yml.is_file():
        entries = parse_registry_file(old_yml)
        if entries:
            write_registry(entries)
            return parse_info_file(info_path())
        return migrate_legacy_registry()
    return migrate_legacy_registry()


def write_registry(entries: list) -> None:
    meta_home().mkdir(parents=True, exist_ok=True)
    lines = ["version: v3", "roots:"]
    seen = set()
    for entry in entries:
        key = (entry["root"], entry["clone"])
        if key in seen:
            continue
        seen.add(key)
    for root, clone in sorted(seen):
        lines.append(f"  - path: {quote_yml_scalar(root)}")
        lines.append(f"    clone: {quote_yml_scalar(clone)}")
    info_path().write_text("\n".join(lines) + "\n")
    old_yml = local_legacy_registry_path()
    if old_yml.is_file() or old_yml.is_symlink():
        old_yml.unlink()


def repo_basename(repo: str) -> str:
    raw = repo.rstrip("/").rsplit("/", 1)[-1].rsplit(":", 1)[-1]
    if raw.endswith(".git"):
        raw = raw[:-4]
    raw = re.sub(r"[^A-Za-z0-9._-]+", "-", raw).strip(".-")
    return raw or "metadata"


def git_origin(clone: Path) -> str:
    proc = run(["git", "-C", str(clone), "remote", "get-url", "origin"])
    return proc.stdout.strip() if proc.returncode == 0 else ""


def is_git_worktree(path: Path) -> bool:
    proc = run(["git", "-C", str(path), "rev-parse", "--is-inside-work-tree"])
    return proc.returncode == 0 and proc.stdout.strip() == "true"


def is_git_repo_path(path: Path) -> bool:
    return path.is_dir() and (path / ".git").exists()


def git_output(repo: Path, args: list) -> str:
    proc = run(["git", "-C", str(repo), *args])
    if proc.returncode != 0:
        return ""
    return proc.stdout.strip()


def remote_names(repo: Path) -> list:
    return [line.strip() for line in git_output(repo, ["remote"]).splitlines() if line.strip()]


def preferred_remote(repo: Path, upstream: str) -> str:
    if "/" in upstream:
        return upstream.split("/", 1)[0]
    remotes = remote_names(repo)
    if "origin" in remotes:
        return "origin"
    return remotes[0] if remotes else ""


def remote_url(repo: Path, remote: str) -> str:
    if not remote:
        return ""
    return git_output(repo, ["remote", "get-url", remote])


def clone_path_for_repo(repo: str) -> Path:
    base = meta_home() / repo_basename(repo)
    if not base.exists() or git_origin(base) == repo:
        return base
    digest = hashlib.sha1(repo.encode("utf-8")).hexdigest()[:8]
    return meta_home() / f"{base.name}-{digest}"


def ensure_clone(repo: str, clone: Path) -> None:
    meta_home().mkdir(parents=True, exist_ok=True)
    if clone.exists():
        if is_git_worktree(clone) and git_origin(clone) == repo:
            return
        if is_git_worktree(clone):
            die(f"clone path points at a different git remote: {clone}")
        die(f"clone path exists but is not a git repository: {clone}")
    proc = run(["git", "clone", repo, str(clone)])
    if proc.returncode != 0:
        die(f"failed to clone metadata repository: {repo}\n{(proc.stderr or proc.stdout).rstrip()}")


def validate_repo(repo: str) -> None:
    proc = run(["git", "ls-remote", repo])
    if proc.returncode != 0:
        die(f"invalid git repository: {repo}\n{(proc.stderr or proc.stdout).rstrip()}")


def cmd_register(folder: str, repo: str) -> int:
    root = Path(folder or ".").expanduser()
    if not root.is_absolute():
        root = (Path.cwd() / root).resolve()
    else:
        root = root.resolve()
    if not root.is_dir():
        die(f"not a directory: {root}")

    validate_repo(repo)
    clone = clone_path_for_repo(repo)
    ensure_clone(repo, clone)

    entries = read_registry()
    updated = False
    entry = {"root": str(root), "repo": repo, "clone": str(clone)}
    for existing in entries:
        if Path(existing["root"]).expanduser().resolve() == root:
            existing.update(entry)
            updated = True
            break
    if not updated:
        entries.append(entry)
    write_registry(entries)

    heading("meta-hub register")
    info(f"root:  {BOLD}{root}{RESET}")
    info(f"repo:  {BOLD}{repo}{RESET}")
    info(f"clone: {BOLD}{clone}{RESET}")
    ok("info updated")
    return 0


def choose_entries(entries: list, pick: bool) -> list:
    if not entries:
        die(f"no info entries; run `meta-hub -f . -r <git-repository>` first")
    if not pick:
        return entries
    if shutil.which("fzf") is None:
        die("`pick` requires fzf on PATH")
    labels = [f"{entry['root']} | {entry['repo']}" for entry in entries]
    proc = subprocess.run(
        ["fzf"],
        input="\n".join(labels) + "\n",
        capture_output=True,
        text=True,
    )
    if proc.returncode != 0 or not proc.stdout.strip():
        die("no meta-hub entry selected")
    selected = proc.stdout.strip()
    for idx, label in enumerate(labels):
        if label == selected:
            return [entries[idx]]
    die("selected entry was not found")


def synced_registry_path(entry: dict) -> Path:
    return Path(entry["clone"]).expanduser().resolve() / REGISTRY_FILE


def read_cached_workstations(entry: dict, required: bool = True) -> list:
    registry = synced_registry_path(entry)
    if registry.is_file():
        return read_synced_registry_text(registry.read_text())["workstations"]
    if required:
        die(f"missing synced registry at {registry}; run `meta-hub index -p <workstation-folder>` first")
    return []


def registered_workstation_contexts(entries: list = None, required: bool = True) -> list:
    entries = read_registry() if entries is None else entries
    if not entries:
        die("no info entries; run `meta-hub -f . -r <git-repository>` first")
    out = []
    for entry in entries:
        root = Path(entry["root"]).resolve()
        clone = Path(entry["clone"]).expanduser().resolve()
        ensure_clone(entry["repo"], clone)
        workstations = read_cached_workstations(entry, required=required)
        for workstation in workstations:
            rel_root = workstation.get("root") or "."
            station_root = safe_source_path(root, rel_root)
            metadata_prefix = Path() if rel_root == "." else Path(rel_root)
            out.append({
                "entry": entry,
                "root": root,
                "clone": clone,
                "workstation": workstation,
                "station_root": station_root,
                "metadata_prefix": metadata_prefix,
            })
    return out


def workspace_name(workspace_yml: Path) -> str:
    data = read_workspace_manifest_text(workspace_yml.read_text())
    return data.get("name") or workspace_yml.parent.name


def add_candidate(candidates: list, seen_paths: set, label: str, path: Path) -> None:
    resolved = path.resolve()
    key = str(resolved)
    if key in seen_paths:
        return
    seen_paths.add(key)
    candidates.append({"label": f"{label} | {resolved}", "path": key})


def project_candidates() -> list:
    candidates = []
    seen_paths = set()
    for ctx in registered_workstation_contexts(required=True):
        workstation = ctx["workstation"]
        station_root = ctx["station_root"]
        metadata_root = ctx["clone"] / ctx["metadata_prefix"]
        station_name = workstation.get("name") or station_root.name
        for workspace_yml in sorted((metadata_root / WS_CONTAINER).glob(f"*/{WORKSPACE_FILE}")):
            name = workspace_name(workspace_yml)
            local_workspace = station_root / WS_CONTAINER / workspace_yml.parent.name
            if local_workspace.is_dir():
                add_candidate(candidates, seen_paths, f"{name} | {station_name}", local_workspace)
    return sorted(candidates, key=lambda item: item["label"])


def repo_candidates() -> list:
    candidates = []
    seen_paths = set()
    for ctx in registered_workstation_contexts(required=True):
        workstation = ctx["workstation"]
        station_root = ctx["station_root"]
        metadata_root = ctx["clone"] / ctx["metadata_prefix"]
        station_name = workstation.get("name") or station_root.name
        manifest_rel = workstation.get("manifest") or WORKSTATION_FILE
        manifest = ctx["clone"] / manifest_rel
        if manifest.is_file():
            data = read_workstation_manifest_text(manifest.read_text())
            for repo in data.get("repos", []):
                repo_data = normalize_repo_record(repo)
                repo_path = station_root / (repo_data["path"] or repo_data["name"])
                if (repo_path / ".git").exists():
                    add_candidate(candidates, seen_paths, f"{repo_data['name']} | {station_name} | source", repo_path)
        for workspace_yml in sorted((metadata_root / WS_CONTAINER).glob(f"*/{WORKSPACE_FILE}")):
            project_name = workspace_name(workspace_yml)
            workspace_dir = station_root / WS_CONTAINER / workspace_yml.parent.name
            if not workspace_dir.is_dir():
                continue
            for child in sorted(p for p in workspace_dir.iterdir() if p.is_dir()):
                if (child / ".git").exists():
                    add_candidate(candidates, seen_paths, f"{child.name} | {station_name}/{project_name} | workspace", child)
    return sorted(candidates, key=lambda item: item["label"])


def pick_path(candidates: list, prompt: str) -> str:
    if not candidates:
        die(f"no {prompt.rstrip('> ')} candidates found")
    if shutil.which("fzf") is None:
        die("fzf is required")
    labels = [item["label"] for item in candidates]
    paths = {item["label"]: item["path"] for item in candidates}
    proc = subprocess.run(
        ["fzf", "--prompt", prompt],
        input="\n".join(labels) + "\n",
        stdout=subprocess.PIPE,
        text=True,
    )
    selected = proc.stdout.strip()
    if proc.returncode != 0 or not selected:
        die(f"no {prompt.rstrip('> ')} selected")
    if selected not in paths:
        die("selected path was not found")
    return paths[selected]


def cmd_project() -> int:
    print(pick_path(project_candidates(), "meta-project> "))
    return 0


def cmd_repo() -> int:
    print(pick_path(repo_candidates(), "meta-repo> "))
    return 0


def read_synced_registry_text(text: str) -> dict:
    data = {"version": "v2", "remote": "", "workstations": []}
    section = ""
    current = None
    for line in text.splitlines():
        if line.startswith("version:"):
            data["version"] = parse_yml_scalar(line.split(":", 1)[1]) or "v2"
            section = ""
        elif line.startswith("remote:"):
            data["remote"] = parse_yml_scalar(line.split(":", 1)[1])
            section = ""
        elif line.startswith("workstations:"):
            section = "workstations"
            current = None
        elif section == "workstations" and line.startswith("  - name:"):
            current = {
                "name": parse_yml_scalar(line.split(":", 1)[1]),
                "root": "",
                "manifest": "",
            }
            data["workstations"].append(current)
        elif section == "workstations" and current is not None and line.startswith("    "):
            key, sep, value = line.strip().partition(":")
            if sep and key in current:
                current[key] = parse_yml_scalar(value)
    return data


def render_synced_registry(remote: str, workstations: list) -> str:
    lines = ["version: v2", f"remote: {quote_yml_scalar(remote)}", "workstations:"]
    for item in workstations:
        lines.append(f"  - name: {quote_yml_scalar(item.get('name') or '')}")
        lines.append(f"    root: {quote_yml_scalar(item.get('root') or '')}")
        lines.append(f"    manifest: {quote_yml_scalar(item.get('manifest') or '')}")
    return "\n".join(lines) + "\n"


def normalize_repo_record(repo: dict) -> dict:
    return {
        "name": str(repo.get("name") or "").strip(),
        "path": str(repo.get("path") or "").strip(),
        "remote": str(repo.get("remote") or "").strip(),
        "remote_url": str(repo.get("remote_url") or "").strip(),
        "upstream": str(repo.get("upstream") or "").strip(),
        "branch": str(repo.get("branch") or "").strip(),
    }


def normalize_workstation_repos(repos: list) -> list:
    out = []
    seen = set()
    for repo in repos or []:
        if not isinstance(repo, dict):
            continue
        item = normalize_repo_record(repo)
        if not item["name"]:
            continue
        if not item["path"]:
            item["path"] = item["name"]
        key = item["path"]
        if key in seen:
            continue
        seen.add(key)
        out.append(item)
    return sorted(out, key=lambda item: (item["path"], item["name"]))


def read_workstation_manifest_text(text: str) -> dict:
    data = {"version": "v1", "name": "", "repos": [], "_external": {"repos": []}}
    section = ""
    current = None
    for line in text.splitlines():
        if line.startswith("version:"):
            data["version"] = parse_yml_scalar(line.split(":", 1)[1]) or "v1"
            section = ""
        elif line.startswith("name:"):
            data["name"] = parse_yml_scalar(line.split(":", 1)[1])
            section = ""
        elif line.startswith("repos:"):
            section = "repos"
            current = None
        elif line.startswith("_external:"):
            section = "_external"
            current = None
        elif section == "_external" and line.startswith("  repos:"):
            section = "_external.repos"
            current = None
        elif section == "repos" and line.startswith("  - name:"):
            current = {"name": parse_yml_scalar(line.split(":", 1)[1])}
            data["repos"].append(current)
        elif section == "repos" and current is not None and line.startswith("    "):
            key, sep, value = line.strip().partition(":")
            if sep:
                current[key] = parse_yml_scalar(value)
        elif section == "_external.repos" and line.startswith("    - name:"):
            current = {"name": parse_yml_scalar(line.split(":", 1)[1])}
            data["_external"]["repos"].append(current)
        elif section == "_external.repos" and current is not None and line.startswith("      "):
            key, sep, value = line.strip().partition(":")
            if sep:
                current[key] = parse_yml_scalar(value)
    return data


def render_repo_records(lines: list, repos: list, indent: str) -> None:
    for repo in normalize_workstation_repos(repos):
        lines.append(f"{indent}- name: {quote_yml_scalar(repo['name'])}")
        lines.append(f"{indent}  path: {quote_yml_scalar(repo['path'] or repo['name'])}")
        lines.append(f"{indent}  remote: {quote_yml_scalar(repo['remote'])}")
        lines.append(f"{indent}  remote_url: {quote_yml_scalar(repo['remote_url'])}")
        lines.append(f"{indent}  upstream: {quote_yml_scalar(repo['upstream'])}")
        lines.append(f"{indent}  branch: {quote_yml_scalar(repo['branch'])}")


def render_workstation_manifest(data: dict) -> str:
    lines = ["version: v1", f"name: {quote_yml_scalar(data.get('name') or '')}", "repos:"]
    render_repo_records(lines, data.get("repos", []), "  ")
    external = data.get("_external", {}).get("repos", [])
    if external:
        lines.append("_external:")
        lines.append("  repos:")
        render_repo_records(lines, external, "    ")
    return "\n".join(lines) + "\n"


def discover_workstation_repos(workstation_root: Path) -> list:
    skipped = {WS_CONTAINER, TECH_DOC_DIR, EXTERNAL_DIR}
    repos = []
    for child in sorted(p for p in workstation_root.iterdir() if p.is_dir()):
        if child.name.startswith(".") or child.name in skipped:
            continue
        if is_git_repo_path(child):
            repos.append(child)
    return repos


def discover_external_workstation_repos(workstation_root: Path) -> list:
    external_root = workstation_root / EXTERNAL_DIR
    if not external_root.is_dir():
        return []
    return sorted(child for child in external_root.iterdir() if child.is_dir() and is_git_repo_path(child))


def workstation_repo_record(workstation_root: Path, repo: Path) -> dict:
    branch = git_output(repo, ["rev-parse", "--abbrev-ref", "HEAD"])
    upstream = git_output(repo, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"])
    remote = preferred_remote(repo, upstream)
    try:
        rel_path = repo.relative_to(workstation_root).as_posix()
    except ValueError:
        rel_path = repo.name
    return {
        "name": repo.name,
        "path": rel_path,
        "remote": remote,
        "remote_url": remote_url(repo, remote),
        "upstream": upstream,
        "branch": branch,
    }


def upsert_repo_records_with_stats(existing: list, discovered: list) -> tuple:
    indexed = normalize_workstation_repos(existing)
    by_path = {repo["path"]: repo for repo in indexed}
    by_name = {repo["name"]: repo for repo in indexed}
    stats = {
        "added": 0,
        "updated": 0,
        "unchanged": 0,
        "missing": [],
        "missing_upstream": 0,
        "events": [],
    }
    discovered_paths = set()
    for record in discovered:
        discovered_paths.add(record["path"])
        current = by_path.get(record["path"]) or by_name.get(record["name"])
        if current is None:
            indexed.append(record)
            by_path[record["path"]] = record
            by_name[record["name"]] = record
            status = "added"
            stats["added"] += 1
        else:
            if any(current.get(k, "") != record[k] for k in record):
                current.update(record)
                by_path[record["path"]] = current
                by_name[record["name"]] = current
                status = "updated"
                stats["updated"] += 1
            else:
                status = "unchanged"
                stats["unchanged"] += 1
        if not record["upstream"]:
            stats["missing_upstream"] += 1
        stats["events"].append({"status": status, "record": dict(record)})
    existing_paths = {repo["path"] for repo in normalize_workstation_repos(indexed)}
    stats["missing"] = sorted(existing_paths - discovered_paths)
    return normalize_workstation_repos(indexed), stats


def index_workstation_data(workstation_root: Path, existing: dict = None) -> tuple:
    data = existing or {"version": "v1", "name": "", "repos": [], "_external": {"repos": []}}
    repos = [
        workstation_repo_record(workstation_root, repo)
        for repo in discover_workstation_repos(workstation_root)
    ]
    external_repos = [
        workstation_repo_record(workstation_root, repo)
        for repo in discover_external_workstation_repos(workstation_root)
    ]
    indexed_repos, repo_stats = upsert_repo_records_with_stats(data.get("repos", []), repos)
    indexed_external_repos, external_stats = upsert_repo_records_with_stats(
        data.get("_external", {}).get("repos", []),
        external_repos,
    )
    return {
        "version": "v1",
        "name": data.get("name") or workstation_root.name,
        "repos": indexed_repos,
        "_external": {
            "repos": indexed_external_repos,
        },
    }, {
        "discovered": len(repos),
        "external_discovered": len(external_repos),
        "repos": repo_stats,
        "external": external_stats,
    }


def print_repo_index_events(stats: dict) -> None:
    for event in stats.get("events", []):
        record = event.get("record", {})
        label = record.get("path") or record.get("name") or "(unknown)"
        status = event.get("status")
        if status == "added":
            ok(f"added {label}")
        elif status == "updated":
            ok(f"updated {label}")
        else:
            info(f"{label}: already indexed")
        if not record.get("upstream"):
            warn(f"{label}: no upstream branch configured")


def print_workstation_index_summary(workstation_root: Path, manifest_dest: Path, stats: dict, changed: bool) -> None:
    repo_stats = stats["repos"]
    external_stats = stats["external"]

    heading("workstation index")
    print_repo_index_events(repo_stats)
    if external_stats.get("events"):
        heading("external index")
        print_repo_index_events(external_stats)

    heading("summary")
    info(f"workstation: {BOLD}{workstation_root}{RESET}")
    info(f"manifest:    {BOLD}{manifest_dest}{RESET}")
    info(f"discovered:  {stats['discovered']}")
    info(
        f"added: {repo_stats['added']}, updated: {repo_stats['updated']}, "
        f"unchanged: {repo_stats['unchanged']}, missing: {len(repo_stats['missing'])}"
    )
    info(
        f"external:    {stats['external_discovered']} "
        f"(added: {external_stats['added']}, updated: {external_stats['updated']}, "
        f"unchanged: {external_stats['unchanged']}, missing: {len(external_stats['missing'])})"
    )
    if repo_stats["missing"]:
        info(f"kept missing entries: {YELLOW}{', '.join(repo_stats['missing'])}{RESET}")
    if external_stats["missing"]:
        info(f"kept missing external entries: {YELLOW}{', '.join(external_stats['missing'])}{RESET}")
    if repo_stats["missing_upstream"]:
        info(f"repos without upstream: {YELLOW}{repo_stats['missing_upstream']}{RESET}")
    if external_stats["missing_upstream"]:
        info(f"external repos without upstream: {YELLOW}{external_stats['missing_upstream']}{RESET}")
    if changed:
        ok("metadata workstation.yml updated")
    else:
        ok("metadata workstation.yml already current")


def workstation_clone_branch(repo: dict) -> str:
    upstream = repo.get("upstream", "")
    remote = repo.get("remote", "")
    if upstream and "/" in upstream:
        up_remote, up_branch = upstream.split("/", 1)
        if not remote or remote == up_remote:
            return up_branch
    branch = repo.get("branch", "")
    return "" if branch == "HEAD" else branch


def resolve_workstation_repo_path(workstation_root: Path, repo: dict) -> Path:
    rel = repo.get("path") or repo.get("name") or ""
    if not rel:
        raise ValueError("missing repo path")
    path = Path(rel)
    if path.is_absolute():
        raise ValueError(f"path must be relative to workstation root: {rel}")
    resolved = (workstation_root / path).resolve()
    try:
        resolved.relative_to(workstation_root)
    except ValueError:
        raise ValueError(f"path escapes workstation root: {rel}")
    return resolved


def read_workspace_manifest_text(text: str) -> dict:
    data = {"version": "v1", "name": "", "branch_name": "", "links": [], "repos": []}
    section = ""
    current_repo = None
    current_link = None
    for line in text.splitlines():
        if line.startswith("version:"):
            data["version"] = parse_yml_scalar(line.split(":", 1)[1]) or "v1"
            section = ""
        elif line.startswith("name:"):
            data["name"] = parse_yml_scalar(line.split(":", 1)[1])
            section = ""
        elif line.startswith("branch_name:"):
            data["branch_name"] = parse_yml_scalar(line.split(":", 1)[1])
            section = ""
        elif line.startswith("links:"):
            section = "links"
            current_link = None
        elif line.startswith("repos:"):
            section = "repos"
            current_repo = None
        elif section == "links" and line.startswith("  - name:"):
            current_link = {"name": parse_yml_scalar(line.split(":", 1)[1]), "link": ""}
            data["links"].append(current_link)
        elif section == "links" and current_link is not None and line.startswith("    link:"):
            current_link["link"] = parse_yml_scalar(line.split(":", 1)[1])
        elif section == "repos" and line.startswith("  - name:"):
            current_repo = {"name": parse_yml_scalar(line.split(":", 1)[1]), "branch_name": "", "base_branch": ""}
            data["repos"].append(current_repo)
        elif section == "repos" and current_repo is not None and line.startswith("    "):
            key, sep, value = line.strip().partition(":")
            if sep and key in current_repo:
                current_repo[key] = parse_yml_scalar(value)
        elif section == "repos" and line.startswith("  - "):
            data["repos"].append({
                "name": parse_yml_scalar(line[4:]),
                "branch_name": data["branch_name"],
                "base_branch": "",
            })
    return data


def render_workspace_manifest(data: dict) -> str:
    lines = [
        "version: v2",
        f"name: {data.get('name') or ''}",
        f"branch_name: {data.get('branch_name') or ''}",
    ]
    links = [item for item in data.get("links", []) if item.get("name") and item.get("link")]
    if links:
        lines.append("links:")
        for item in links:
            lines.append(f"  - name: {item['name']}")
            lines.append(f"    link: {item['link']}")
    lines.append("repos:")
    for repo in data.get("repos", []):
        name = repo.get("name") or ""
        if not name:
            continue
        lines.append(f"  - name: {name}")
        lines.append(f"    branch_name: {repo.get('branch_name') or data.get('branch_name') or ''}")
        if repo.get("base_branch"):
            lines.append(f"    base_branch: {repo['base_branch']}")
    return "\n".join(lines) + "\n"


def safe_source_path(root: Path, rel: str) -> Path:
    path = root if rel == "." else (root / rel)
    resolved = path.resolve()
    try:
        resolved.relative_to(root)
    except ValueError:
        die(f"metadata path escapes source root: {rel}")
    return resolved


def merge_metadata_text(rel_path: Path, source_text: str, existing_text: str) -> str:
    path_text = rel_path.as_posix()
    name = rel_path.name
    if path_text == REGISTRY_FILE:
        return merge_synced_registry(source_text, existing_text)
    if name == WORKSTATION_FILE:
        return merge_workstation(source_text, existing_text)
    if name == WORKSPACE_FILE:
        return merge_workspace(source_text, existing_text)
    if rel_path == Path(".cmds-hub") / "cmd_history":
        return merge_lines(source_text, existing_text)
    if rel_path == Path(".skills-hub") / "execute_plugins" or (
        len(rel_path.parts) > 2 and rel_path.parts[:2] == (".skills-hub", "execute_plugins")
    ):
        return merge_lines(source_text, existing_text)
    return source_text


def merge_copy_file(src: Path, dest: Path, rel_path: Path) -> None:
    dest.parent.mkdir(parents=True, exist_ok=True)
    if dest.exists() and dest.is_dir():
        warn(f"{dest} exists as a directory, skipping file sync")
        return
    if dest.is_file():
        dest.write_text(merge_metadata_text(rel_path, src.read_text(), dest.read_text()))
        return
    shutil.copy2(src, dest)


def merge_write_text(dest: Path, rel_path: Path, text: str) -> None:
    dest.parent.mkdir(parents=True, exist_ok=True)
    if dest.exists() and dest.is_dir():
        warn(f"{dest} exists as a directory, skipping file sync")
        return
    if dest.is_file():
        dest.write_text(merge_metadata_text(rel_path, text, dest.read_text()))
        return
    dest.write_text(text)


def remove_legacy_workstations_file(clone: Path) -> None:
    legacy = clone / LEGACY_WORKSTATIONS_FILE
    if legacy.is_symlink() or legacy.is_file():
        legacy.unlink()
    elif legacy.exists():
        warn(f"{legacy} exists and is not a file, skipping legacy cleanup")


def merge_copy_path(src: Path, dest: Path, rel_path: Path) -> bool:
    if not src.exists():
        return False
    if src.is_dir():
        if dest.exists() and not dest.is_dir():
            warn(f"{dest} exists as a file, skipping directory sync")
            return False
        copied = False
        for child in sorted(src.rglob("*")):
            if child.is_dir():
                continue
            child_rel = child.relative_to(src)
            merge_copy_file(child, dest / child_rel, rel_path / child_rel)
            copied = True
        return copied
    merge_copy_file(src, dest, rel_path)
    return True


def copy_workspace_manifests(workstation_root: Path, clone: Path, dest_prefix: Path) -> int:
    count = 0
    local_workspaces = workstation_root / WS_CONTAINER
    if not local_workspaces.is_dir():
        return count
    for workspace_yml in sorted(local_workspaces.glob(f"*/{WORKSPACE_FILE}")):
        rel = workspace_yml.relative_to(workstation_root)
        merge_copy_file(workspace_yml, clone / dest_prefix / rel, dest_prefix / rel)
        count += 1
    return count


def copy_extra_metadata(clone: Path) -> int:
    count = 0
    for source_rel, dest_rel in EXTRA_SYNC_PATHS:
        if merge_copy_path(Path.home() / source_rel, clone / dest_rel, dest_rel):
            count += 1
    return count


def commit_metadata_changes(clone: Path) -> bool:
    proc = run(["git", "-C", str(clone), "add", "-A"])
    if proc.returncode != 0:
        die(f"git add failed in {clone}\n{(proc.stderr or proc.stdout).rstrip()}")
    status = run(["git", "-C", str(clone), "status", "--porcelain"])
    if not status.stdout.strip():
        info("no metadata changes")
        return False

    message = f"sync from {getpass.getuser()}@{socket.gethostname()}"
    proc = run(["git", "-C", str(clone), "commit", "-m", message])
    if proc.returncode != 0:
        die(f"git commit failed in {clone}\n{(proc.stderr or proc.stdout).rstrip()}")
    return True


def upsert_workstation(workstations: list, item: dict) -> list:
    key = item.get("manifest") or item.get("root")
    out = []
    replaced = False
    for existing in workstations:
        existing_key = existing.get("manifest") or existing.get("root")
        if existing_key == key:
            out.append(dict(item))
            replaced = True
        else:
            out.append(dict(existing))
    if not replaced:
        out.append(dict(item))
    return sorted(out, key=lambda value: (value.get("root") or "", value.get("name") or ""))


def registered_entry_for_workstation(workstation_root: Path) -> tuple:
    entries = read_registry()
    matches = []
    for entry in entries:
        root = Path(entry["root"]).resolve()
        try:
            rel = workstation_root.relative_to(root)
        except ValueError:
            continue
        matches.append((len(root.parts), entry, root, rel))
    if not matches:
        die(f"workstation path is not under a registered root: {workstation_root}")
    _, entry, root, rel = sorted(matches, key=lambda item: item[0], reverse=True)[0]
    rel_text = "." if rel == Path(".") else rel.as_posix()
    return entry, root, rel_text


def indexed_workstations_for_entry(entry: dict) -> list:
    registry = synced_registry_path(entry)
    return read_synced_registry_text(registry.read_text())["workstations"] if registry.is_file() else []


def index_workstation_metadata(entry: dict, rel_root: str, workstation_root: Path, workstations: list) -> tuple:
    repo = entry["repo"]
    clone = Path(entry["clone"]).expanduser().resolve()
    manifest_rel = WORKSTATION_FILE if rel_root == "." else f"{rel_root}/{WORKSTATION_FILE}"
    manifest_dest = clone / manifest_rel
    existing = read_workstation_manifest_text(manifest_dest.read_text()) if manifest_dest.is_file() else None
    data, stats = index_workstation_data(workstation_root, existing)
    old_text = manifest_dest.read_text() if manifest_dest.is_file() else ""
    merge_write_text(manifest_dest, Path(manifest_rel), render_workstation_manifest(data))
    new_text = manifest_dest.read_text() if manifest_dest.is_file() else ""
    print_workstation_index_summary(workstation_root, manifest_dest, stats, old_text != new_text)

    workstations = upsert_workstation(workstations, {
        "name": data.get("name") or workstation_root.name,
        "root": rel_root,
        "manifest": manifest_rel,
    })
    dest_prefix = Path() if rel_root == "." else Path(rel_root)
    workspace_count = copy_workspace_manifests(workstation_root, clone, dest_prefix)
    return workstations, len(data.get("repos", [])), workspace_count


def write_indexed_workstations(entry: dict, workstations: list) -> None:
    registry = synced_registry_path(entry)
    merge_write_text(
        registry,
        Path(REGISTRY_FILE),
        render_synced_registry(entry["repo"], workstations),
    )


def index_entry_path(path: str) -> bool:
    workstation_root = Path(path).expanduser()
    if not workstation_root.is_absolute():
        workstation_root = (Path.cwd() / workstation_root).resolve()
    else:
        workstation_root = workstation_root.resolve()
    if not workstation_root.is_dir():
        die(f"not a directory: {workstation_root}")

    entry, root, rel_root = registered_entry_for_workstation(workstation_root)
    clone = Path(entry["clone"]).expanduser().resolve()
    ensure_clone(entry["repo"], clone)

    heading(f"index {rel_root}")
    if not pull_metadata(entry):
        warn("skipping workstation index because remote pull did not complete")
        return False

    workstations = indexed_workstations_for_entry(entry)
    workstations, repo_count, workspace_count = index_workstation_metadata(
        entry,
        rel_root,
        workstation_root,
        workstations,
    )
    write_indexed_workstations(entry, workstations)
    remove_legacy_workstations_file(clone)
    extra_count = copy_extra_metadata(clone)

    changed = commit_metadata_changes(clone)
    if changed:
        ok(
            f"indexed {repo_count} repo(s), "
            f"{workspace_count} workspace manifest(s), {extra_count} extra path(s)"
        )
    return True


def index_entry(entry: dict) -> bool:
    root = Path(entry["root"]).resolve()
    if not root.is_dir():
        die(f"registered root is missing: {root}")
    clone = Path(entry["clone"]).expanduser().resolve()
    ensure_clone(entry["repo"], clone)

    heading(f"index {repo_basename(entry['repo'])}")
    if not pull_metadata(entry):
        warn("skipping workstation index because remote pull did not complete")
        return False

    workstations = indexed_workstations_for_entry(entry)
    if not workstations:
        die(f"missing synced registry at {synced_registry_path(entry)}; run `meta-hub index -p <workstation-folder>` first")

    indexed = skipped = repo_count = workspace_count = 0
    for workstation in list(workstations):
        rel_root = workstation.get("root") or "."
        station_root = safe_source_path(root, rel_root)
        if not station_root.is_dir():
            warn(f"missing local workstation folder: {station_root}")
            skipped += 1
            continue
        workstations, repos, workspaces = index_workstation_metadata(
            entry,
            rel_root,
            station_root,
            workstations,
        )
        indexed += 1
        repo_count += repos
        workspace_count += workspaces

    write_indexed_workstations(entry, workstations)
    remove_legacy_workstations_file(clone)
    extra_count = copy_extra_metadata(clone)
    changed = commit_metadata_changes(clone)
    if changed:
        ok(
            f"indexed {indexed} workstation(s), {repo_count} repo(s), "
            f"{workspace_count} workspace manifest(s), {extra_count} extra path(s)"
        )
    elif skipped:
        info(f"skipped {skipped} missing workstation(s)")
    return indexed > 0


def setup_repo_from_metadata(workstation_root: Path, repo: dict) -> str:
    repo_data = normalize_repo_record(repo)
    if not repo_data["name"]:
        return "skipped"
    if not repo_data["path"]:
        repo_data["path"] = repo_data["name"]
    try:
        dest = resolve_workstation_repo_path(workstation_root, repo_data)
    except ValueError as exc:
        warn(str(exc))
        return "failed"

    if dest.exists():
        if is_git_repo_path(dest):
            return "skipped"
        warn(f"path exists but is not a git repo: {dest}")
        return "failed"

    remote_url_value = repo_data.get("remote_url", "")
    if not remote_url_value:
        warn(f"{repo_data['path']}: missing remote_url in metadata")
        return "failed"

    dest.parent.mkdir(parents=True, exist_ok=True)
    cmd = ["git", "clone"]
    if repo_data.get("remote"):
        cmd.extend(["--origin", repo_data["remote"]])
    branch = workstation_clone_branch(repo_data)
    if branch:
        cmd.extend(["--branch", branch])
    cmd.extend([remote_url_value, str(dest)])
    proc = run(cmd)
    if proc.returncode != 0:
        warn(f"clone failed for {repo_data['path']}: {(proc.stderr or proc.stdout).rstrip()}")
        return "failed"
    return "cloned"


def ensure_workspace_dirs_from_metadata(clone: Path, station_root: Path, metadata_prefix: Path) -> int:
    count = 0
    metadata_root = clone / metadata_prefix
    for workspace_yml in sorted((metadata_root / WS_CONTAINER).glob(f"*/{WORKSPACE_FILE}")):
        workspace_dir = station_root / WS_CONTAINER / workspace_yml.parent.name
        if not workspace_dir.exists():
            workspace_dir.mkdir(parents=True, exist_ok=True)
            count += 1
    return count


def sync_entry(entry: dict) -> bool:
    root = Path(entry["root"]).resolve()
    root.mkdir(parents=True, exist_ok=True)
    clone = Path(entry["clone"]).expanduser().resolve()
    ensure_clone(entry["repo"], clone)

    heading(f"sync {repo_basename(entry['repo'])}")
    if not pull_metadata(entry):
        warn("skipping workstation setup because remote pull did not complete")
        return False

    workstations = read_cached_workstations(entry, required=False)
    if not workstations:
        info("no indexed workstations")
        return True

    cloned = skipped = failed = workspace_dirs = 0
    for workstation in workstations:
        rel_root = workstation.get("root") or "."
        station_root = safe_source_path(root, rel_root)
        station_root.mkdir(parents=True, exist_ok=True)
        manifest_rel = workstation.get("manifest") or WORKSTATION_FILE
        manifest = clone / manifest_rel
        if not manifest.is_file():
            warn(f"missing metadata workstation manifest: {manifest_rel}")
            continue
        data = read_workstation_manifest_text(manifest.read_text())
        for repo in normalize_workstation_repos(data.get("repos", [])):
            result = setup_repo_from_metadata(station_root, repo)
            if result == "cloned":
                cloned += 1
            elif result == "skipped":
                skipped += 1
            else:
                failed += 1
        metadata_prefix = Path() if rel_root == "." else Path(rel_root)
        workspace_dirs += ensure_workspace_dirs_from_metadata(clone, station_root, metadata_prefix)

    ok(f"cloned {cloned}, skipped {skipped}, failed {failed}, workspace dirs {workspace_dirs}")
    return failed == 0


def sync_workstation_tech_docs(workstation_root: Path) -> dict:
    workspaces_dir = workstation_root / WS_CONTAINER
    index_dir = workstation_root / TECH_DOC_DIR
    desired = {}

    if workspaces_dir.is_dir():
        for workspace_yml in sorted(workspaces_dir.glob(f"*/{WORKSPACE_FILE}")):
            workspace_dir = workspace_yml.parent
            tech_doc = workspace_dir / TECH_DOC_DIR
            if not tech_doc.is_dir():
                continue
            data = read_workspace_manifest_text(workspace_yml.read_text())
            name = data.get("name") or workspace_dir.name
            desired[name] = tech_doc.resolve()

    counts = {"created": 0, "updated": 0, "removed": 0, "skipped": 0}
    if not desired and not index_dir.exists():
        return counts

    index_dir.mkdir(parents=True, exist_ok=True)
    for name, target in desired.items():
        link_parent = index_dir / name
        link_path = link_parent / TECH_DOC_DIR
        if link_parent.exists() and not link_parent.is_dir():
            warn(f"{workstation_root.name}/{name}: {link_parent} exists and is not a directory, skipping")
            counts["skipped"] += 1
            continue
        link_parent.mkdir(parents=True, exist_ok=True)

        if link_path.is_symlink():
            if link_path.resolve() == target:
                counts["skipped"] += 1
                continue
            link_path.unlink()
            link_path.symlink_to(target, target_is_directory=True)
            counts["updated"] += 1
            continue

        if link_path.exists():
            warn(f"{workstation_root.name}/{name}: {link_path} exists and is not a symlink, skipping")
            counts["skipped"] += 1
            continue

        link_path.symlink_to(target, target_is_directory=True)
        counts["created"] += 1

    if index_dir.is_dir():
        for entry in sorted(p for p in index_dir.iterdir() if p.is_dir()):
            if entry.name in desired:
                continue
            link_path = entry / TECH_DOC_DIR
            if not link_path.is_symlink():
                continue
            link_path.unlink()
            counts["removed"] += 1
            try:
                entry.rmdir()
            except OSError:
                pass

    return counts


def sync_tech_doc_entry(entry: dict) -> bool:
    root = Path(entry["root"]).resolve()
    if not root.is_dir():
        die(f"registered root is missing: {root}")

    heading(f"sync tech docs {root.name}")
    totals = {"created": 0, "updated": 0, "removed": 0, "skipped": 0}
    for ctx in registered_workstation_contexts([entry], required=True):
        workstation_root = ctx["station_root"]
        if not workstation_root.is_dir():
            continue
        counts = sync_workstation_tech_docs(workstation_root)
        for key, value in counts.items():
            totals[key] += value

    ok(
        f"created {totals['created']}, updated {totals['updated']}, "
        f"removed {totals['removed']}, skipped {totals['skipped']}"
    )
    return True


def merge_by_key(local_items: list, remote_items: list, key_fn) -> list:
    out = []
    positions = {}
    for item in local_items:
        key = key_fn(item)
        if not key:
            continue
        positions[key] = len(out)
        out.append(dict(item))
    for item in remote_items:
        key = key_fn(item)
        if not key:
            continue
        if key not in positions:
            positions[key] = len(out)
            out.append(dict(item))
            continue
        existing = out[positions[key]]
        for field, value in item.items():
            if not existing.get(field) and value:
                existing[field] = value
    return out


def merge_synced_registry(local_text: str, remote_text: str) -> str:
    local = read_synced_registry_text(local_text)
    remote = read_synced_registry_text(remote_text)
    return render_synced_registry(
        local.get("remote") or remote.get("remote") or "",
        merge_by_key(
            local.get("workstations", []),
            remote.get("workstations", []),
            lambda item: item.get("manifest") or item.get("root"),
        ),
    )


def merge_workstation(local_text: str, remote_text: str) -> str:
    local = read_workstation_manifest_text(local_text)
    remote = read_workstation_manifest_text(remote_text)
    return render_workstation_manifest({
        "name": local.get("name") or remote.get("name") or "",
        "repos": merge_by_key(
            local.get("repos", []),
            remote.get("repos", []),
            lambda item: item.get("path") or item.get("name"),
        ),
        "_external": {
            "repos": merge_by_key(
                local.get("_external", {}).get("repos", []),
                remote.get("_external", {}).get("repos", []),
                lambda item: item.get("path") or item.get("name"),
            ),
        },
    })


def merge_workspace(local_text: str, remote_text: str) -> str:
    local = read_workspace_manifest_text(local_text)
    remote = read_workspace_manifest_text(remote_text)
    return render_workspace_manifest({
        "name": local.get("name") or remote.get("name") or "",
        "branch_name": local.get("branch_name") or remote.get("branch_name") or "",
        "links": merge_by_key(
            local.get("links", []),
            remote.get("links", []),
            lambda item: item.get("name") or item.get("link"),
        ),
        "repos": merge_by_key(
            local.get("repos", []),
            remote.get("repos", []),
            lambda item: item.get("name"),
        ),
    })


def merge_lines(local_text: str, remote_text: str) -> str:
    lines = []
    seen = set()
    for line in [*local_text.splitlines(), *remote_text.splitlines()]:
        if line in seen:
            continue
        seen.add(line)
        lines.append(line)
    return "\n".join(lines) + ("\n" if lines else "")


def git_stage_text(clone: Path, stage: int, path: str) -> str:
    proc = run(["git", "-C", str(clone), "show", f":{stage}:{path}"])
    return proc.stdout if proc.returncode == 0 else ""


def resolve_conflicted_file(clone: Path, path: str) -> bool:
    local = git_stage_text(clone, 2, path)
    remote = git_stage_text(clone, 3, path)
    name = Path(path).name
    path_obj = Path(path)
    if path == REGISTRY_FILE:
        merged = merge_synced_registry(local, remote)
    elif name == WORKSTATION_FILE:
        merged = merge_workstation(local, remote)
    elif name == WORKSPACE_FILE:
        merged = merge_workspace(local, remote)
    elif path_obj == Path(".cmds-hub") / "cmd_history":
        merged = merge_lines(local, remote)
    elif path_obj == Path(".skills-hub") / "execute_plugins" or (
        len(path_obj.parts) > 2 and path_obj.parts[:2] == (".skills-hub", "execute_plugins")
    ):
        merged = merge_lines(local, remote)
    else:
        return False
    target = clone / path
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(merged)
    proc = run(["git", "-C", str(clone), "add", path])
    if proc.returncode != 0:
        die(f"failed to stage resolved metadata file: {path}")
    return True


def unmerged_paths(clone: Path) -> list:
    proc = run(["git", "-C", str(clone), "diff", "--name-only", "--diff-filter=U"])
    if proc.returncode != 0:
        return []
    return [line.strip() for line in proc.stdout.splitlines() if line.strip()]


def resolve_metadata_conflicts(clone: Path) -> bool:
    paths = unmerged_paths(clone)
    if not paths:
        return False
    unresolved = []
    for path in paths:
        if not resolve_conflicted_file(clone, path):
            unresolved.append(path)
    if unresolved:
        warn(f"manual conflict resolution required: {', '.join(unresolved)}")
        return False
    remaining = unmerged_paths(clone)
    if remaining:
        warn(f"unresolved metadata conflicts remain: {', '.join(remaining)}")
        return False
    proc = run(["git", "-C", str(clone), "commit", "--no-edit"])
    if proc.returncode != 0:
        die(f"failed to finish metadata merge in {clone}\n{(proc.stderr or proc.stdout).rstrip()}")
    ok("resolved metadata conflicts")
    return True


def metadata_pull_branch(clone: Path) -> str:
    for branch in ("main", "master"):
        if remote_branch_exists(clone, branch):
            return branch
    return ""


def pull_metadata(entry: dict) -> bool:
    clone = Path(entry["clone"]).expanduser().resolve()
    ensure_clone(entry["repo"], clone)
    branch = metadata_pull_branch(clone)
    if not branch:
        ok("remote has no branches")
        return True
    info(f"pulling origin/{branch}")
    proc = run(["git", "-C", str(clone), "pull", "--no-rebase", "origin", branch])
    if proc.returncode == 0:
        ok("pulled")
        return True
    if unmerged_paths(clone):
        return resolve_metadata_conflicts(clone)
    warn((proc.stderr or proc.stdout).rstrip() or "pull failed")
    return False


def remote_branch_exists(clone: Path, branch: str) -> bool:
    proc = run(["git", "-C", str(clone), "ls-remote", "--exit-code", "--heads", "origin", branch])
    return proc.returncode == 0


def current_branch(clone: Path) -> str:
    proc = run(["git", "-C", str(clone), "rev-parse", "--abbrev-ref", "HEAD"])
    branch = proc.stdout.strip() if proc.returncode == 0 else ""
    return "" if branch == "HEAD" else branch


def metadata_push_branch(clone: Path) -> str:
    for branch in ("main", "master"):
        if remote_branch_exists(clone, branch):
            return branch
    branch = current_branch(clone)
    if branch in ("main", "master"):
        return branch
    return "main"


def push_entry(entry: dict) -> bool:
    clone = Path(entry["clone"]).expanduser().resolve()
    ensure_clone(entry["repo"], clone)
    heading(f"push {repo_basename(entry['repo'])}")
    branch = metadata_push_branch(clone)
    proc = run(["git", "-C", str(clone), "push", "-u", "origin", f"HEAD:{branch}"])
    if proc.returncode == 0:
        ok(f"pushed {branch}")
        return True
    warn((proc.stderr or proc.stdout).rstrip() or "push failed")
    return False


def run_entries(mode: str, pick: bool) -> int:
    entries = choose_entries(read_registry(), pick)
    ok_count = 0
    for entry in entries:
        if mode == "sync":
            ok_count += 1 if sync_entry(entry) else 0
        elif mode == "sync_tech_doc":
            ok_count += 1 if sync_tech_doc_entry(entry) else 0
        elif mode == "push":
            ok_count += 1 if push_entry(entry) else 0
    heading("summary")
    info(f"{mode}: {ok_count}/{len(entries)}")
    return 0 if ok_count == len(entries) else 1


USAGE = """\
Usage:
  meta-hub -f <folder> -r <git-repository>
  meta-hub -r <git-repository>
  meta-hub index
  meta-hub index -p <workstation-folder>
  meta-hub sync [pick]
  meta-hub sync_tech_doc [pick]
  meta-hub push [pick]
  meta-hub project
  meta-hub p
  meta-hub repo
  meta-hub r

Options:
  -f <folder>          source folder containing workstation metadata; defaults to .
  -p <folder>          workstation folder to index into metadata
  -r <git-repository> metadata git repository to clone/register
"""


def main() -> None:
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)

    if argv[0] == "index":
        argv.pop(0)
        path = ""
        i = 0
        while i < len(argv):
            arg = argv[i]
            if arg == "-p":
                i += 1
                if i >= len(argv):
                    die("-p requires a workstation folder")
                path = argv[i]
            else:
                die(f"unexpected args for index: {' '.join(argv)}\n\n{USAGE}")
            i += 1
        if path:
            sys.exit(0 if index_entry_path(path) else 1)
        entries = choose_entries(read_registry(), False)
        ok_count = sum(1 for entry in entries if index_entry(entry))
        heading("summary")
        info(f"index: {ok_count}/{len(entries)}")
        sys.exit(0 if ok_count == len(entries) else 1)

    if argv[0] in ("sync", "sync_tech_doc", "push"):
        mode = argv.pop(0)
        pick = False
        if argv == ["pick"]:
            pick = True
        elif argv:
            die(f"unexpected args for {mode}: {' '.join(argv)}\n\n{USAGE}")
        sys.exit(run_entries(mode, pick))

    if argv[0] in ("project", "p", "repo", "r"):
        mode = argv.pop(0)
        if argv:
            die(f"unexpected args for {mode}: {' '.join(argv)}\n\n{USAGE}")
        if mode in ("project", "p"):
            sys.exit(cmd_project())
        sys.exit(cmd_repo())

    folder = "."
    repo = ""
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "-f":
            i += 1
            if i >= len(argv):
                die("-f requires a folder")
            folder = argv[i]
        elif arg == "-r":
            i += 1
            if i >= len(argv):
                die("-r requires a git repository")
            repo = argv[i]
        else:
            die(f"unknown argument: {arg}\n\n{USAGE}")
        i += 1

    if not repo:
        die("-r <git-repository> is required for registration")
    sys.exit(cmd_register(folder, repo))


if __name__ == "__main__":
    main()
