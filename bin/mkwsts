#!/usr/bin/env python3
"""mkwsts - plural workstation registry manager."""

import os
import sys
from pathlib import Path

WORKSTATION_FILE = "workstation.yml"
WORKSTATIONS_FILE = "workstations.yml"
SKIP_DIRS = {"local_workspaces"}

_USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(code: str) -> str:
    return f"\033[{code}m" if _USE_COLOR else ""


RESET = _c("0")
BOLD = _c("1")
RED = _c("31")
GREEN = _c("32")
CYAN = _c("36")


def heading(text: str) -> None:
    print(f"\n{BOLD}{CYAN}=== {text} ==={RESET}", flush=True)


def info(text: str) -> None:
    print(f"  {text}", flush=True)


def ok(text: str) -> None:
    print(f"  {GREEN}ok{RESET} {text}", flush=True)


def die(text: str, code: int = 1) -> None:
    print(f"{RED}error:{RESET} {text}", file=sys.stderr)
    sys.exit(code)


def parse_yml_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == '"' and value[-1] == '"':
        body = value[1:-1]
        return body.replace('\\"', '"').replace("\\\\", "\\")
    return value


def quote_yml_scalar(value: str) -> str:
    text = str(value or "")
    text = text.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{text}"'


def read_workstation_name(yml: Path) -> str:
    for line in yml.read_text().splitlines():
        if line.startswith("name:"):
            return parse_yml_scalar(line.split(":", 1)[1])
    return ""


def should_skip_dir(path: Path, root: Path) -> bool:
    if path == root:
        return False
    return path.name.startswith(".") or path.name in SKIP_DIRS


def discover_workstations(root: Path) -> list:
    entries = []
    candidates = [root]
    candidates.extend(
        child for child in sorted(root.iterdir())
        if child.is_dir() and not should_skip_dir(child, root)
    )

    for cur in candidates:
        yml = cur / WORKSTATION_FILE
        if not yml.is_file():
            continue

        rel_root = "." if cur == root else cur.relative_to(root).as_posix()
        manifest = WORKSTATION_FILE if rel_root == "." else f"{rel_root}/{WORKSTATION_FILE}"
        name = read_workstation_name(yml) or (root.name if rel_root == "." else cur.name)
        entries.append({
            "name": name,
            "root": rel_root,
            "manifest": manifest,
        })
    return sorted(entries, key=lambda item: (item["root"], item["name"]))


def render_workstations_manifest(name: str, workstations: list) -> str:
    lines = ["version: v1", f"name: {quote_yml_scalar(name)}", "workstations:"]
    for workstation in workstations:
        lines.append(f"  - name: {quote_yml_scalar(workstation['name'])}")
        lines.append(f"    root: {quote_yml_scalar(workstation['root'])}")
        lines.append(f"    manifest: {quote_yml_scalar(workstation['manifest'])}")
    return "\n".join(lines) + "\n"


def write_workstations_manifest(yml: Path, name: str, workstations: list) -> bool:
    text = render_workstations_manifest(name, workstations)
    old = yml.read_text() if yml.is_file() else ""
    if old == text:
        return False
    yml.write_text(text)
    return True


def cmd_index() -> int:
    root = Path.cwd().resolve()
    yml = root / WORKSTATIONS_FILE
    workstations = discover_workstations(root)
    changed = write_workstations_manifest(yml, root.name, workstations)

    heading("workstations index")
    for workstation in workstations:
        info(f"{workstation['root']}: {workstation['name']}")

    heading("summary")
    info(f"root:     {BOLD}{root}{RESET}")
    info(f"manifest: {BOLD}{yml}{RESET}")
    info(f"indexed:  {len(workstations)}")
    if changed:
        ok("workstations.yml updated")
    else:
        ok("workstations.yml already current")
    return 0


USAGE = """\
Usage:
  mkwsts index

Modes:
  index      Build or refresh workstations.yml in the current folder by
             scanning the current folder and immediate child folders for
             workstation.yml files. Records workstation-level details only:
             name, root, and manifest.
             Example:
               mkwsts index

Environment:
  NO_COLOR      set to any value to disable colored output.
"""


def parse_args(argv):
    argv = list(argv)
    if not argv:
        print(USAGE)
        sys.exit(0)
    if argv[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)

    mode = argv.pop(0)
    if mode != "index":
        die(f"unknown subcommand: {mode}\n\n{USAGE}")
    if argv:
        die("'index' takes no args")
    return mode


def main() -> None:
    mode = parse_args(sys.argv[1:])
    if mode == "index":
        sys.exit(cmd_index())
    die(f"unknown mode: {mode}")


if __name__ == "__main__":
    main()
