#!/bin/sh
# Wipe every pinned session entry. The sidebar (if open) re-renders to
# (none — prefix+a to pin) immediately.
PIN_FILE="${HOME}/.config/tmux/pinned-sessions"

if [ ! -s "$PIN_FILE" ]; then
	tmux display-message "no pinned sessions to clear"
	exit 0
fi

count="$(awk 'NF' "$PIN_FILE" | wc -l | tr -d ' ')"
: > "$PIN_FILE"
tmux display-message "cleared ${count} pinned session(s)"

# Trigger an in-place redraw of every open sidebar (no respawn = no flicker).
"$HOME/bin/tmux-pin-broadcast-redraw" >/dev/null 2>&1 || :
