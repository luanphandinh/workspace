#!/usr/bin/env python3
from __future__ import annotations

import shutil
import sys
from datetime import datetime
from filecmp import cmp
from pathlib import Path


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print("usage: backup <file_path>", file=sys.stderr)
        return 2

    path = Path(sys.argv[1]).expanduser()
    if not path.is_file():
        print(f"error: file does not exist: {path}", file=sys.stderr)
        return 1

    date = datetime.now().strftime("%Y%m%d")
    prefix = f"{path.name}_{date}_"
    max_counter = -1
    latest_backup = None
    for item in path.parent.glob(f"{prefix}*"):
        suffix = item.name.removeprefix(prefix)
        if suffix.isdigit():
            counter = int(suffix)
            if counter > max_counter:
                max_counter = counter
                latest_backup = item

    if latest_backup is not None and cmp(path, latest_backup, shallow=False):
        print(latest_backup)
        return 0

    backup_path = path.with_name(f"{prefix}{max_counter + 1}")
    shutil.copy2(path, backup_path)
    print(backup_path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
