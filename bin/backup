#!/usr/bin/env python3
from __future__ import annotations

import shutil
import sys
from datetime import datetime
from pathlib import Path


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print("usage: backup <file_path>", file=sys.stderr)
        return 2

    path = Path(sys.argv[1]).expanduser()
    if not path.is_file():
        print(f"error: file does not exist: {path}", file=sys.stderr)
        return 1

    date = datetime.now().strftime("%Y%m%d")
    prefix = f"{path.name}_{date}_"
    max_counter = -1
    for item in path.parent.glob(f"{prefix}*"):
        suffix = item.name.removeprefix(prefix)
        if suffix.isdigit():
            max_counter = max(max_counter, int(suffix))

    backup_path = path.with_name(f"{prefix}{max_counter + 1}")
    shutil.copy2(path, backup_path)
    print(backup_path)
    return 0


if __name__ == "__main__":
    sys.exit(main())
