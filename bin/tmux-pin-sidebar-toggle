#!/bin/sh
# Open or close the pinned-sessions sidebar in EVERY window of EVERY
# session. State:
#   - server-option @pin_sidebar_open  : "1" while open, unset otherwise
#   - window-option @pin_sidebar_pane  : tracks the sidebar pane id per window
# Sidebar pane: 22-col fixed-width left split, full window height (-f),
# running ~/bin/tmux-pin-sidebar.
set -e

state="$(tmux show-options -gqv '@pin_sidebar_open' 2>/dev/null || :)"

if [ "$state" = "1" ]; then
	# --- closing: kill every sidebar pane we have on record ---------------
	tmux list-windows -aF '#{window_id} #{@pin_sidebar_pane}' 2>/dev/null \
		| awk '$2 != "" { print $1, $2 }' \
		| while IFS= read -r line; do
			win="${line%% *}"
			pane="${line##* }"
			if tmux list-panes -t "$win" -F '#{pane_id}' 2>/dev/null \
				| grep -Fxq "$pane"; then
				tmux kill-pane -t "$pane" >/dev/null 2>&1 || :
			fi
			tmux set-option -wu -t "$win" '@pin_sidebar_pane' >/dev/null 2>&1 || :
		done
	tmux set-option -gu '@pin_sidebar_open' >/dev/null 2>&1 || :
	exit 0
fi

# --- opening: split a sidebar into every window of every session ---------
# Prune the pin file first so any pins for now-dead sessions don't show up
# as "✗ dead" placeholders the moment we render. Legacy name-only entries
# also get migrated to ids during the prune.
"$HOME/bin/tmux-pin-prune" >/dev/null 2>&1 || :

# Set the global flag FIRST so tmux-pin-sidebar-attach (which gates on it)
# actually creates panes when we call it below.
tmux set-option -g '@pin_sidebar_open' '1'

tmux list-windows -aF '#{window_id}' 2>/dev/null | while IFS= read -r win; do
	"$HOME/bin/tmux-pin-sidebar-attach" "$win" >/dev/null 2>&1 || :
done
