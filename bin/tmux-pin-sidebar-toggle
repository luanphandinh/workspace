#!/bin/sh
# Open or close a thin (22-col) left sidebar listing pinned tmux sessions, in
# the current window. Pane id is tracked in window-option @pin_sidebar_pane;
# closing kills that pane and clears the option.
set -e

WIN="$(tmux display-message -p '#{window_id}')"
existing="$(tmux show-options -wqv -t "$WIN" '@pin_sidebar_pane' 2>/dev/null || :)"

if [ -n "$existing" ] \
	&& tmux list-panes -t "$WIN" -F '#{pane_id}' 2>/dev/null | grep -Fxq "$existing"; then
	tmux kill-pane -t "$existing"
	tmux set-option -wu -t "$WIN" '@pin_sidebar_pane' >/dev/null 2>&1 || :
	exit 0
fi

# -hb : split horizontally, place the new pane to the left (b = before)
# -l 22: fixed 22-column width
# -d  : keep focus on the original pane
new_pane="$(tmux split-window -hbd -l 22 -t "$WIN" -P -F '#{pane_id}' "$HOME/bin/tmux-pin-sidebar")"
tmux set-option -wt "$WIN" '@pin_sidebar_pane' "$new_pane"
