#!/bin/sh
# Body of the pinned-sessions sidebar. Stays alive; redraws on every line
# received on stdin. Triggers send Enter via `tmux send-keys` so the redraw
# happens in-place вҖ” no respawn-pane, no flicker.
PIN_FILE="${HOME}/.config/tmux/pinned-sessions"

# Suppress terminal echo so trigger keystrokes don't appear in rendered text.
stty -echo 2>/dev/null || :

# Pre-expand the escape sequences once. `printf '%s'` does NOT interpret
# backslash escapes in its arguments, only in the format string вҖ” so we
# materialise them here as actual control bytes and use them via %s.
GREEN="$(printf '\033[1;32m')"
DIM="$(printf '\033[2m')"
RESET="$(printf '\033[0m')"
# Erase-to-end-of-line вҖ” appended to every line so stale text from a
# previous (longer) render is wiped without blanking the whole pane.
EOL="$(printf '\033[K')"

render() {
	{
		# Hide cursor + go home. NO full-screen clear вҖ” that's the source
		# of the visible blank flicker. Each line below ends with EOL to
		# erase residual text; after all content, \033[J wipes any extra
		# trailing lines from a previous longer render.
		printf '\033[?25l\033[H'

		printf 'в”Җв”Җ pinned в”Җв”Җ%s\n%s\n' "$EOL" "$EOL"

		if [ ! -s "$PIN_FILE" ]; then
			printf '(none вҖ” prefix+a to pin)%s\n' "$EOL"
		else
			current="$(tmux display-message -p '#{session_id}' 2>/dev/null)"
			mapping="$(tmux list-sessions -F '#{session_id}|#{session_name}' 2>/dev/null || :)"

			while IFS= read -r entry; do
				[ -z "$entry" ] && continue
				# Resolve entry вҶ’ (id, name). Tolerate legacy name entries.
				case "$entry" in
					'$'[0-9]*)
						id="$entry"
						name="$(printf '%s\n' "$mapping" \
							| awk -F'|' -v id="$id" '$1==id{print $2; exit}')"
						;;
					*)
						name="$entry"
						id="$(printf '%s\n' "$mapping" \
							| awk -F'|' -v n="$name" '$2==n{print $1; exit}')"
						;;
				esac

				if [ -z "$id" ] || [ -z "$name" ]; then
					printf "${DIM}вң— %s (dead)${RESET}%s\n" "${name:-$entry}" "$EOL"
					continue
				fi

				# Session header вҖ” green if this is THIS sidebar's session.
				if [ "$id" = "$current" ]; then
					printf "${GREEN}в–ё %s${RESET}%s\n" "$name" "$EOL"
				else
					printf '  %s%s\n' "$name" "$EOL"
				fi

				# Children вҖ” windows in that session. 4-col indent. Last
				# entry uses `в””`, others use `в”ң`. The active window in each
				# session gets a green в–ё in place of the tree char.
				tmux list-windows -t "$id" -F '#{window_active}|#{window_name}' 2>/dev/null \
					| awk -F'|' -v g="$GREEN" -v r="$RESET" -v eol="$EOL" '
						{ lines[NR] = $0 }
						END {
							n = NR
							for (i = 1; i <= n; i++) {
								split(lines[i], p, "|")
								active = p[1]
								wname  = p[2]
								tree   = (i == n) ? "в””" : "в”ң"
								if (active == 1)
									printf "    %sв–ё %s%s%s\n", g, wname, r, eol
								else
									printf "    %s %s%s\n", tree, wname, eol
							}
						}
					'
			done < "$PIN_FILE"
		fi

		# Aligned help: 8-col key field + 1 space + description.
		# `вҢҘвҢҳвҶ‘/вҶ“` / `вҢҘвҢҳвҶҗ/вҶ’` are 5 visible cols, padded to 8 with 3 spaces.
		printf '\n%sв”Җв”Җ%s\n' "$EOL" "$EOL"
		printf 'prefix+a pin/unpin%s\n' "$EOL"
		printf 'prefix+A toggle%s\n' "$EOL"
		printf 'prefix+e clear all%s\n' "$EOL"
		printf 'вҢҘвҢҳвҶ‘/вҶ“    cycle%s\n' "$EOL"
		printf 'вҢҘвҢҳвҶҗ/вҶ’    window%s\n' "$EOL"

		# Wipe any stale content below the new render (left over from a
		# previous taller render вҖ” e.g. dropped pin, closed window).
		printf '\033[J\033[?25h'
	}
}

render

# Block waiting for stdin; each Enter sent by tmux-pin-broadcast-redraw
# unblocks `read` and triggers a re-render. When the pane is killed,
# `read` returns non-zero and we exit cleanly.
while IFS= read -r _; do
	render
done
