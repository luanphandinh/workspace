#!/bin/sh
# Toggle pin status of the current tmux session.
# Pin file stores session IDs ($1, $2 …) — stable across rename. Display
# names are looked up dynamically by the sidebar / cycle scripts.
set -e

PIN_FILE="${HOME}/.config/tmux/pinned-sessions"
mkdir -p "$(dirname "$PIN_FILE")"
[ -f "$PIN_FILE" ] || : > "$PIN_FILE"

# --- one-shot migration: any legacy name-based entries → ids -------------
# Older versions of this script stored session names. Walk the file once;
# rewrite each non-`$N` line to the matching session id (or drop it if no
# live session has that name).
if [ -s "$PIN_FILE" ] && grep -qv '^\$[0-9]\+' "$PIN_FILE"; then
	mapping="$(tmux list-sessions -F '#{session_name}|#{session_id}' 2>/dev/null || :)"
	tmp="$(mktemp)"
	while IFS= read -r line; do
		[ -z "$line" ] && continue
		case "$line" in
			'$'[0-9]*) printf '%s\n' "$line" >> "$tmp" ;;
			*)
				id="$(printf '%s\n' "$mapping" \
					| awk -F'|' -v n="$line" '$1==n{print $2; exit}')"
				[ -n "$id" ] && printf '%s\n' "$id" >> "$tmp"
				;;
		esac
	done < "$PIN_FILE"
	mv "$tmp" "$PIN_FILE"
fi

id="$(tmux display-message -p '#{session_id}')"
name="$(tmux display-message -p '#S')"

if grep -Fxq -- "$id" "$PIN_FILE" 2>/dev/null; then
	tmp="$(mktemp)"
	grep -Fxv -- "$id" "$PIN_FILE" > "$tmp" 2>/dev/null || :
	mv "$tmp" "$PIN_FILE"
	tmux display-message "unpinned: $name"
else
	printf '%s\n' "$id" >> "$PIN_FILE"
	tmux display-message "pinned: $name"
fi

# Trigger an in-place redraw of every open sidebar (no respawn = no flicker).
"$HOME/bin/tmux-pin-broadcast-redraw" >/dev/null 2>&1 || :
