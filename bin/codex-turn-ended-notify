#!/bin/sh
set -eu

notify_title="${AGENT_NOTIFY_TITLE:-${CODEX_NOTIFY_TITLE:-Codex}}"
notify_group="${AGENT_NOTIFY_GROUP:-agent-notify-$notify_title}"
activate_app="${AGENT_NOTIFY_ACTIVATE_APP:-${CODEX_NOTIFY_ACTIVATE_APP:-}}"

get_tmux_cmd() {
	if [ -n "${TMUX_BIN:-}" ]; then
		printf '%s\n' "$TMUX_BIN"
		return 0
	fi
	command -v tmux 2>/dev/null
}

tmux_format() {
	tmux_cmd="$1"
	pane="$2"
	format="$3"
	if [ -n "$pane" ]; then
		"$tmux_cmd" display-message -p -t "$pane" "$format" 2>/dev/null || :
	else
		"$tmux_cmd" display-message -p "$format" 2>/dev/null || :
	fi
}

usable_tmux_pane() {
	tmux_cmd="$1"
	pane="$2"
	[ -n "$pane" ] || return 1

	pane_id="$(tmux_format "$tmux_cmd" "$pane" '#{pane_id}')"
	target_window="$(tmux_format "$tmux_cmd" "$pane" '#{session_name}:#{window_index}')"
	case "$pane_id" in
		%*) ;;
		*) return 1 ;;
	esac
	case "$target_window" in
		"" | ":" | ":." | ".") return 1 ;;
	esac

	printf '%s\n' "$pane_id"
}

resolve_tmux_pane() {
	tmux_cmd="$1"
	if [ -n "${TMUX_PANE:-}" ]; then
		resolved_pane="$(usable_tmux_pane "$tmux_cmd" "$TMUX_PANE" || :)"
		if [ -n "$resolved_pane" ]; then
			printf '%s\n' "$resolved_pane"
			return 0
		fi
	fi

	current_pane="$(tmux_format "$tmux_cmd" "" '#{pane_id}')"
	case "$current_pane" in
		%*) usable_tmux_pane "$tmux_cmd" "$current_pane" || : ;;
	esac
}

jump_to_tmux_pane() {
	pane="${1:-}"
	[ -n "$pane" ] || exit 0
	tmux_cmd="$(get_tmux_cmd || :)"
	[ -n "$tmux_cmd" ] || exit 0

	target_pane="$(usable_tmux_pane "$tmux_cmd" "$pane" || :)"
	[ -n "$target_pane" ] || exit 0
	target_window="$(tmux_format "$tmux_cmd" "$target_pane" '#{session_name}:#{window_index}')"
	target_session="$(tmux_format "$tmux_cmd" "$target_pane" '#{session_name}')"
	case "$target_window" in
		"" | ":" | ":." | ".") exit 0 ;;
	esac

	"$tmux_cmd" select-window -t "$target_window" >/dev/null 2>&1 || :
	"$tmux_cmd" select-pane -t "$target_pane" >/dev/null 2>&1 || :
	"$tmux_cmd" display-message -t "$target_pane" "$notify_title notification focused #{session_name}:#{window_index}.#{pane_index}" >/dev/null 2>&1 || :

	if [ -n "$target_session" ]; then
		tab="$(printf '\t')"
		client_count="$("$tmux_cmd" list-clients 2>/dev/null | wc -l | tr -d ' ')"
		"$tmux_cmd" list-clients -F '#{client_tty}	#{session_name}' 2>/dev/null |
			while IFS="$tab" read -r client_tty client_session; do
				[ -n "$client_tty" ] || continue
				if [ "$client_session" = "$target_session" ] || [ "$client_count" = "1" ]; then
					"$tmux_cmd" switch-client -c "$client_tty" -t "$target_pane" >/dev/null 2>&1 || :
				fi
			done
	fi

	if [ -n "$activate_app" ] && command -v open >/dev/null 2>&1; then
		open -a "$activate_app" >/dev/null 2>&1 || :
	elif [ -n "$activate_app" ] && command -v osascript >/dev/null 2>&1; then
		osascript \
			-e 'on run argv' \
			-e 'tell application (item 1 of argv) to activate' \
			-e 'end run' \
			"$activate_app" >/dev/null 2>&1 || :
	fi
}

shell_quote() {
	printf "'%s'" "$(printf "%s" "$1" | sed "s/'/'\\\\''/g")"
}

if [ "${1:-}" = "--jump-tmux" ]; then
	jump_to_tmux_pane "${2:-}"
	exit 0
fi

payload="${1:-}"
if [ -z "$payload" ] && [ ! -t 0 ]; then
	payload="$(cat)"
fi

cwd="$(pwd -P 2>/dev/null || pwd)"
case "$cwd" in
	"$HOME") display_path="~" ;;
	"$HOME"/*) display_path="~/${cwd#"$HOME"/}" ;;
	*) display_path="$cwd" ;;
esac
message="Task complete: $display_path"

script_path="$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd -P)/$(basename "$0")"

if command -v terminal-notifier >/dev/null 2>&1; then
	tmux_cmd="$(get_tmux_cmd || :)"
	notify_pane=""
	if [ -n "$tmux_cmd" ]; then
		notify_pane="$(resolve_tmux_pane "$tmux_cmd")"
	fi

	if [ -n "$notify_pane" ]; then
		tmux_target="$(tmux_format "$tmux_cmd" "$notify_pane" '#{session_name}:#{window_index}.#{pane_index}')"
		click_cmd="$(shell_quote "$script_path") --jump-tmux $(shell_quote "$notify_pane")"
		if [ -n "$tmux_cmd" ]; then
			click_cmd="TMUX_BIN=$(shell_quote "$tmux_cmd") $click_cmd"
		fi
		if [ -n "$activate_app" ]; then
			click_cmd="AGENT_NOTIFY_ACTIVATE_APP=$(shell_quote "$activate_app") $click_cmd"
		fi
		if [ -n "${TMUX:-}" ]; then
			click_cmd="TMUX=$(shell_quote "$TMUX") $click_cmd"
		fi
		if [ -n "$tmux_target" ]; then
			terminal-notifier -title "$notify_title" -message "$message" -subtitle "tmux $tmux_target" -group "$notify_group" -ignoreDnD -execute "$click_cmd" >/dev/null 2>&1 || :
		else
			terminal-notifier -title "$notify_title" -message "$message" -group "$notify_group" -ignoreDnD -execute "$click_cmd" >/dev/null 2>&1 || :
		fi
	else
		terminal-notifier -title "$notify_title" -message "$message" -group "$notify_group" -ignoreDnD >/dev/null 2>&1 || :
	fi
elif command -v osascript >/dev/null 2>&1; then
	osascript \
		-e 'on run argv' \
		-e 'display notification (item 1 of argv) with title (item 2 of argv)' \
		-e 'end run' \
		"$message" "$notify_title" >/dev/null 2>&1 || :
fi

if [ -n "${TMUX:-}" ]; then
	tmux_cmd="$(get_tmux_cmd || :)"
	if [ -n "$tmux_cmd" ]; then
		"$tmux_cmd" display-message "$notify_title $message" >/dev/null 2>&1 || :
		notify_pane="$(resolve_tmux_pane "$tmux_cmd")"
	else
		notify_pane=""
	fi
	if [ -n "$notify_pane" ]; then
		pane_tty="$(tmux_format "$tmux_cmd" "$notify_pane" '#{pane_tty}')"
		if [ -n "$pane_tty" ] && [ -w "$pane_tty" ]; then
			printf '\a' >"$pane_tty" 2>/dev/null || :
		fi
	fi
fi

if tty_path="$(tty 2>/dev/null)" && [ "$tty_path" != "not a tty" ]; then
	printf '\a' >"$tty_path" 2>/dev/null || :
fi
