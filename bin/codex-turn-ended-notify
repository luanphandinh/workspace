#!/bin/sh
set -eu

jump_to_tmux_pane() {
	pane="${1:-}"
	[ -n "$pane" ] || exit 0
	tmux_cmd="${TMUX_BIN:-tmux}"
	if [ "$tmux_cmd" = "tmux" ]; then
		command -v tmux >/dev/null 2>&1 || exit 0
	fi

	target_window="$("$tmux_cmd" display-message -p -t "$pane" '#{session_name}:#{window_index}' 2>/dev/null || :)"
	target_session="$("$tmux_cmd" display-message -p -t "$pane" '#{session_name}' 2>/dev/null || :)"
	target_pane="$("$tmux_cmd" display-message -p -t "$pane" '#{pane_id}' 2>/dev/null || :)"
	[ -n "$target_window" ] || exit 0
	[ -n "$target_pane" ] || target_pane="$pane"

	"$tmux_cmd" select-window -t "$target_window" >/dev/null 2>&1 || :
	"$tmux_cmd" select-pane -t "$target_pane" >/dev/null 2>&1 || :
	"$tmux_cmd" display-message -t "$target_pane" "Codex notification focused #{session_name}:#{window_index}.#{pane_index}" >/dev/null 2>&1 || :

	if [ -n "$target_session" ]; then
		tab="$(printf '\t')"
		client_count="$("$tmux_cmd" list-clients 2>/dev/null | wc -l | tr -d ' ')"
		"$tmux_cmd" list-clients -F '#{client_tty}	#{session_name}' 2>/dev/null |
			while IFS="$tab" read -r client_tty client_session; do
				[ -n "$client_tty" ] || continue
				if [ "$client_session" = "$target_session" ] || [ "$client_count" = "1" ]; then
					"$tmux_cmd" switch-client -c "$client_tty" -t "$target_pane" >/dev/null 2>&1 || :
				fi
			done
	fi

	if [ -n "${CODEX_NOTIFY_ACTIVATE_APP:-}" ] && command -v osascript >/dev/null 2>&1; then
		osascript \
			-e 'on run argv' \
			-e 'tell application (item 1 of argv) to activate' \
			-e 'end run' \
			"$CODEX_NOTIFY_ACTIVATE_APP" >/dev/null 2>&1 || :
	fi
}

shell_quote() {
	printf "'%s'" "$(printf "%s" "$1" | sed "s/'/'\\\\''/g")"
}

if [ "${1:-}" = "--jump-tmux" ]; then
	jump_to_tmux_pane "${2:-}"
	exit 0
fi

payload="${1:-}"
if [ -z "$payload" ] && [ ! -t 0 ]; then
	payload="$(cat)"
fi

cwd="$(pwd -P 2>/dev/null || pwd)"
case "$cwd" in
	"$HOME") display_path="~" ;;
	"$HOME"/*) display_path="~/${cwd#"$HOME"/}" ;;
	*) display_path="$cwd" ;;
esac
message="Task complete: $display_path"

config_dir="${CODEX_HOME:-$HOME/.codex}"
config_file="$config_dir/config.toml"
script_path="$(CDPATH= cd "$(dirname "$0")" 2>/dev/null && pwd -P)/$(basename "$0")"

if [ -n "$payload" ] && [ -r "$config_file" ] && command -v python3 >/dev/null 2>&1; then
	python3 - "$config_file" "$script_path" "$payload" <<'PY' >/dev/null 2>&1 || :
import ast
import os
import shutil
import subprocess
import sys

config_file, script_path, payload = sys.argv[1:]


def notify_from_toml(path):
    try:
        import tomllib

        with open(path, "rb") as file:
            value = tomllib.load(file).get("notify")
        if isinstance(value, list):
            return [str(item) for item in value]
    except Exception:
        pass
    return []


def notify_from_literal(path):
    try:
        lines = open(path, encoding="utf-8").read().splitlines()
    except OSError:
        return []

    collecting = False
    chunks = []
    for raw_line in lines:
        line = raw_line.strip()
        if not collecting:
            if "=" not in line:
                continue
            key, value = line.split("=", 1)
            if key.strip() != "notify":
                continue
            chunks.append(value.strip())
            collecting = "]" not in value
        else:
            chunks.append(line)
            collecting = "]" not in line

        if not collecting and chunks:
            break

    if not chunks:
        return []

    try:
        value = ast.literal_eval(" ".join(chunks))
    except Exception:
        return []
    if isinstance(value, (list, tuple)):
        return [str(item) for item in value]
    return []


notify = notify_from_toml(config_file) or notify_from_literal(config_file)
if not notify:
    raise SystemExit(0)

notify[0] = os.path.expandvars(os.path.expanduser(notify[0]))
current = os.path.realpath(script_path)
target = os.path.realpath(notify[0])
if target == current:
    raise SystemExit(0)

if os.sep in notify[0]:
    if not os.access(notify[0], os.X_OK):
        raise SystemExit(0)
elif shutil.which(notify[0]) is None:
    raise SystemExit(0)

subprocess.run(notify + [payload], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
PY
fi

if command -v terminal-notifier >/dev/null 2>&1; then
	if [ -n "${TMUX_PANE:-}" ]; then
		tmux_target=""
		if tmux_target="$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)"; then
			:
		else
			tmux_target=""
		fi
		click_cmd="$(shell_quote "$script_path") --jump-tmux $(shell_quote "$TMUX_PANE")"
		if tmux_bin="$(command -v tmux 2>/dev/null)"; then
			click_cmd="TMUX_BIN=$(shell_quote "$tmux_bin") $click_cmd"
		fi
		if [ -n "${TMUX:-}" ]; then
			click_cmd="TMUX=$(shell_quote "$TMUX") $click_cmd"
		fi
		if [ -n "$tmux_target" ]; then
			terminal-notifier -title "Codex" -message "$message" -subtitle "tmux $tmux_target" -execute "$click_cmd" >/dev/null 2>&1 || :
		else
			terminal-notifier -title "Codex" -message "$message" -execute "$click_cmd" >/dev/null 2>&1 || :
		fi
	else
		terminal-notifier -title "Codex" -message "$message" >/dev/null 2>&1 || :
	fi
elif command -v osascript >/dev/null 2>&1; then
	osascript \
		-e 'on run argv' \
		-e 'display notification (item 1 of argv) with title "Codex"' \
		-e 'end run' \
		"$message" >/dev/null 2>&1 || :
fi

if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
	tmux display-message "Codex $message" >/dev/null 2>&1 || :
	if [ -n "${TMUX_PANE:-}" ]; then
		pane_tty="$(tmux display-message -p -t "$TMUX_PANE" '#{pane_tty}' 2>/dev/null || :)"
		if [ -n "$pane_tty" ] && [ -w "$pane_tty" ]; then
			printf '\a' >"$pane_tty" 2>/dev/null || :
		fi
	fi
fi

if tty_path="$(tty 2>/dev/null)" && [ "$tty_path" != "not a tty" ]; then
	printf '\a' >"$tty_path" 2>/dev/null || :
fi
