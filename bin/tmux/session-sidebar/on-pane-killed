#!/bin/sh
# Called from tmux's after-kill-pane hook. Re-pins the sidebar to its
# canonical width (if the window has one) and lets tmux's natural reflow
# absorb the freed space across the rest of the layout — preserving the
# user's split topology (vertical, horizontal, mixed).
#
# Operates ONLY on the window whose id is passed as $1. tmux substitutes
# #{window_id} in the hook command, so the script targets surgically
# instead of touching every window in the server.
#
# We deliberately do NOT call `select-layout` here. select-layout
# (`tiled`, `even-horizontal`, etc.) collapses the existing topology
# into a uniform shape — the user explicitly does not want that.
WIDTH=22

win="${1:-}"
[ -z "$win" ] && exit 0

sidebar="$(tmux list-panes -t "$win" -F '#{pane_id} #{@pin_sidebar}' 2>/dev/null \
	| awk '$2 == "1" { print $1; exit }')"

if [ -n "$sidebar" ]; then
	tmux resize-pane -t "$sidebar" -x "$WIDTH" >/dev/null 2>&1 || :
fi
