#!/bin/sh
# Re-fit every window to the current client viewport AND snap each
# pinned sidebar back to the configured width without rearranging panes.
# Layout topology (which splits are vertical vs horizontal, weights
# between siblings) is preserved end-to-end:
#   - fit-windows  → resize-window -x W -y H per window. tmux
#                             scales the existing pane structure
#                             proportionally to the new dimensions.
#   - resize-pane -x WIDTH  → force the sidebar pane back to canonical
#                             width; tmux redistributes the freed/absorbed
#                             columns across siblings using existing weights.
# No kill+recreate, no select-layout. Both would clobber topology.
WIDTH="$(tmux show-options -gqv '@pin_sidebar_width' 2>/dev/null || :)"
case "$WIDTH" in
	''|*[!0-9]*) WIDTH=20 ;;
esac

# 1. Fit every window to the live viewport (handles inactive sessions
#    whose cached size diverged from the current client).
"$HOME/bin/tmux/session-sidebar/fit-windows" >/dev/null 2>&1 || :

# 2. Snap every tagged sidebar pane back to configured width.
tmux list-panes -aF '#{pane_id} #{@pin_sidebar}' 2>/dev/null \
	| awk '$2 == "1" { print $1 }' \
	| while IFS= read -r pane; do
		[ -z "$pane" ] && continue
		tmux resize-pane -t "$pane" -x "$WIDTH" >/dev/null 2>&1 || :
	done

# 3. Repaint sidebar contents (line widths may have changed).
"$HOME/bin/tmux/session-sidebar/broadcast-redraw" >/dev/null 2>&1 || :

# 4. Force a full client repaint to clear any `....` placeholder cells
#    where the cached layout didn't match the new viewport.
tmux refresh-client >/dev/null 2>&1 || :

tmux display-message "viewport re-fit, sidebars snapped to ${WIDTH} cols"
