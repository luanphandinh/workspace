#!/usr/bin/env python3
"""mkwst — parent-folder workstation index manager.

A workstation is a folder containing sibling git repos, optional read-only
external repos under `_external/`, and a `workstation.yml` index.
"""

import concurrent.futures
import os
import shutil
import subprocess
import sys
from pathlib import Path

WS_CONTAINER = "local_workspaces"
WORKSTATION_FILE = "workstation.yml"
EXTERNAL_DIR = "_external"

# ---------------------------------------------------------------------------
# Colored logging. Disabled when stdout isn't a TTY or NO_COLOR is set, so pipes
# and CI logs stay clean.
# ---------------------------------------------------------------------------
_USE_COLOR = sys.stdout.isatty() and os.environ.get("NO_COLOR") is None


def _c(code: str) -> str:
    return f"\033[{code}m" if _USE_COLOR else ""


RESET = _c("0")
BOLD = _c("1")
DIM = _c("2")
RED = _c("31")
GREEN = _c("32")
YELLOW = _c("33")
BLUE = _c("34")
CYAN = _c("36")


def heading(text: str) -> None:
    # flush=True keeps our stdout interleaved correctly with subprocess stderr
    # when the final output is redirected (where stdout would otherwise become
    # block-buffered and git messages leak above our headings).
    print(f"\n{BOLD}{CYAN}=== {text} ==={RESET}", flush=True)


def info(text: str) -> None:
    print(f"  {text}", flush=True)


def ok(text: str) -> None:
    print(f"  {GREEN}✓{RESET} {text}", flush=True)


def warn(text: str) -> None:
    print(f"  {YELLOW}!{RESET} {text}", flush=True)


def fail(text: str) -> None:
    print(f"  {RED}✗{RESET} {text}", flush=True)


def die(text: str, code: int = 1) -> None:
    print(f"{RED}error:{RESET} {text}", file=sys.stderr)
    sys.exit(code)


def has_cmd(name: str) -> bool:
    return shutil.which(name) is not None


# ---------------------------------------------------------------------------
# Parallel per-repo runner. Each worker writes to its own RepoLog instead of
# stdout; once all workers finish, logs are printed in submission order so
# output reads like the serial version — no interleaving, no flickering.
# ---------------------------------------------------------------------------
class RepoLog:
    """A buffered logger. Same methods as the top-level log helpers but
    accumulates lines so they can be flushed together at the end."""

    def __init__(self) -> None:
        self._lines: list = []

    def heading(self, t: str) -> None: self._lines.append(("heading", t))
    def info(self, t: str) -> None: self._lines.append(("info", t))
    def ok(self, t: str) -> None: self._lines.append(("ok", t))
    def warn(self, t: str) -> None: self._lines.append(("warn", t))
    def fail(self, t: str) -> None: self._lines.append(("fail", t))
    def raw(self, t: str) -> None: self._lines.append(("raw", t))

    def render(self) -> None:
        for kind, text in self._lines:
            if kind == "heading": heading(text)
            elif kind == "info": info(text)
            elif kind == "ok": ok(text)
            elif kind == "warn": warn(text)
            elif kind == "fail": fail(text)
            elif kind == "raw":
                if text:
                    print(text, flush=True)


def _draw_progress_bar(done: int, total: int) -> None:
    """Draw/redraw a single-line progress bar in place using \r. Caller is
    responsible for clearing the line when done."""
    bar_width = 30
    filled = int(bar_width * done / total) if total else bar_width
    bar = "█" * filled + "░" * (bar_width - filled)
    pct = int(done / total * 100) if total else 100
    sys.stdout.write(f"\r  [{CYAN}{bar}{RESET}] {done}/{total} ({pct}%)")
    sys.stdout.flush()


def _clear_progress_line() -> None:
    # 60 spaces clears a 30-char bar plus the "N/M (P%)" counter safely.
    sys.stdout.write("\r" + " " * 60 + "\r")
    sys.stdout.flush()


def run_in_parallel(items, worker, max_workers: int = 8) -> list:
    """Call worker(item, log) for each item in a thread pool, then flush each
    RepoLog in submission order. Returns the list of worker return values,
    one per item in the same order.

    Shows a live progress bar while workers run, as long as stdout is a TTY
    and there are enough items to make it worthwhile (>=2). The bar is drawn
    in-place with \\r and cleared before the buffered logs are rendered, so
    the final output still reads cleanly."""
    if not items:
        return []
    n = min(max_workers, len(items))
    logs = [RepoLog() for _ in items]
    results: list = [None] * len(items)

    show_bar = sys.stdout.isatty() and len(items) >= 2
    if show_bar:
        _draw_progress_bar(0, len(items))

    with concurrent.futures.ThreadPoolExecutor(max_workers=n) as ex:
        futs = {ex.submit(worker, item, logs[i]): i for i, item in enumerate(items)}
        done = 0
        for fut in concurrent.futures.as_completed(futs):
            i = futs[fut]
            try:
                results[i] = fut.result()
            except Exception as e:
                results[i] = None
                logs[i].fail(f"worker crashed: {e}")
            done += 1
            if show_bar:
                _draw_progress_bar(done, len(items))

    if show_bar:
        _clear_progress_line()

    for log in logs:
        log.render()
    return results


# ---------------------------------------------------------------------------
# Subprocess helpers
# ---------------------------------------------------------------------------
def run(cmd, cwd=None, capture=True):
    return subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        capture_output=capture,
        text=True,
    )


def parse_yml_scalar(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == '"' and value[-1] == '"':
        body = value[1:-1]
        return body.replace('\\"', '"').replace("\\\\", "\\")
    return value


def quote_yml_scalar(value: str) -> str:
    text = str(value or "")
    text = text.replace("\\", "\\\\").replace('"', '\\"')
    return f'"{text}"'


def read_workstation_manifest(yml: Path) -> dict:
    data = {"version": "v1", "name": "", "repos": [], "_external": {"repos": []}}
    section = ""
    current_repo = None
    if not yml.is_file():
        return data

    for line in yml.read_text().splitlines():
        if line.startswith("version:"):
            data["version"] = parse_yml_scalar(line.split(":", 1)[1]) or "v1"
            section = ""
        elif line.startswith("name:"):
            data["name"] = parse_yml_scalar(line.split(":", 1)[1])
            section = ""
        elif line.startswith("repos:"):
            section = "repos"
            current_repo = None
        elif line.startswith("_external:"):
            section = "_external"
            current_repo = None
        elif section == "_external" and line.startswith("  repos:"):
            section = "_external.repos"
            current_repo = None
        elif section == "repos" and line.startswith("  - name:"):
            current_repo = {
                "name": parse_yml_scalar(line.split(":", 1)[1]),
                "path": "",
                "remote": "",
                "remote_url": "",
                "upstream": "",
                "branch": "",
            }
            data["repos"].append(current_repo)
        elif section == "repos" and current_repo is not None and line.startswith("    "):
            key, sep, value = line.strip().partition(":")
            if sep and key in current_repo:
                current_repo[key] = parse_yml_scalar(value)
        elif section == "_external.repos" and line.startswith("    - name:"):
            current_repo = {
                "name": parse_yml_scalar(line.split(":", 1)[1]),
                "path": "",
                "remote": "",
                "remote_url": "",
                "upstream": "",
                "branch": "",
            }
            data["_external"]["repos"].append(current_repo)
        elif section == "_external.repos" and current_repo is not None and line.startswith("      "):
            key, sep, value = line.strip().partition(":")
            if sep and key in current_repo:
                current_repo[key] = parse_yml_scalar(value)
    return data


def normalize_workstation_repos(repos: list) -> list:
    out = []
    seen = set()
    for repo in repos or []:
        if not isinstance(repo, dict):
            continue
        item = {
            "name": str(repo.get("name") or "").strip(),
            "path": str(repo.get("path") or "").strip(),
            "remote": str(repo.get("remote") or "").strip(),
            "remote_url": str(repo.get("remote_url") or "").strip(),
            "upstream": str(repo.get("upstream") or "").strip(),
            "branch": str(repo.get("branch") or "").strip(),
        }
        if not item["name"]:
            continue
        if not item["path"]:
            item["path"] = item["name"]
        key = item["path"]
        if key in seen:
            continue
        seen.add(key)
        out.append(item)
    return sorted(out, key=lambda r: (r["path"], r["name"]))


def render_workstation_manifest(name: str, repos: list, external_repos: list = None) -> str:
    lines = ["version: v1", f"name: {quote_yml_scalar(name)}", "repos:"]
    for repo in normalize_workstation_repos(repos):
        lines.append(f"  - name: {quote_yml_scalar(repo['name'])}")
        lines.append(f"    path: {quote_yml_scalar(repo['path'])}")
        lines.append(f"    remote: {quote_yml_scalar(repo['remote'])}")
        lines.append(f"    remote_url: {quote_yml_scalar(repo['remote_url'])}")
        lines.append(f"    upstream: {quote_yml_scalar(repo['upstream'])}")
        lines.append(f"    branch: {quote_yml_scalar(repo['branch'])}")
    normalized_external = normalize_workstation_repos(external_repos or [])
    if normalized_external:
        lines.append("_external:")
        lines.append("  repos:")
        for repo in normalized_external:
            lines.append(f"    - name: {quote_yml_scalar(repo['name'])}")
            lines.append(f"      path: {quote_yml_scalar(repo['path'])}")
            lines.append(f"      remote: {quote_yml_scalar(repo['remote'])}")
            lines.append(f"      remote_url: {quote_yml_scalar(repo['remote_url'])}")
            lines.append(f"      upstream: {quote_yml_scalar(repo['upstream'])}")
            lines.append(f"      branch: {quote_yml_scalar(repo['branch'])}")
    return "\n".join(lines) + "\n"


def write_workstation_manifest(yml: Path, name: str, repos: list, external_repos: list = None) -> bool:
    text = render_workstation_manifest(name, repos, external_repos)
    old = yml.read_text() if yml.is_file() else ""
    if old == text:
        return False
    yml.write_text(text)
    return True

def git_output(repo: Path, args: list) -> str:
    proc = run(["git", "-C", str(repo), *args])
    if proc.returncode != 0:
        return ""
    return proc.stdout.strip()


def remote_names(repo: Path) -> list:
    out = git_output(repo, ["remote"])
    return [line.strip() for line in out.splitlines() if line.strip()]


def preferred_remote(repo: Path, upstream: str) -> str:
    if "/" in upstream:
        return upstream.split("/", 1)[0]
    remotes = remote_names(repo)
    if "origin" in remotes:
        return "origin"
    return remotes[0] if remotes else ""


def remote_url(repo: Path, remote: str) -> str:
    if not remote:
        return ""
    return git_output(repo, ["remote", "get-url", remote])


# index mode: build/update workstation.yml for the current parent folder.
# Scans immediate child git repos, plus immediate git repos under _external/,
# and refreshes remote/upstream/current-branch metadata for existing entries.
# ---------------------------------------------------------------------------
def is_git_repo_path(path: Path) -> bool:
    return path.is_dir() and (path / ".git").exists()


def discover_workstation_repos(root: Path) -> list:
    skipped = {WS_CONTAINER, "tech_doc", EXTERNAL_DIR}
    repos = []
    for child in sorted(p for p in root.iterdir() if p.is_dir()):
        if child.name.startswith(".") or child.name in skipped:
            continue
        if is_git_repo_path(child):
            repos.append(child)
    return repos


def discover_external_workstation_repos(root: Path) -> list:
    external_root = root / EXTERNAL_DIR
    if not external_root.is_dir():
        return []
    return sorted(child for child in external_root.iterdir() if child.is_dir() and is_git_repo_path(child))


def workstation_repo_record(root: Path, repo: Path) -> dict:
    branch = git_output(repo, ["rev-parse", "--abbrev-ref", "HEAD"])
    upstream = git_output(repo, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"])
    remote = preferred_remote(repo, upstream)
    try:
        rel_path = repo.relative_to(root).as_posix()
    except ValueError:
        rel_path = repo.name
    return {
        "name": repo.name,
        "path": rel_path,
        "remote": remote,
        "remote_url": remote_url(repo, remote),
        "upstream": upstream,
        "branch": branch,
    }


def cmd_index() -> int:
    root = Path.cwd().resolve()
    yml = root / WORKSTATION_FILE
    data = read_workstation_manifest(yml)
    workstation_name = data["name"] or root.name
    indexed = normalize_workstation_repos(data["repos"])
    external_indexed = normalize_workstation_repos(data.get("_external", {}).get("repos", []))
    by_path = {repo["path"]: repo for repo in indexed}
    by_name = {repo["name"]: repo for repo in indexed}
    external_by_path = {repo["path"]: repo for repo in external_indexed}
    external_by_name = {repo["name"]: repo for repo in external_indexed}

    added = updated = unchanged = missing_upstream = 0
    external_added = external_updated = external_unchanged = external_missing_upstream = 0
    discovered = discover_workstation_repos(root)
    external_discovered = discover_external_workstation_repos(root)

    heading("workstation index")
    for repo_path in discovered:
        record = workstation_repo_record(root, repo_path)
        current = by_path.get(record["path"]) or by_name.get(record["name"])
        if current is None:
            indexed.append(record)
            by_path[record["path"]] = record
            by_name[record["name"]] = record
            added += 1
            ok(f"added {record['path']}")
        elif any(current.get(k, "") != record[k] for k in record):
            current.update(record)
            updated += 1
            ok(f"updated {record['path']}")
        else:
            unchanged += 1
            info(f"{record['path']}: already indexed")

        if not record["upstream"]:
            missing_upstream += 1
            warn(f"{record['path']}: no upstream branch configured")

    if external_discovered:
        heading("external index")
    for repo_path in external_discovered:
        record = workstation_repo_record(root, repo_path)
        current = external_by_path.get(record["path"]) or external_by_name.get(record["name"])
        if current is None:
            external_indexed.append(record)
            external_by_path[record["path"]] = record
            external_by_name[record["name"]] = record
            external_added += 1
            ok(f"added {record['path']}")
        elif any(current.get(k, "") != record[k] for k in record):
            current.update(record)
            external_updated += 1
            ok(f"updated {record['path']}")
        else:
            external_unchanged += 1
            info(f"{record['path']}: already indexed")

        if not record["upstream"]:
            external_missing_upstream += 1
            warn(f"{record['path']}: no upstream branch configured")

    existing_paths = {repo["path"] for repo in normalize_workstation_repos(indexed)}
    discovered_paths = {
        repo_path.relative_to(root).as_posix()
        for repo_path in discovered
    }
    missing = sorted(existing_paths - discovered_paths)
    external_existing_paths = {repo["path"] for repo in normalize_workstation_repos(external_indexed)}
    external_discovered_paths = {
        repo_path.relative_to(root).as_posix()
        for repo_path in external_discovered
    }
    external_missing = sorted(external_existing_paths - external_discovered_paths)
    changed = write_workstation_manifest(yml, workstation_name, indexed, external_indexed)

    heading("summary")
    info(f"workstation: {BOLD}{root}{RESET}")
    info(f"manifest:    {BOLD}{yml}{RESET}")
    info(f"discovered:  {len(discovered)}")
    info(f"added: {added}, updated: {updated}, unchanged: {unchanged}, missing: {len(missing)}")
    info(
        f"external:    {len(external_discovered)} "
        f"(added: {external_added}, updated: {external_updated}, "
        f"unchanged: {external_unchanged}, missing: {len(external_missing)})"
    )
    if missing:
        info(f"kept missing entries: {YELLOW}{', '.join(missing)}{RESET}")
    if external_missing:
        info(f"kept missing external entries: {YELLOW}{', '.join(external_missing)}{RESET}")
    if missing_upstream:
        info(f"repos without upstream: {YELLOW}{missing_upstream}{RESET}")
    if external_missing_upstream:
        info(f"external repos without upstream: {YELLOW}{external_missing_upstream}{RESET}")
    if changed:
        ok("workstation.yml updated")
    else:
        ok("workstation.yml already current")
    return 0


def workstation_clone_branch(repo: dict) -> str:
    upstream = repo.get("upstream", "")
    remote = repo.get("remote", "")
    if upstream and "/" in upstream:
        up_remote, up_branch = upstream.split("/", 1)
        if not remote or remote == up_remote:
            return up_branch
    branch = repo.get("branch", "")
    return "" if branch == "HEAD" else branch


def resolve_workstation_repo_path(root: Path, repo: dict) -> Path:
    rel = repo.get("path") or repo.get("name") or ""
    if not rel:
        raise ValueError("missing repo path")
    path = Path(rel)
    if path.is_absolute():
        raise ValueError(f"path must be relative to workstation root: {rel}")
    resolved = (root / path).resolve()
    try:
        resolved.relative_to(root)
    except ValueError:
        raise ValueError(f"path escapes workstation root: {rel}")
    return resolved


def cmd_setup() -> int:
    root = Path.cwd().resolve()
    yml = root / WORKSTATION_FILE
    if not yml.is_file():
        die(f"no {WORKSTATION_FILE} at {root}; run `mkwst index` first or create it")

    data = read_workstation_manifest(yml)
    repos = normalize_workstation_repos(data["repos"])
    if not repos:
        heading("workstation setup")
        info("no repos recorded")
        return 0

    info(f"setting up {len(repos)} repo(s) from {WORKSTATION_FILE}...")

    def worker(repo: dict, log: RepoLog) -> str:
        label = repo.get("path") or repo.get("name") or "(unknown)"
        log.heading(label)
        try:
            dest = resolve_workstation_repo_path(root, repo)
        except ValueError as e:
            log.fail(str(e))
            return "failed"

        if dest.exists():
            if is_git_repo_path(dest):
                log.info("already present")
                return "skipped"
            log.fail(f"path exists but is not a git repo: {dest}")
            return "failed"

        remote = repo.get("remote", "")
        remote_url_value = repo.get("remote_url", "")
        if not remote_url_value:
            log.fail("missing remote_url in workstation.yml")
            return "failed"

        dest.parent.mkdir(parents=True, exist_ok=True)
        cmd = ["git", "clone"]
        if remote:
            cmd.extend(["--origin", remote])
        branch = workstation_clone_branch(repo)
        if branch:
            cmd.extend(["--branch", branch])
        cmd.extend([remote_url_value, str(dest)])

        log.info("git clone")
        proc = run(cmd)
        log.raw((proc.stdout or "").rstrip())
        log.raw((proc.stderr or "").rstrip())
        if proc.returncode != 0:
            log.fail(f"clone failed for {label}")
            return "failed"
        log.ok(f"cloned {label}")
        return "cloned"

    results = run_in_parallel(repos, worker, max_workers=4)
    cloned = sum(1 for r in results if r == "cloned")
    skipped = sum(1 for r in results if r == "skipped")
    failed_repos = [repos[i].get("path") or repos[i].get("name") for i, r in enumerate(results) if r == "failed"]
    failed = len(failed_repos)

    heading("summary")
    color = GREEN if failed == 0 else YELLOW
    info(f"workstation: {BOLD}{root}{RESET}")
    info(f"cloned: {color}{cloned}{RESET}, skipped: {skipped}, failed: {color}{failed}{RESET}")
    if failed_repos:
        info(f"failed: {RED}{', '.join(failed_repos)}{RESET}")
    return 0 if failed == 0 else 1


def split_present_workstation_repos(root: Path, repos: list) -> tuple:
    kept = []
    removed = []
    for repo in normalize_workstation_repos(repos):
        label = repo.get("path") or repo.get("name") or "(unknown)"
        try:
            dest = resolve_workstation_repo_path(root, repo)
        except ValueError as e:
            removed.append((label, str(e)))
            continue
        if is_git_repo_path(dest):
            kept.append(repo)
        elif dest.exists():
            removed.append((label, f"path exists but is not a git repo: {dest}"))
        else:
            removed.append((label, f"path missing: {dest}"))
    return kept, removed


def cmd_clean_workstation(folder: str = "") -> int:
    path = Path(folder) if folder else Path.cwd()
    if not path.is_absolute():
        path = Path.cwd() / path
    root = path.resolve()
    yml = root / WORKSTATION_FILE
    if not yml.is_file():
        die(f"no {WORKSTATION_FILE} at {root}; run from a workstation root or pass one")

    data = read_workstation_manifest(yml)
    workstation_name = data["name"] or root.name
    repos, removed = split_present_workstation_repos(root, data["repos"])
    external_repos, external_removed = split_present_workstation_repos(
        root,
        data.get("_external", {}).get("repos", []),
    )
    changed = write_workstation_manifest(yml, workstation_name, repos, external_repos)

    heading("workstation clean")
    for label, reason in removed:
        ok(f"removed stale repo metadata: {label} ({reason})")
    for label, reason in external_removed:
        ok(f"removed stale external repo metadata: {label} ({reason})")
    if not removed and not external_removed:
        info("no stale repo metadata found")

    heading("summary")
    info(f"workstation: {BOLD}{root}{RESET}")
    info(f"manifest:    {BOLD}{yml}{RESET}")
    info(f"repos kept: {len(repos)}, removed: {len(removed)}")
    info(f"external kept: {len(external_repos)}, removed: {len(external_removed)}")
    if changed:
        ok("workstation.yml updated")
    else:
        ok("workstation.yml already current")
    return 0


USAGE = """\
Usage:
  mkwst index
  mkwst setup
  mkwst clean [<workstation-folder>]

Modes:
  index      Build or refresh workstation.yml in the current folder. Scans
             immediate child git repos, adds repos not yet recorded, and
             refreshes each repo's path, remote, upstream, and current branch
             metadata. Also scans immediate git repos under `_external/` and
             records them under `_external.repos`. Does not fetch, delete stale
             entries, or scan local_workspaces/.
             Example:
               mkwst index
  setup      Read workstation.yml in the current folder and clone any recorded
             repo whose path is missing. Existing git repos are skipped.
             Existing non-git paths fail. Uses remote_url and the recorded
             upstream branch when available.
             Example:
               mkwst setup
  clean      Remove stale repo metadata from workstation.yml when the recorded
             path is missing or no longer a git repo. Does not delete repo
             directories, fetch, pull, or add newly discovered repos.
             Examples:
               mkwst clean
               mkwst clean /abs/path/to/workstation

Environment:
  NO_COLOR      set to any value to disable colored output.
"""


def parse_args(argv):
    argv = list(argv)
    if not argv:
        print(USAGE)
        sys.exit(0)
    if argv[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)

    mode = argv.pop(0)
    target_path = ""
    if mode not in {"index", "setup", "clean"}:
        die(f"unknown subcommand: {mode}\n\n{USAGE}")
    if mode in {"index", "setup"} and argv:
        die(f"'{mode}' takes no args")
    if mode == "clean":
        if argv and not argv[0].startswith("-"):
            target_path = argv.pop(0)
        if argv:
            die("'clean' takes an optional workstation folder only")
    return mode, target_path


def main() -> None:
    if not has_cmd("git"):
        die("git not installed")

    mode, target_path = parse_args(sys.argv[1:])
    if mode == "index":
        sys.exit(cmd_index())
    if mode == "setup":
        sys.exit(cmd_setup())
    if mode == "clean":
        sys.exit(cmd_clean_workstation(target_path))
    die(f"unknown mode: {mode}")


if __name__ == "__main__":
    main()
