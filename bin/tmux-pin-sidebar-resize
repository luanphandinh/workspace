#!/bin/sh
# Force every pinned-sessions sidebar back to its canonical width across
# the whole tmux server. Used after monitor plug/unplug when tmux layout
# caching has left the strip at a wrong width / wrong window proportion.
#
# Strategy: kill every tagged sidebar pane and immediately re-attach a
# fresh one to the same window via tmux-pin-sidebar-attach. A plain
# `resize-pane -x` only nudges the pane within whatever (potentially
# stale) layout tmux has cached — it doesn't refresh the surrounding
# window. Recreating the pane forces tmux to re-evaluate the layout and
# the new sidebar comes up at the canonical 22-col width every time.
#
# Discovery is via the pane-level option @pin_sidebar=1 (set by
# tmux-pin-sidebar-attach when the pane is created and re-asserted by
# tmux-pin-sidebar on every render).
WIDTH=22

# Collect "<window_id> <pane_id>" pairs for every tagged sidebar.
pairs="$(tmux list-panes -aF '#{window_id}|#{pane_id}|#{@pin_sidebar}' 2>/dev/null \
	| awk -F'|' '$3 == "1" { print $1, $2 }')"

if [ -z "$pairs" ]; then
	tmux display-message "no pinned sidebars to resize"
	exit 0
fi

# Force every window to the current client viewport BEFORE we kill+recreate
# any panes. tmux normally only resizes windows that a client is actively
# viewing; without this, inactive sessions would have their sidebar
# recreated against a stale (possibly tiny) cached window size.
"$HOME/bin/tmux-pin-fit-windows" >/dev/null 2>&1 || :

# Make sure the global flag is on — tmux-pin-sidebar-attach gates on it.
tmux set-option -g '@pin_sidebar_open' '1' >/dev/null 2>&1 || :

# Kill every tagged sidebar pane first.
printf '%s\n' "$pairs" | while IFS=' ' read -r _win pane; do
	[ -z "$pane" ] && continue
	tmux kill-pane -t "$pane" >/dev/null 2>&1 || :
done

# Re-attach a fresh sidebar into each affected window. Dedupe windows in
# case future changes ever permit multiple sidebars per window.
printf '%s\n' "$pairs" | awk '{ print $1 }' | sort -u | while IFS= read -r win; do
	[ -z "$win" ] && continue
	"$HOME/bin/tmux-pin-sidebar-attach" "$win" >/dev/null 2>&1 || :
done

tmux display-message "pinned sidebar reset to ${WIDTH} cols (all sessions)"
